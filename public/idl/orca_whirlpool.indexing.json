{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "protocolId": "orca-whirlpool-mainnet",
  "label": "Orca Whirlpool Declarative Runtime",
  "programId": "$protocol.programId",
  "decoderArtifacts": {
    "orca_whirlpool": {
      "kind": "generated_idl_decoder",
      "family": "codama",
      "codamaPath": "/idl/orca_whirlpool.codama.json",
      "artifact": "orca_whirlpool"
    }
  },
  "sources": {
    "orca_whirlpool_crawler": {
      "kind": "rpc_transaction_crawler",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "orca_whirlpool",
      "decodeTargets": [
        "instruction",
        "log_event"
      ],
      "filters": {}
    },
    "orca_whirlpool_snapshot": {
      "kind": "rpc_account_snapshot",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "orca_whirlpool",
      "decodeTargets": [
        "account"
      ],
      "filters": {
        "accountName": "Whirlpool",
        "targetsFrom": {
          "kind": "incomplete_state_from_records",
          "stateRecordName": "Whirlpool",
          "missingFields": [
            "tokenDecimalsA",
            "tokenDecimalsB"
          ],
          "recordNames": [
            "SwapEvent"
          ],
          "addressField": "resource_id",
          "lookbackMinutes": 1440,
          "limit": 500
        }
      }
    },
    "orca_whirlpool_snapshot_backfill": {
      "kind": "rpc_account_snapshot",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "orca_whirlpool",
      "decodeTargets": [
        "account"
      ],
      "filters": {
        "accountName": "Whirlpool",
        "targetsFrom": {
          "kind": "incomplete_state_from_state",
          "stateRecordName": "Whirlpool",
          "missingFields": [
            "tokenDecimalsA",
            "tokenDecimalsB"
          ],
          "limit": 500
        }
      }
    }
  },
  "matchRules": [
    {
      "source": "orca_whirlpool_snapshot",
      "match": {
        "decodedType": "account",
        "name": "Whirlpool"
      },
      "pipeline": "whirlpool_snapshot"
    },
    {
      "source": "orca_whirlpool_snapshot_backfill",
      "match": {
        "decodedType": "account",
        "name": "Whirlpool"
      },
      "pipeline": "whirlpool_snapshot"
    },
    {
      "source": "orca_whirlpool_crawler",
      "match": {
        "decodedType": "event",
        "name": "TradedEvent"
      },
      "pipeline": "whirlpool_trade"
    }
  ],
  "pipelines": {
    "whirlpool_trade": {
      "extract": {
        "pool": "$decoded.whirlpool",
        "marketType": "whirlpool",
        "trader": "$update.signer",
        "aToB": "$decoded.a_to_b",
        "inputAmountAtomic": "$decoded.input_amount",
        "outputAmountAtomic": "$decoded.output_amount",
        "preSqrtPrice": "$decoded.pre_sqrt_price",
        "postSqrtPrice": "$decoded.post_sqrt_price",
        "lpFeeAtomic": "$decoded.lp_fee",
        "protocolFeeAtomic": "$decoded.protocol_fee",
        "signature": "$update.signature",
        "slot": "$update.slot",
        "observedAt": "$update.eventTime"
      },
      "resolve": [
        {
          "name": "whirlpoolState",
          "resolve": "state.lookup",
          "recordName": "Whirlpool",
          "subjectId": "$ctx.pool",
          "required": true,
          "requiredFields": [
            "marketType",
            "tokenMintA",
            "tokenMintB",
            "tokenVaultA",
            "tokenVaultB",
            "tokenDecimalsA",
            "tokenDecimalsB",
            "tickSpacing",
            "feeRateBps",
            "liquidity",
            "tickCurrentIndex",
            "vaultBalanceAUi",
            "vaultBalanceBUi"
          ]
        }
      ],
      "compute": [
        {
          "name": "side",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "sell_a",
          "else": "buy_a"
        },
        {
          "name": "tokenInMint",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$whirlpoolState.tokenMintA",
          "else": "$whirlpoolState.tokenMintB"
        },
        {
          "name": "tokenOutMint",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$whirlpoolState.tokenMintB",
          "else": "$whirlpoolState.tokenMintA"
        },
        {
          "name": "inputDecimals",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$whirlpoolState.tokenDecimalsA",
          "else": "$whirlpoolState.tokenDecimalsB"
        },
        {
          "name": "outputDecimals",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$whirlpoolState.tokenDecimalsB",
          "else": "$whirlpoolState.tokenDecimalsA"
        },
        {
          "name": "amountInUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.inputAmountAtomic",
          "decimals": "$inputDecimals"
        },
        {
          "name": "amountOutUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.outputAmountAtomic",
          "decimals": "$outputDecimals"
        },
        {
          "name": "baseAmountUi",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$amountInUi",
          "else": "$amountOutUi"
        },
        {
          "name": "quoteAmountUi",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$amountOutUi",
          "else": "$amountInUi"
        },
        {
          "name": "priceQuote",
          "compute": "math.safe_div",
          "dividend": "$quoteAmountUi",
          "divisor": "$baseAmountUi"
        },
        {
          "name": "inversePriceQuote",
          "compute": "math.safe_div",
          "dividend": 1,
          "divisor": "$priceQuote"
        },
        {
          "name": "vaultBalanceAAdded",
          "compute": "math.add",
          "values": [
            "$whirlpoolState.vaultBalanceAUi",
            "$amountInUi"
          ]
        },
        {
          "name": "vaultBalanceASubtracted",
          "compute": "math.sub",
          "values": [
            "$whirlpoolState.vaultBalanceAUi",
            "$amountOutUi"
          ]
        },
        {
          "name": "vaultBalanceBAdded",
          "compute": "math.add",
          "values": [
            "$whirlpoolState.vaultBalanceBUi",
            "$amountInUi"
          ]
        },
        {
          "name": "vaultBalanceBSubtracted",
          "compute": "math.sub",
          "values": [
            "$whirlpoolState.vaultBalanceBUi",
            "$amountOutUi"
          ]
        },
        {
          "name": "updatedVaultBalanceAUi",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$vaultBalanceAAdded",
          "else": "$vaultBalanceASubtracted"
        },
        {
          "name": "updatedVaultBalanceBUi",
          "compute": "logic.if",
          "condition": "$ctx.aToB",
          "then": "$vaultBalanceBSubtracted",
          "else": "$vaultBalanceBAdded"
        },
        {
          "name": "baseReserveQuoteValue",
          "compute": "math.mul",
          "values": [
            "$updatedVaultBalanceAUi",
            "$priceQuote"
          ]
        },
        {
          "name": "liquidityQuote",
          "compute": "math.add",
          "values": [
            "$baseReserveQuoteValue",
            "$updatedVaultBalanceBUi"
          ]
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "SwapEvent",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.trader",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "trader": "$ctx.trader",
            "side": "$side",
            "tokenInMint": "$tokenInMint",
            "tokenOutMint": "$tokenOutMint",
            "amountInUi": "$amountInUi",
            "amountOutUi": "$amountOutUi",
            "priceQuote": "$priceQuote",
            "quoteNotionalUi": "$quoteAmountUi",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "Whirlpool",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "marketType": "$whirlpoolState.marketType",
            "tokenMintA": "$whirlpoolState.tokenMintA",
            "tokenMintB": "$whirlpoolState.tokenMintB",
            "tokenVaultA": "$whirlpoolState.tokenVaultA",
            "tokenVaultB": "$whirlpoolState.tokenVaultB",
            "tokenDecimalsA": "$whirlpoolState.tokenDecimalsA",
            "tokenDecimalsB": "$whirlpoolState.tokenDecimalsB",
            "tickSpacing": "$whirlpoolState.tickSpacing",
            "feeRateBps": "$whirlpoolState.feeRateBps",
            "liquidity": "$whirlpoolState.liquidity",
            "tickCurrentIndex": "$whirlpoolState.tickCurrentIndex",
            "priceQuote": "$priceQuote",
            "inversePriceQuote": "$inversePriceQuote",
            "vaultBalanceAUi": "$updatedVaultBalanceAUi",
            "vaultBalanceBUi": "$updatedVaultBalanceBUi",
            "liquidityQuote": "$liquidityQuote",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "whirlpool_snapshot": {
      "extract": {
        "pool": "$update.pubkey",
        "marketType": "whirlpool",
        "tokenMintA": "$decoded.token_mint_a",
        "tokenMintB": "$decoded.token_mint_b",
        "tokenVaultA": "$decoded.token_vault_a",
        "tokenVaultB": "$decoded.token_vault_b",
        "tickSpacing": "$decoded.tick_spacing",
        "feeRateRaw": "$decoded.fee_rate",
        "liquidity": "$decoded.liquidity",
        "tickCurrentIndex": "$decoded.tick_current_index",
        "sqrtPrice": "$decoded.sqrt_price",
        "observedAt": "$update.eventTime"
      },
      "resolve": [
        {
          "name": "mintAInfo",
          "resolve": "rpc.token_supply",
          "mint": "$ctx.tokenMintA"
        },
        {
          "name": "mintBInfo",
          "resolve": "rpc.token_supply",
          "mint": "$ctx.tokenMintB"
        },
        {
          "name": "vaultBalanceA",
          "resolve": "rpc.token_account_balance",
          "account": "$ctx.tokenVaultA"
        },
        {
          "name": "vaultBalanceB",
          "resolve": "rpc.token_account_balance",
          "account": "$ctx.tokenVaultB"
        }
      ],
      "compute": [
        {
          "name": "priceQuote",
          "compute": "math.sqrt_price_x64_to_price",
          "sqrtPriceX64": "$ctx.sqrtPrice",
          "decimalsA": "$mintAInfo.decimals",
          "decimalsB": "$mintBInfo.decimals"
        },
        {
          "name": "inversePriceQuote",
          "compute": "math.safe_div",
          "dividend": 1,
          "divisor": "$priceQuote"
        },
        {
          "name": "baseReserveQuoteValue",
          "compute": "math.mul",
          "values": [
            "$vaultBalanceA.uiAmount",
            "$priceQuote"
          ]
        },
        {
          "name": "liquidityQuote",
          "compute": "math.add",
          "values": [
            "$baseReserveQuoteValue",
            "$vaultBalanceB.uiAmount"
          ]
        },
        {
          "name": "feeRateBps",
          "compute": "math.safe_div",
          "dividend": "$ctx.feeRateRaw",
          "divisor": 100
        }
      ],
      "emit": {
        "state": {
          "recordKind": "account",
          "recordName": "Whirlpool",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "tokenMintA": "$ctx.tokenMintA",
            "tokenMintB": "$ctx.tokenMintB",
            "tokenVaultA": "$ctx.tokenVaultA",
            "tokenVaultB": "$ctx.tokenVaultB",
            "tokenDecimalsA": "$mintAInfo.decimals",
            "tokenDecimalsB": "$mintBInfo.decimals",
            "tickSpacing": "$ctx.tickSpacing",
            "feeRateBps": "$feeRateBps",
            "liquidity": "$ctx.liquidity",
            "tickCurrentIndex": "$ctx.tickCurrentIndex",
            "priceQuote": "$priceQuote",
            "inversePriceQuote": "$inversePriceQuote",
            "vaultBalanceAUi": "$vaultBalanceA.uiAmount",
            "vaultBalanceBUi": "$vaultBalanceB.uiAmount",
            "liquidityQuote": "$liquidityQuote",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    }
  },
  "operations": {
    "best_pool_for_pair": {
      "index_view": {
        "kind": "search",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "orca-whirlpool-mainnet",
          "record_kind": "account",
          "record_name": "Whirlpool",
          "notes": "Canonical Whirlpool pool directory ordered by indexed liquidity."
        },
        "projection": {
          "projection_kind": "search",
          "filters": {
            "any": [
              {
                "all": [
                  {
                    "field": "tokenMintA",
                    "op": "=",
                    "value": "$input.token_in_mint"
                  },
                  {
                    "field": "tokenMintB",
                    "op": "=",
                    "value": "$input.token_out_mint"
                  }
                ]
              },
              {
                "all": [
                  {
                    "field": "tokenMintA",
                    "op": "=",
                    "value": "$input.token_out_mint"
                  },
                  {
                    "field": "tokenMintB",
                    "op": "=",
                    "value": "$input.token_in_mint"
                  }
                ]
              }
            ]
          },
          "sort_by": [
            {
              "field": "liquidityQuote",
              "dir": "desc"
            },
            {
              "field": "updatedAt",
              "dir": "desc"
            }
          ]
        },
        "inputs": {
          "token_in_mint": {
            "type": "token_mint",
            "required": false
          },
          "token_out_mint": {
            "type": "token_mint",
            "required": false
          }
        },
        "read_output": {
          "type": "object",
          "source": "$items.0",
          "object_schema": {
            "entity_type": "orca_whirlpool",
            "identity_fields": [
              "pool"
            ],
            "fields": {
              "subjectId": {
                "type": "pubkey",
                "required": true
              },
              "resourceId": {
                "type": "pubkey",
                "required": true
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "marketType": {
                "type": "string",
                "required": true
              },
              "tokenMintA": {
                "type": "pubkey",
                "required": true
              },
              "tokenMintB": {
                "type": "pubkey",
                "required": true
              },
              "tokenVaultA": {
                "type": "pubkey",
                "required": true
              },
              "tokenVaultB": {
                "type": "pubkey",
                "required": true
              },
              "tokenDecimalsA": {
                "type": "u8",
                "required": true
              },
              "tokenDecimalsB": {
                "type": "u8",
                "required": true
              },
              "tickSpacing": {
                "type": "u16",
                "required": true
              },
              "feeRateBps": {
                "type": "number",
                "required": true
              },
              "liquidity": {
                "type": "u128",
                "required": true
              },
              "tickCurrentIndex": {
                "type": "i32",
                "required": true
              },
              "priceQuote": {
                "type": "number",
                "required": true
              },
              "inversePriceQuote": {
                "type": "number",
                "required": true
              },
              "vaultBalanceAUi": {
                "type": "number",
                "required": true
              },
              "vaultBalanceBUi": {
                "type": "number",
                "required": true
              },
              "liquidityQuote": {
                "type": "number",
                "required": true
              },
              "observedAt": {
                "type": "timestamp",
                "required": true
              },
              "updatedAt": {
                "type": "timestamp",
                "required": false
              },
              "lastEventTime": {
                "type": "timestamp",
                "required": false
              }
            }
          }
        }
      }
    },
    "trade_feed": {
      "index_view": {
        "kind": "feed",
        "canonical": {
          "source": "indexed_idl_records",
          "protocol_id": "orca-whirlpool-mainnet",
          "record_kind": "event",
          "record_name": "SwapEvent",
          "subject_input": "pool",
          "resource_input": "pool",
          "resource_field": "resource_id",
          "time_field": "event_time",
          "notes": "Recent canonical Orca swap records ordered by event time."
        },
        "projection": {
          "projection_kind": "feed",
          "group_by": [
            "subject_id"
          ],
          "sort_by": [
            {
              "field": "event_time",
              "dir": "desc"
            }
          ]
        },
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          },
          "limit": {
            "type": "u16",
            "required": false,
            "default": 50
          }
        },
        "read_output": {
          "type": "array",
          "source": "$items",
          "item_schema": {
            "entity_type": "orca_swap",
            "identity_fields": [
              "signature"
            ],
            "fields": {
              "signature": {
                "type": "string",
                "required": true
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "trader": {
                "type": "pubkey",
                "required": false
              },
              "side": {
                "type": "string",
                "required": true
              },
              "eventTime": {
                "type": "timestamp",
                "required": true
              },
              "tokenInMint": {
                "type": "pubkey",
                "required": false
              },
              "tokenOutMint": {
                "type": "pubkey",
                "required": false
              },
              "amountInUi": {
                "type": "number",
                "required": false
              },
              "amountOutUi": {
                "type": "number",
                "required": false
              },
              "quoteNotionalUi": {
                "type": "number",
                "required": true
              },
              "priceQuote": {
                "type": "number",
                "required": true
              }
            }
          }
        }
      }
    },
    "market_cap_series": {
      "index_view": {
        "kind": "series",
        "canonical": {
          "source": "indexed_series_1m",
          "protocol_id": "orca-whirlpool-mainnet",
          "series_id": "orca.whirlpool.market.1m",
          "subject_input": "pool",
          "resource_input": "pool",
          "time_field": "bucket_start",
          "notes": "Canonical 1m Orca Whirlpool market series projected from canonical swap records."
        },
        "projection": {
          "projection_kind": "series",
          "source_operation": "trade_feed",
          "group_by": [
            "subject_id"
          ],
          "bucket": "1m",
          "fill_mode": "sparse",
          "aggregations": [
            {
              "name": "open",
              "field": "priceQuote",
              "fn": "first"
            },
            {
              "name": "high",
              "field": "priceQuote",
              "fn": "max"
            },
            {
              "name": "low",
              "field": "priceQuote",
              "fn": "min"
            },
            {
              "name": "close",
              "field": "priceQuote",
              "fn": "last"
            },
            {
              "name": "volumeQuote",
              "field": "quoteNotionalUi",
              "fn": "sum"
            },
            {
              "name": "tradeCount",
              "field": "*",
              "fn": "count"
            }
          ]
        },
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          },
          "limit": {
            "type": "u16",
            "required": false,
            "default": 240
          },
          "from": {
            "type": "string",
            "required": false
          },
          "to": {
            "type": "string",
            "required": false
          },
          "interval": {
            "type": "string",
            "required": false,
            "default": "1m"
          },
          "mode": {
            "type": "string",
            "required": false,
            "default": "sparse"
          }
        },
        "read_output": {
          "type": "array",
          "source": "$items",
          "item_schema": {
            "entity_type": "orca_market_series_point",
            "identity_fields": [
              "bucketStart"
            ],
            "fields": {
              "bucketStart": {
                "type": "timestamp",
                "required": true
              },
              "open": {
                "type": "number",
                "required": true
              },
              "high": {
                "type": "number",
                "required": true
              },
              "low": {
                "type": "number",
                "required": true
              },
              "close": {
                "type": "number",
                "required": true
              },
              "volumeQuote": {
                "type": "number",
                "required": true
              },
              "tradeCount": {
                "type": "u32",
                "required": true
              }
            }
          }
        }
      }
    },
    "pools_get": {
      "index_view": {
        "kind": "account",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "orca-whirlpool-mainnet",
          "record_kind": "account",
          "record_name": "Whirlpool",
          "resource_input": "pool",
          "resource_field": "resource_id",
          "notes": "Read the latest canonical Whirlpool state by pool address."
        },
        "projection": {
          "projection_kind": "snapshot",
          "group_by": [
            "resource_id"
          ]
        },
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          }
        },
        "read_output": {
          "type": "object",
          "source": "$items.0",
          "object_schema": {
            "entity_type": "orca_whirlpool",
            "identity_fields": [
              "pool"
            ],
            "fields": {
              "subjectId": {
                "type": "pubkey",
                "required": true
              },
              "resourceId": {
                "type": "pubkey",
                "required": true
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "marketType": {
                "type": "string",
                "required": true
              },
              "tokenMintA": {
                "type": "pubkey",
                "required": true
              },
              "tokenMintB": {
                "type": "pubkey",
                "required": true
              },
              "tokenVaultA": {
                "type": "pubkey",
                "required": true
              },
              "tokenVaultB": {
                "type": "pubkey",
                "required": true
              },
              "tokenDecimalsA": {
                "type": "u8",
                "required": true
              },
              "tokenDecimalsB": {
                "type": "u8",
                "required": true
              },
