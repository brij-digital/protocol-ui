{
  "$schema": "/idl/solana_agent_runtime.schema.v1.json",
  "schema": "solana-agent-runtime.v1",
  "protocol": {
    "protocolId": "pump-amm-mainnet",
    "programId": "$protocol.programId",
    "codamaPath": "/idl/pump_amm.codama.json"
  },
  "computes": {
    "preview_buy": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112"
        },
        "quote_amount_in": {
          "type": "u64",
          "required": true
        },
        "track_volume": {
          "type": "bool",
          "required": false,
          "default": true
        },
        "pool": {
          "type": "pubkey",
          "required": true
        },
        "slippage_bps": {
          "type": "u16",
          "required": true
        }
      },
      "use": [
        {
          "template": "pump.buy.v1",
          "with": {
            "base_mint": "$input.base_mint",
            "quote_mint": "$input.quote_mint",
            "quote_amount_in": "$input.quote_amount_in",
            "slippage_bps": "$input.slippage_bps",
            "track_volume": "$input.track_volume"
          }
        }
      ],
      "read_output": {
        "type": "object",
        "source": "$derived",
        "object_schema": {
          "entity_type": "pump_preview_buy",
          "fields": {
            "pool": {
              "type": "pubkey",
              "required": false
            },
            "base_mint": {
              "type": "pubkey",
              "required": false
            },
            "quote_mint": {
              "type": "pubkey",
              "required": false
            },
            "quote_amount_in": {
              "type": "u64",
              "required": false
            },
            "slippage_bps": {
              "type": "u16",
              "required": false
            },
            "estimated_base_amount_out": {
              "type": "u64",
              "required": false
            },
            "minimum_base_amount_out": {
              "type": "u64",
              "required": false
            },
            "price_quote": {
              "type": "number",
              "required": false
            },
            "market_cap_quote": {
              "type": "number",
              "required": false
            }
          }
        }
      }
    },
    "preview_sell": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112"
        },
        "pool": {
          "type": "pubkey",
          "required": true
        },
        "base_amount_in": {
          "type": "u64",
          "required": true
        },
        "min_quote_amount_out": {
          "type": "u64",
          "required": false,
          "default": "1"
        }
      },
      "use": [
        {
          "template": "pump.sell.v1",
          "with": {
            "base_mint": "$input.base_mint",
            "quote_mint": "$input.quote_mint",
            "base_amount_in": "$input.base_amount_in",
            "min_quote_amount_out": "$input.min_quote_amount_out"
          }
        }
      ],
      "read_output": {
        "type": "object",
        "source": "$derived",
        "object_schema": {
          "entity_type": "pump_preview_sell",
          "fields": {
            "pool": {
              "type": "pubkey",
              "required": false
            },
            "base_mint": {
              "type": "pubkey",
              "required": false
            },
            "quote_mint": {
              "type": "pubkey",
              "required": false
            },
            "base_amount_in": {
              "type": "u64",
              "required": false
            },
            "min_quote_amount_out": {
              "type": "u64",
              "required": false
            },
            "estimated_quote_amount_out": {
              "type": "u64",
              "required": false
            },
            "price_quote": {
              "type": "number",
              "required": false
            },
            "market_cap_quote": {
              "type": "number",
              "required": false
            }
          }
        }
      }
    }
  },
  "templates": {
    "pump.buy.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey"
        },
        "quote_amount_in": {
          "type": "u64"
        },
        "slippage_bps": {
          "type": "u16"
        },
        "track_volume": {
          "type": "bool"
        }
      },
      "expand": {
        "instruction": "buy",
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "pool_data",
            "resolver": "decode_account",
            "address": "$input.pool",
            "account_type": "Pool"
          },
          {
            "name": "global_config",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_config"
            ]
          },
          {
            "name": "global_config_data",
            "resolver": "decode_account",
            "address": "$global_config",
            "account_type": "GlobalConfig"
          },
          {
            "name": "base_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.base_mint"
          },
          {
            "name": "quote_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.quote_mint"
          },
          {
            "name": "user_base_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "name": "user_quote_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "name": "coin_creator_vault_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:creator_vault",
              "$pool_data.coin_creator"
            ]
          },
          {
            "name": "coin_creator_vault_ata",
            "resolver": "ata",
            "owner": "$coin_creator_vault_authority",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "global_volume_accumulator",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_volume_accumulator"
            ]
          },
          {
            "name": "user_volume_accumulator",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:user_volume_accumulator",
              "$wallet"
            ]
          },
          {
            "name": "user_volume_accumulator_wsol_ata",
            "resolver": "ata",
            "owner": "$user_volume_accumulator",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "event_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:__event_authority"
            ]
          },
          {
            "name": "fee_config",
            "resolver": "pda",
            "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
            "seeds": [
              "utf8:fee_config",
              "$protocol.programId"
            ]
          },
          {
            "name": "fee_config_data",
            "resolver": "decode_account",
            "address": "$fee_config",
            "account_type": "FeeConfig"
          },
          {
            "name": "pump_pool_authority",
            "resolver": "pda",
            "program_id": "6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P",
            "seeds": [
              "utf8:pool-authority",
              "$pool_data.base_mint"
            ]
          },
          {
            "name": "pool_base_reserve_atomic",
            "resolver": "token_account_balance",
            "address": "$pool_data.pool_base_token_account"
          },
          {
            "name": "pool_quote_reserve_atomic",
            "resolver": "token_account_balance",
            "address": "$pool_data.pool_quote_token_account"
          },
          {
            "name": "base_mint_supply_atomic",
            "resolver": "token_supply",
            "mint": "$pool_data.base_mint"
          },
          {
            "name": "pool_v2",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:pool-v2",
              "$pool_data.base_mint"
            ]
          }
        ],
        "args": {
          "base_amount_out": "$base_amount_out",
          "max_quote_amount_in": "$max_quote_amount_in",
          "track_volume": "$param.track_volume"
        },
        "pre": [
          {
            "kind": "spl_ata_create_idempotent",
            "payer": "$wallet",
            "ata": "$user_base_token_account",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "kind": "spl_ata_create_idempotent",
            "payer": "$wallet",
            "ata": "$user_quote_token_account",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "kind": "system_transfer",
            "from": "$wallet",
            "to": "$user_quote_token_account",
            "lamports": "$max_quote_amount_in",
            "when": {
              "equals": [
                "$pool_data.quote_mint",
                "So11111111111111111111111111111111111111112"
              ]
            }
          },
          {
            "kind": "spl_token_sync_native",
            "account": "$user_quote_token_account",
            "when": {
              "equals": [
                "$pool_data.quote_mint",
                "So11111111111111111111111111111111111111112"
              ]
            }
          }
        ],
        "accounts": {
          "pool": "$input.pool",
          "global_config": "$global_config",
          "base_mint": "$pool_data.base_mint",
          "quote_mint": "$pool_data.quote_mint",
          "user_base_token_account": "$user_base_token_account",
          "user_quote_token_account": "$user_quote_token_account",
          "pool_base_token_account": "$pool_data.pool_base_token_account",
          "pool_quote_token_account": "$pool_data.pool_quote_token_account",
          "protocol_fee_recipient": "$protocol_fee_recipient",
          "base_token_program": "$base_token_program",
          "quote_token_program": "$quote_token_program",
          "coin_creator_vault_authority": "$coin_creator_vault_authority"
        },
        "remaining_accounts": "$remaining_accounts",
        "compute": [
          {
            "name": "protocol_fee_recipient",
            "compute": "list.get",
            "values": "$global_config_data.protocol_fee_recipients",
            "index": 0
          },
          {
            "name": "protocol_fee_recipient_token_account",
            "compute": "pda(seed_spec)",
            "program_id": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
            "seeds": [
              {
                "kind": "pubkey",
                "value": "$protocol_fee_recipient"
              },
              {
                "kind": "pubkey",
                "value": "$quote_token_program"
              },
              {
                "kind": "pubkey",
                "value": "$pool_data.quote_mint"
              }
            ]
          },
          {
            "name": "remaining_accounts",
            "compute": "logic.if",
            "condition": "$pool_data.is_cashback_coin",
            "then": [
              {
                "pubkey": "$user_volume_accumulator_wsol_ata",
                "isSigner": false,
                "isWritable": true
              },
              {
                "pubkey": "$pool_v2",
                "isSigner": false,
                "isWritable": false
              }
            ],
            "else": [
              {
                "pubkey": "$pool_v2",
                "isSigner": false,
                "isWritable": false
              }
            ]
          },
          {
            "name": "creator_is_default",
            "compute": "compare.equals",
            "left": "$pool_data.coin_creator",
            "right": "11111111111111111111111111111111"
          },
          {
            "name": "is_pump_pool",
            "compute": "compare.equals",
            "left": "$pool_data.creator",
            "right": "$pump_pool_authority"
          },
          {
            "name": "market_cap_numerator",
            "compute": "math.mul",
            "values": [
              "$pool_quote_reserve_atomic",
              "$base_mint_supply_atomic"
            ]
          },
          {
            "name": "market_cap_lamports",
            "compute": "math.floor_div",
            "dividend": "$market_cap_numerator",
            "divisor": "$pool_base_reserve_atomic"
          },
          {
            "name": "fee_tier_candidates",
            "compute": "list.filter",
            "items": "$fee_config_data.fee_tiers",
            "where": [
              {
                "path": "market_cap_lamports_threshold",
                "op": ">=",
                "value": "$market_cap_lamports"
              }
            ]
          },
          {
            "name": "selected_fee_tier_primary",
            "compute": "list.min_by",
            "items": "$fee_tier_candidates",
            "path": "market_cap_lamports_threshold",
            "allow_empty": true
          },
          {
            "name": "selected_fee_tier_default",
            "compute": "list.max_by",
            "items": "$fee_config_data.fee_tiers",
            "path": "market_cap_lamports_threshold",
            "allow_empty": true
          },
          {
            "name": "selected_fee_tier",
            "compute": "coalesce",
            "values": [
              "$selected_fee_tier_primary",
              "$selected_fee_tier_default"
            ]
          },
          {
            "name": "selected_fees_if_pump",
            "compute": "coalesce",
            "values": [
              "$selected_fee_tier.fees",
              "$fee_config_data.flat_fees"
            ]
          },
          {
            "name": "lp_fee_bps",
            "compute": "logic.if",
            "condition": "$is_pump_pool",
            "then": "$selected_fees_if_pump.lp_fee_bps",
            "else": "$global_config_data.lp_fee_basis_points"
          },
          {
            "name": "protocol_fee_bps",
            "compute": "logic.if",
            "condition": "$is_pump_pool",
            "then": "$selected_fees_if_pump.protocol_fee_bps",
            "else": "$global_config_data.protocol_fee_basis_points"
          },
          {
            "name": "creator_fee_bps_raw",
            "compute": "logic.if",
            "condition": "$is_pump_pool",
            "then": "$selected_fees_if_pump.creator_fee_bps",
            "else": "$global_config_data.coin_creator_fee_basis_points"
          },
          {
            "name": "creator_fee_bps",
            "compute": "logic.if",
            "condition": "$creator_is_default",
            "then": "0",
            "else": "$creator_fee_bps_raw"
          },
          {
            "name": "total_fee_bps",
            "compute": "math.add",
            "values": [
              "$lp_fee_bps",
              "$protocol_fee_bps",
              "$creator_fee_bps"
            ]
          },
          {
            "name": "effective_quote_numerator",
            "compute": "math.mul",
            "values": [
              "$param.quote_amount_in",
              "10000"
            ]
          },
          {
            "name": "effective_quote_denominator",
            "compute": "math.add",
            "values": [
              "10000",
              "$total_fee_bps"
            ]
          },
          {
            "name": "effective_quote",
            "compute": "math.floor_div",
            "dividend": "$effective_quote_numerator",
            "divisor": "$effective_quote_denominator"
          },
          {
            "name": "base_amount_out_numerator",
            "compute": "math.mul",
            "values": [
              "$pool_base_reserve_atomic",
              "$effective_quote"
            ]
          },
          {
            "name": "base_amount_out_denominator",
            "compute": "math.add",
            "values": [
              "$pool_quote_reserve_atomic",
              "$effective_quote"
            ]
          },
          {
            "name": "base_amount_out",
            "compute": "math.floor_div",
            "dividend": "$base_amount_out_numerator",
            "divisor": "$base_amount_out_denominator"
          },
          {
            "name": "slippage_factor",
            "compute": "math.add",
            "values": [
              "10000",
              "$param.slippage_bps"
            ]
          },
          {
            "name": "max_quote_amount_in_numerator",
            "compute": "math.mul",
            "values": [
              "$param.quote_amount_in",
              "$slippage_factor"
            ]
          },
          {
            "name": "max_quote_amount_in",
            "compute": "math.floor_div",
            "dividend": "$max_quote_amount_in_numerator",
            "divisor": "10000"
          }
        ]
      }
    },
    "pump.sell.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey"
        },
        "base_amount_in": {
          "type": "u64"
        },
        "min_quote_amount_out": {
          "type": "u64"
        }
      },
      "expand": {
        "instruction": "sell",
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "pool_data",
            "resolver": "decode_account",
            "address": "$input.pool",
            "account_type": "Pool"
          },
          {
            "name": "global_config",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_config"
            ]
          },
          {
            "name": "global_config_data",
            "resolver": "decode_account",
            "address": "$global_config",
            "account_type": "GlobalConfig"
          },
          {
            "name": "base_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.base_mint"
          },
          {
            "name": "quote_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.quote_mint"
          },
          {
            "name": "user_base_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "name": "user_quote_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "name": "coin_creator_vault_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:creator_vault",
              "$pool_data.coin_creator"
            ]
          },
          {
            "name": "coin_creator_vault_ata",
            "resolver": "ata",
            "owner": "$coin_creator_vault_authority",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "event_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:__event_authority"
            ]
          },
          {
            "name": "fee_config",
            "resolver": "pda",
            "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
            "seeds": [
              "utf8:fee_config",
              "$protocol.programId"
            ]
          }
        ],
        "args": {
          "base_amount_in": "$param.base_amount_in",
          "min_quote_amount_out": "$param.min_quote_amount_out"
        },
        "accounts": {
          "pool": "$input.pool",
          "global_config": "$global_config",
          "base_mint": "$pool_data.base_mint",
          "quote_mint": "$pool_data.quote_mint",
          "user_base_token_account": "$user_base_token_account",
          "user_quote_token_account": "$user_quote_token_account",
          "pool_base_token_account": "$pool_data.pool_base_token_account",
          "pool_quote_token_account": "$pool_data.pool_quote_token_account",
          "protocol_fee_recipient": "$protocol_fee_recipient",
          "base_token_program": "$base_token_program",
          "quote_token_program": "$quote_token_program",
          "coin_creator_vault_authority": "$coin_creator_vault_authority"
        },
        "compute": [
          {
            "name": "protocol_fee_recipient",
            "compute": "list.get",
            "values": "$global_config_data.protocol_fee_recipients",
            "index": 0
          },
          {
            "name": "protocol_fee_recipient_token_account",
            "compute": "pda(seed_spec)",
            "program_id": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
            "seeds": [
              {
                "kind": "pubkey",
                "value": "$protocol_fee_recipient"
              },
              {
                "kind": "pubkey",
                "value": "$quote_token_program"
              },
              {
                "kind": "pubkey",
                "value": "$pool_data.quote_mint"
              }
            ]
          }
        ]
      }
    }
  },
  "index_views": {
    "list_tokens": {
      "inputs": {
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112"
        },
        "min_last_seen_slot": {
          "type": "u64",
          "required": false,
          "default": "0"
        }
      },
      "read_output": {
        "source": "$items",
        "type": "array",
        "item_schema": {
          "entity_type": "pump_pool",
          "identity_fields": [
            "pool"
          ],
          "fields": {
            "mint": {
              "type": "pubkey",
              "required": true
            },
            "pool": {
              "type": "pubkey",
              "required": true
            },
            "marketType": {
              "type": "string",
              "required": true
            },
            "quoteMint": {
              "type": "pubkey",
              "required": false
            },
            "priceQuote": {
              "type": "number",
              "required": false
            },
            "marketCapQuote": {
              "type": "number",
              "required": false
            },
            "liquidityQuote": {
              "type": "number",
              "required": false
            },
            "volume24hQuote": {
              "type": "number",
              "required": false
            },
            "priceChange5mPct": {
              "type": "number",
              "required": false
            },
            "priceChange1hPct": {
              "type": "number",
              "required": false
            },
            "priceChange24hPct": {
              "type": "number",
              "required": false
            },
            "latestTradeAt": {
              "type": "timestamp",
              "required": false
            },
            "observedAt": {
              "type": "timestamp",
              "required": false
            },
