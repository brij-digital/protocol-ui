{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "protocolId": "pump-amm-mainnet",
  "label": "Pump AMM Declarative Runtime",
  "programId": "$protocol.programId",
  "decoderArtifacts": {
    "pump_swap": {
      "kind": "generated_idl_decoder",
      "family": "codama",
      "codamaPath": "/idl/pump_amm.codama.json",
      "codecIdlPath": "/idl/pump_amm.json",
      "artifact": "pump_swap"
    }
  },
  "sources": {
    "pump_swap_crawler": {
      "kind": "rpc_transaction_crawler",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "pump_swap",
      "decodeTargets": [
        "instruction",
        "log_event"
      ],
      "filters": {}
    },
    "pump_pool_snapshot": {
      "kind": "rpc_account_snapshot",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "pump_swap",
      "decodeTargets": [
        "account"
      ],
      "filters": {
        "accountName": "Pool",
        "targetsFrom": {
          "kind": "missing_state_from_records",
          "stateRecordName": "PoolMetadata",
          "recordNames": [
            "BuyEvent",
            "SellEvent"
          ],
          "addressField": "resource_id",
          "lookbackMinutes": 1440,
          "limit": 500
        }
      }
    }
  },
  "matchRules": [
    {
      "source": "pump_pool_snapshot",
      "match": {
        "decodedType": "account",
        "name": "Pool"
      },
      "pipeline": "pool_snapshot"
    },
    {
      "source": "pump_swap_crawler",
      "match": {
        "decodedType": "event",
        "name": "CreatePoolEvent"
      },
      "pipeline": "pool_create"
    },
    {
      "source": "pump_swap_crawler",
      "match": {
        "decodedType": "event",
        "name": "BuyEvent"
      },
      "pipeline": "trade_buy"
    },
    {
      "source": "pump_swap_crawler",
      "match": {
        "decodedType": "event",
        "name": "SellEvent"
      },
      "pipeline": "trade_sell"
    }
  ],
  "pipelines": {
    "pool_snapshot": {
      "extract": {
        "pool": "$update.pubkey",
        "mint": "$decoded.base_mint",
        "quoteMint": "$decoded.quote_mint",
        "coinCreator": "$decoded.coin_creator",
        "isCashbackCoin": "$decoded.is_cashback_coin",
        "observedAt": "$update.eventTime"
      },
      "resolve": [
        {
          "name": "baseSupply",
          "resolve": "rpc.token_supply",
          "mint": "$ctx.mint"
        },
        {
          "name": "quoteSupply",
          "resolve": "rpc.token_supply",
          "mint": "$ctx.quoteMint"
        }
      ],
      "emit": {
        "state": {
          "recordKind": "account",
          "recordName": "PoolMetadata",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "mint": "$ctx.mint",
            "quoteMint": "$ctx.quoteMint",
            "baseDecimals": "$baseSupply.decimals",
            "quoteDecimals": "$quoteSupply.decimals",
            "baseSupplyUi": "$baseSupply.supplyUi",
            "coinCreator": "$ctx.coinCreator",
            "isCashbackCoin": "$ctx.isCashbackCoin"
          }
        }
      }
    },
    "pool_create": {
      "extract": {
        "pool": "$decoded.pool",
        "mint": "$decoded.base_mint",
        "quoteMint": "$decoded.quote_mint",
        "baseDecimals": "$decoded.base_mint_decimals",
        "quoteDecimals": "$decoded.quote_mint_decimals",
        "coinCreator": "$decoded.coin_creator",
        "isCashbackCoin": false,
        "observedAt": "$update.eventTime"
      },
      "resolve": [
        {
          "name": "baseSupply",
          "resolve": "rpc.token_supply",
          "mint": "$ctx.mint"
        }
      ],
      "emit": {
        "state": {
          "recordKind": "state",
          "recordName": "PoolMetadata",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "mint": "$ctx.mint",
            "quoteMint": "$ctx.quoteMint",
            "baseDecimals": "$ctx.baseDecimals",
            "quoteDecimals": "$ctx.quoteDecimals",
            "baseSupplyUi": "$baseSupply.supplyUi",
            "coinCreator": "$ctx.coinCreator",
            "isCashbackCoin": "$ctx.isCashbackCoin"
          }
        }
      }
    },
    "trade_buy": {
      "resolve": [
        {
          "name": "poolMeta",
          "resolve": "state.lookup",
          "recordName": "PoolMetadata",
          "subjectId": "$decoded.pool",
          "required": true
        }
      ],
      "extract": {
        "mint": "$poolMeta.mint",
        "pool": "$decoded.pool",
        "marketType": "amm",
        "quoteMint": "$poolMeta.quoteMint",
        "baseDecimals": "$poolMeta.baseDecimals",
        "quoteDecimals": "$poolMeta.quoteDecimals",
        "baseSupplyUi": "$poolMeta.baseSupplyUi",
        "coinCreator": "$poolMeta.coinCreator",
        "isCashbackCoin": "$poolMeta.isCashbackCoin",
        "participant": "$decoded.user",
        "side": "buy",
        "baseAmountAtomic": "$decoded.base_amount_out",
        "quoteAmountAtomic": "$decoded.quote_amount_in",
        "poolBaseReservesAtomic": "$decoded.pool_base_token_reserves",
        "poolQuoteReservesAtomic": "$decoded.pool_quote_token_reserves",
        "signature": "$update.signature",
        "slot": "$update.slot",
        "observedAt": "$update.eventTime"
      },
      "compute": [
        {
          "name": "baseAmountUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.baseAmountAtomic",
          "decimals": "$ctx.baseDecimals"
        },
        {
          "name": "quoteAmountUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.quoteAmountAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "priceQuote",
          "compute": "math.safe_div",
          "dividend": "$quoteAmountUi",
          "divisor": "$baseAmountUi"
        },
        {
          "name": "supplyPositive",
          "compute": "compare.gt",
          "left": "$ctx.baseSupplyUi",
          "right": 0
        },
        {
          "name": "marketCapRaw",
          "compute": "math.mul",
          "values": [
            "$priceQuote",
            "$ctx.baseSupplyUi"
          ]
        },
        {
          "name": "marketCapQuote",
          "compute": "logic.if",
          "condition": "$supplyPositive",
          "then": "$marketCapRaw",
          "else": "$null"
        },
        {
          "name": "baseReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.poolBaseReservesAtomic",
          "decimals": "$ctx.baseDecimals"
        },
        {
          "name": "quoteReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.poolQuoteReservesAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "baseReserveQuoteValue",
          "compute": "math.mul",
          "values": [
            "$baseReserveUi",
            "$priceQuote"
          ]
        },
        {
          "name": "liquidityQuote",
          "compute": "math.add",
          "values": [
            "$baseReserveQuoteValue",
            "$quoteReserveUi"
          ]
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "BuyEvent",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.participant",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "participant": "$ctx.participant",
            "side": "$ctx.side",
            "priceQuote": "$priceQuote",
            "marketCapQuote": "$marketCapQuote",
            "quoteAmountUi": "$quoteAmountUi",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "Pool",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "quoteMint": "$ctx.quoteMint",
            "baseDecimals": "$ctx.baseDecimals",
            "quoteDecimals": "$ctx.quoteDecimals",
            "priceQuote": "$priceQuote",
            "marketCapQuote": "$marketCapQuote",
            "liquidityQuote": "$liquidityQuote",
            "baseReserveUi": "$baseReserveUi",
            "quoteReserveUi": "$quoteReserveUi",
            "baseSupplyUi": "$ctx.baseSupplyUi",
            "coinCreator": "$ctx.coinCreator",
            "isCashbackCoin": "$ctx.isCashbackCoin",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "trade_sell": {
      "resolve": [
        {
          "name": "poolMeta",
          "resolve": "state.lookup",
          "recordName": "PoolMetadata",
          "subjectId": "$decoded.pool",
          "required": true
        }
      ],
      "extract": {
        "mint": "$poolMeta.mint",
        "pool": "$decoded.pool",
        "marketType": "amm",
        "quoteMint": "$poolMeta.quoteMint",
        "baseDecimals": "$poolMeta.baseDecimals",
        "quoteDecimals": "$poolMeta.quoteDecimals",
        "baseSupplyUi": "$poolMeta.baseSupplyUi",
        "coinCreator": "$poolMeta.coinCreator",
        "isCashbackCoin": "$poolMeta.isCashbackCoin",
        "participant": "$decoded.user",
        "side": "sell",
        "baseAmountAtomic": "$decoded.base_amount_in",
        "quoteAmountAtomic": "$decoded.quote_amount_out",
        "poolBaseReservesAtomic": "$decoded.pool_base_token_reserves",
        "poolQuoteReservesAtomic": "$decoded.pool_quote_token_reserves",
        "signature": "$update.signature",
        "slot": "$update.slot",
        "observedAt": "$update.eventTime"
      },
      "compute": [
        {
          "name": "baseAmountUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.baseAmountAtomic",
          "decimals": "$ctx.baseDecimals"
        },
        {
          "name": "quoteAmountUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.quoteAmountAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "priceQuote",
          "compute": "math.safe_div",
          "dividend": "$quoteAmountUi",
          "divisor": "$baseAmountUi"
        },
        {
          "name": "supplyPositive",
          "compute": "compare.gt",
          "left": "$ctx.baseSupplyUi",
          "right": 0
        },
        {
          "name": "marketCapRaw",
          "compute": "math.mul",
          "values": [
            "$priceQuote",
            "$ctx.baseSupplyUi"
          ]
        },
        {
          "name": "marketCapQuote",
          "compute": "logic.if",
          "condition": "$supplyPositive",
          "then": "$marketCapRaw",
          "else": "$null"
        },
        {
          "name": "baseReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.poolBaseReservesAtomic",
          "decimals": "$ctx.baseDecimals"
        },
        {
          "name": "quoteReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.poolQuoteReservesAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "baseReserveQuoteValue",
          "compute": "math.mul",
          "values": [
            "$baseReserveUi",
            "$priceQuote"
          ]
        },
        {
          "name": "liquidityQuote",
          "compute": "math.add",
          "values": [
            "$baseReserveQuoteValue",
            "$quoteReserveUi"
          ]
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "SellEvent",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.participant",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "participant": "$ctx.participant",
            "side": "$ctx.side",
            "priceQuote": "$priceQuote",
            "marketCapQuote": "$marketCapQuote",
            "quoteAmountUi": "$quoteAmountUi",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "Pool",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "quoteMint": "$ctx.quoteMint",
            "baseDecimals": "$ctx.baseDecimals",
            "quoteDecimals": "$ctx.quoteDecimals",
            "priceQuote": "$priceQuote",
            "marketCapQuote": "$marketCapQuote",
            "liquidityQuote": "$liquidityQuote",
            "baseReserveUi": "$baseReserveUi",
            "quoteReserveUi": "$quoteReserveUi",
            "baseSupplyUi": "$ctx.baseSupplyUi",
            "coinCreator": "$ctx.coinCreator",
            "isCashbackCoin": "$ctx.isCashbackCoin",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    }
  },
  "operations": {
    "list_tokens": {
      "inputs": {
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "label": "Quote Mint"
        },
        "min_last_seen_slot": {
          "type": "u64",
          "required": false,
          "default": "0",
          "label": "Min Last Seen Slot"
        }
      },
      "view": {
        "kind": "search",
        "entity_type": "pump_pool",
        "title": "List tokens",
        "description": "List Pump AMM pools for a quote mint.",
        "bootstrap": {
          "kind": "scan_accounts",
          "source": "rpc.getProgramAccounts",
          "program_id": "$protocol.programId",
          "account_type": "Pool",
          "lookback_seconds": 300,
          "max_pages": 5,
          "retention_seconds": 3600,
          "filters": []
        },
        "refresh": {
          "mode": "stream",
          "source": "program_account_updates"
        },
        "query": {
          "indexed_filters": {
            "all": [
              {
                "field": "memcmp.75",
                "op": "=",
                "value": "$input.quote_mint"
              }
            ]
          },
          "filters": {
            "all": [
              {
                "field": "decoded.quote_mint",
                "op": "=",
                "value": "$input.quote_mint"
              },
              {
                "field": "account.lastSeenSlot",
                "op": ">=",
                "value": "$input.min_last_seen_slot"
              },
              {
                "field": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ]
          },
          "hydrate": {
            "mode": "accounts",
            "candidate_limit": 30,
            "fields": [
              "pubkey",
              "data_bytes",
              "slot"
            ]
          },
          "decode": {
            "account_type": "Pool"
          },
          "sort": [
            {
              "field": "account.lastSeenSlot",
              "dir": "desc",
              "mode": "indexed"
            },
            {
              "field": "decoded.index",
              "dir": "desc",
              "mode": "indexed"
            },
            {
              "field": "decoded.lp_supply",
              "dir": "desc",
              "mode": "indexed_then_live_refine",
              "candidate_limit": 30
            }
          ],
          "limit": 30,
          "select": {
            "pool": "$account.pubkey",
            "baseMint": "$decoded.base_mint",
            "quoteMint": "$decoded.quote_mint",
            "index": "$decoded.index",
            "lpSupply": "$decoded.lp_supply",
            "coinCreator": "$decoded.coin_creator",
            "isCashbackCoin": "$decoded.is_cashback_coin"
          }
        }
      },
      "read_output": {
        "source": "$derived.pool_candidates",
        "type": "list",
        "title": "Recent Pump AMM tokens",
        "itemLabelFields": [
          "baseMint",
          "pool",
          "index",
          "lpSupply"
        ],
        "maxItems": 20,
        "emptyText": "No Pump AMM token found for this quote mint."
      },
      "label": "List Tokens",
      "use": [
        {
          "template": "pump.list_tokens.v1",
          "with": {
            "quote_mint": "$input.quote_mint"
          }
        }
      ]
    },
    "view_pool": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true,
          "read_from": "$input.base_mint",
          "ui_mode": "readonly",
          "label": "Base Mint"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "read_from": "$input.quote_mint",
          "ui_mode": "readonly",
          "label": "Quote Mint"
        }
      },
      "view": {
        "kind": "search",
        "entity_type": "pump_pool",
        "title": "View pool",
        "description": "Find a Pump AMM pool for a base/quote pair.",
        "bootstrap": {
          "kind": "scan_accounts",
          "source": "rpc.getProgramAccounts",
          "program_id": "$protocol.programId",
          "account_type": "Pool",
          "lookback_seconds": 300,
          "max_pages": 5,
          "retention_seconds": 3600,
          "filters": []
        },
        "refresh": {
          "mode": "stream",
          "source": "program_account_updates"
        },
        "query": {
          "indexed_filters": {
            "all": [
              {
                "field": "memcmp.43",
                "op": "=",
                "value": "$input.base_mint"
              },
              {
                "field": "memcmp.75",
                "op": "=",
                "value": "$input.quote_mint"
              }
            ]
          },
          "filters": {
            "all": [
              {
                "field": "decoded.base_mint",
                "op": "=",
                "value": "$input.base_mint"
              },
              {
                "field": "decoded.quote_mint",
                "op": "=",
                "value": "$input.quote_mint"
              },
              {
                "field": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ]
          },
          "hydrate": {
            "mode": "accounts",
            "candidate_limit": 5,
            "fields": [
              "pubkey",
              "data_bytes",
              "slot"
            ]
          },
          "decode": {
            "account_type": "Pool"
          },
          "sort": [
            {
              "field": "decoded.index",
              "dir": "desc",
              "mode": "indexed"
            },
            {
              "field": "decoded.lp_supply",
              "dir": "desc",
              "mode": "indexed_then_live_refine",
              "candidate_limit": 5
            }
          ],
          "limit": 1,
          "select": {
            "pool": "$account.pubkey",
            "baseMint": "$decoded.base_mint",
            "quoteMint": "$decoded.quote_mint",
            "index": "$decoded.index",
            "lpSupply": "$decoded.lp_supply",
            "poolBaseTokenAccount": "$decoded.pool_base_token_account",
            "poolQuoteTokenAccount": "$decoded.pool_quote_token_account",
            "coinCreator": "$decoded.coin_creator",
            "isCashbackCoin": "$decoded.is_cashback_coin"
          }
        }
      },
      "read_output": {
        "source": "$derived.pool_detail",
        "type": "list",
        "title": "Pool snapshot (live RPC)",
        "itemLabelFields": [
          "baseMint",
          "pool",
          "lpSupply",
          "poolBaseTokenAccount",
          "poolQuoteTokenAccount"
        ],
        "maxItems": 1,
        "emptyText": "Pool not found."
      },
      "label": "View Pool",
      "use": [
        {
          "template": "pump.view_pool.v1",
          "with": {
            "base_mint": "$input.base_mint",
            "quote_mint": "$input.quote_mint"
          }
        }
      ]
    },
    "resolve_pool": {
      "inputs": {
        "mint": {
          "type": "pubkey",
          "required": true,
          "label": "Mint"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "label": "Quote Mint"
        }
      },
      "view": {
        "kind": "search",
        "source_kind": "account_changes",
        "sync_disabled": true,
        "freshness": {
          "class": "near_realtime",
          "target_ms": 5000,
          "max_staleness_ms": 20000
        },
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "pump-amm-mainnet",
          "record_kind": "account",
          "record_name": [
            "Pool",
            "BondingCurve"
          ],
          "subject_input": "mint",
          "subject_field": "subject_id",
          "resource_field": "resource_id",
          "notes": "Resolve a mint to its current projected state derived from IDL-native records."
        },
        "projection": {
          "projection_kind": "snapshot",
          "group_by": [
            "subject_id"
          ]
        },
        "entity_type": "pump_pool",
        "title": "Resolve pool",
        "description": "Resolve the Pump AMM pool for a token mint against a quote mint.",
        "bootstrap": {
          "kind": "scan_accounts",
          "source": "rpc.getProgramAccounts",
          "program_id": "$protocol.programId",
          "account_type": "Pool",
          "retention_seconds": 3600,
          "filters": []
        },
        "refresh": {
          "mode": "stream",
          "source": "program_account_updates"
        },
        "query": {
          "indexed_filters": {
            "all": [
              {
                "field": "memcmp.43",
                "op": "=",
                "value": "$input.mint"
              },
              {
                "field": "memcmp.75",
                "op": "=",
                "value": "$input.quote_mint"
              }
            ]
          },
          "filters": {
            "all": [
              {
                "field": "decoded.base_mint",
                "op": "=",
                "value": "$input.mint"
              },
              {
                "field": "decoded.quote_mint",
                "op": "=",
                "value": "$input.quote_mint"
              },
              {
                "field": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ]
          },
          "hydrate": {
            "mode": "accounts",
            "candidate_limit": 5,
            "fields": [
              "pubkey",
              "data_bytes",
              "slot"
            ]
          },
          "decode": {
            "account_type": "Pool"
          },
