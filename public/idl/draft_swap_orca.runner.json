{
  "$schema": "/idl/solana_action_runner.schema.v1.json",
  "schema": "solana-action-runner.v1",
  "actionId": "draft_swap_orca",
  "title": "Draft Swap on Orca",
  "description": "Resolve token symbols, pick the most liquid Orca Whirlpool pool, compute a quote, then draft the swap write.",
  "inputs": {
    "token_in_symbol": {
      "type": "string",
      "description": "Indexed token symbol, for example USDC.",
      "example": "USDC"
    },
    "token_out_symbol": {
      "type": "string",
      "description": "Indexed token symbol, for example SOL.",
      "example": "SOL"
    },
    "amount_in": {
      "type": "u64",
      "description": "Atomic input amount in the input token smallest unit.",
      "example": "1000000"
    },
    "slippage_bps": {
      "type": "u16",
      "default": 100,
      "description": "Slippage in basis points."
    },
    "unwrap_sol_output": {
      "type": "bool",
      "default": true,
      "description": "Whether to unwrap WSOL output into native SOL."
    }
  },
  "steps": [
    {
      "id": "token_in",
      "kind": "index_view",
      "protocolId": "token-index-mainnet",
      "operationId": "tokens_get",
      "input": {
        "symbol": "$input.token_in_symbol"
      },
      "limit": 1
    },
    {
      "id": "token_out",
      "kind": "index_view",
      "protocolId": "token-index-mainnet",
      "operationId": "tokens_get",
      "input": {
        "symbol": "$input.token_out_symbol"
      },
      "limit": 1
    },
    {
      "id": "pool",
      "kind": "index_view",
      "protocolId": "orca-whirlpool-mainnet",
      "operationId": "best_pool_for_pair",
      "input": {
        "token_in_mint": "$token_in.output.mint",
        "token_out_mint": "$token_out.output.mint"
      },
      "limit": 1
    },
    {
      "id": "quote",
      "kind": "read",
      "protocolId": "orca-whirlpool-mainnet",
      "operationId": "quote_exact_in",
      "input": {
        "token_in_mint": "$token_in.output.mint",
        "token_out_mint": "$token_out.output.mint",
        "amount_in": "$input.amount_in",
        "slippage_bps": "$input.slippage_bps",
        "whirlpool": "$pool.output.pool",
        "unwrap_sol_output": "$input.unwrap_sol_output"
      }
    },
    {
      "id": "draft",
      "kind": "write",
      "protocolId": "orca-whirlpool-mainnet",
      "operationId": "swap_exact_in",
      "input": {
        "amount": "$input.amount_in",
        "other_amount_threshold": "$quote.output.minimum_out",
        "sqrt_price_limit": "0",
        "amount_specified_is_input": true,
        "a_to_b": "$quote.output.a_to_b",
        "token_program_a": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
        "token_program_b": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
        "whirlpool": "$pool.output.pool",
        "token_mint_a": "$quote.meta.derived.whirlpool_data.token_mint_a",
        "token_mint_b": "$quote.meta.derived.whirlpool_data.token_mint_b",
        "token_vault_a": "$quote.meta.derived.whirlpool_data.token_vault_a",
        "token_vault_b": "$quote.meta.derived.whirlpool_data.token_vault_b",
        "tick_array0": "$quote.meta.derived.tick_arrays.0",
        "tick_array1": "$quote.meta.derived.tick_arrays.1",
        "tick_array2": "$quote.meta.derived.tick_arrays.2"
      }
    }
  ],
  "output": {
    "token_in": "$token_in.output",
    "token_out": "$token_out.output",
    "pool": "$pool.output",
    "quote": "$quote.output",
    "draft": {
      "protocolId": "$draft.output.protocolId",
      "operationId": "$draft.output.operationId",
      "instructionName": "$draft.output.instructionName",
      "args": "$draft.output.args",
      "accounts": "$draft.output.accounts",
      "remainingAccounts": "$draft.output.remainingAccounts",
      "preInstructions": "$quote.meta.preInstructions",
      "postInstructions": "$quote.meta.postInstructions"
    }
  }
}
