{
  "$schema": "/idl/solana_agent_runtime.schema.v1.json",
  "schema": "solana-agent-runtime.v1",
  "version": "0.1.0",
  "protocol": {
    "protocolId": "token-index-mainnet",
    "label": "Manual Token Index",
    "programId": "11111111111111111111111111111111",
    "codamaPath": "/idl/token_index.indexing.json"
  },
  "navigation": {
    "entities": {
      "token": {
        "description": "Known token metadata entry.",
        "identity_fields": [
          "mint"
        ],
        "aliases": [
          "asset"
        ]
      }
    }
  },
  "index_views": {
    "tokens_index": {
      "read": {
        "kind": "search",
        "title": "Known tokens",
        "description": "List manually indexed known tokens."
      },
      "read_output": {
        "type": "array",
        "source": "$items",
        "title": "Known tokens",
        "item_schema": {
          "entity_type": "token",
          "identity_fields": [
            "mint"
          ],
          "fields": {
            "symbol": {
              "type": "string",
              "required": true
            },
            "name": {
              "type": "string",
              "required": true
            },
            "mint": {
              "type": "token_mint",
              "required": true
            },
            "decimals": {
              "type": "u16",
              "required": true
            }
          }
        }
      }
    }
  },
  "computes": {},
  "contract_writes": {},
  "templates": {}
}
