{
  "$schema": "/idl/solana_agent_runtime.schema.v1.json",
  "schema": "solana-agent-runtime.v1",
  "protocol": {
    "protocolId": "token-index-mainnet",
    "programId": "11111111111111111111111111111111",
    "codamaPath": "/idl/token_index.codama.json"
  },
  "index_views": {
    "tokens_get": {
      "inputs": {
        "symbol": {
          "type": "string",
          "required": true
        }
      },
      "read": {
        "kind": "index",
        "description": "Resolve one manually indexed token by symbol.",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "token-index-mainnet",
          "record_kind": "account",
          "record_name": "Token",
          "notes": "Manual token directory seeded directly into canonical state."
        },
        "projection": {
          "projection_kind": "search",
          "filters": {
            "field": "symbol",
            "op": "ieq",
            "value": "$input.symbol"
          },
          "sort_by": [
            {
              "field": "symbol",
              "dir": "asc"
            }
          ]
        }
      },
      "read_output": {
        "type": "object",
        "source": "$items.0",
        "object_schema": {
          "entity_type": "token",
          "identity_fields": [
            "mint"
          ],
          "fields": {
            "symbol": {
              "type": "string",
              "required": true
            },
            "name": {
              "type": "string",
              "required": true
            },
            "mint": {
              "type": "token_mint",
              "required": true
            },
            "decimals": {
              "type": "u16",
              "required": true
            }
          }
        }
      }
    },
    "tokens_index": {
      "inputs": {},
      "read": {
        "kind": "search",
        "title": "Known tokens",
        "description": "List manually indexed known tokens.",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "token-index-mainnet",
          "record_kind": "account",
          "record_name": "Token",
          "notes": "Manual token directory seeded directly into canonical state."
        },
        "projection": {
          "projection_kind": "search",
          "sort_by": [
            {
              "field": "symbol",
              "dir": "asc"
            }
          ]
        }
      },
      "read_output": {
        "type": "array",
        "source": "$rows",
        "item_schema": {
          "entity_type": "token",
          "identity_fields": [
            "mint"
          ],
          "fields": {
            "symbol": {
              "type": "string",
              "required": true
            },
            "name": {
              "type": "string",
              "required": true
            },
            "mint": {
              "type": "token_mint",
              "required": true
            },
            "decimals": {
              "type": "u16",
              "required": true
            }
          }
        }
      }
    }
  },
  "computes": {},
  "contract_writes": {}
}
