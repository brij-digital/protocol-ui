{
  "$schema": "/idl/solana_agent_runtime.schema.v1.json",
  "schema": "solana-agent-runtime.v1",
  "version": "0.1.0",
  "protocol": {
    "protocolId": "orca-whirlpool-mainnet",
    "label": "Orca Whirlpool Declarative Runtime",
    "programId": "$protocol.programId",
    "codamaPath": "/idl/orca_whirlpool.codama.json"
  },
  "navigation": {
    "entities": {
      "pool": {
        "description": "Whirlpool liquidity pool.",
        "identity_fields": [
          "pool"
        ],
        "codama_account": "Whirlpool"
      },
      "token_pair": {
        "description": "Ordered or unordered token mint pair.",
        "identity_fields": [
          "token_in_mint",
          "token_out_mint"
        ]
      }
    },
    "entrypoints": {
      "discover_pool_for_pair": "reads.index.list_pools",
      "inspect_pool": "reads.index.pool_snapshot",
      "quote_swap_exact_in": "computes.quote_exact_in",
      "swap_exact_in": "executions.swap_exact_in"
    },
    "relations": [
      {
        "from": "token_pair",
        "to": "pool",
        "via": "reads.index.list_pools"
      },
      {
        "from": "pool",
        "to": "pool_snapshot",
        "via": "reads.index.pool_snapshot"
      }
    ],
    "recipes": {
      "swap_token_pair": [
        "reads.index.list_pools",
        "reads.index.pool_snapshot",
        "computes.quote_exact_in",
        "executions.swap_exact_in"
      ]
    }
  },
  "reads": {
    "index": {
      "resolve_pool": {
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          }
        },
        "read": {
          "kind": "account",
          "freshness": {
            "class": "near_realtime",
            "target_ms": 5000,
            "max_staleness_ms": 20000
          },
          "entity_type": "orca_whirlpool",
          "title": "Resolve pool",
          "description": "Resolve a known Orca Whirlpool address into the latest projected state.",
          "canonical": {
            "source": "indexed_idl_state",
            "protocol_id": "orca-whirlpool-mainnet",
            "record_kind": "account",
            "record_name": "Whirlpool",
            "resource_input": "pool",
            "resource_field": "resource_id",
            "notes": "Resolve a known Whirlpool address into its latest canonical state row."
          },
          "projection": {
            "projection_kind": "snapshot",
            "group_by": [
              "resource_id"
            ]
          }
        }
      },
      "pool_snapshot": {
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          }
        },
        "read": {
          "kind": "account",
          "freshness": {
            "class": "near_realtime",
            "target_ms": 5000,
            "max_staleness_ms": 20000
          },
          "entity_type": "orca_whirlpool",
          "title": "Pool snapshot",
          "description": "Read the current Orca Whirlpool snapshot for a known pool address.",
          "canonical": {
            "source": "indexed_idl_state",
            "protocol_id": "orca-whirlpool-mainnet",
            "record_kind": "account",
            "record_name": "Whirlpool",
            "resource_input": "pool",
            "resource_field": "resource_id",
            "notes": "Read the latest canonical Whirlpool state by pool address."
          },
          "projection": {
            "projection_kind": "snapshot",
            "group_by": [
              "resource_id"
            ]
          }
        }
      },
      "trade_feed": {
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          },
          "limit": {
            "type": "u16",
            "required": false,
            "default": 50
          }
        },
        "read": {
          "kind": "feed",
          "freshness": {
            "class": "near_realtime",
            "target_ms": 1000,
            "max_staleness_ms": 5000
          },
          "entity_type": "orca_swap",
          "title": "Trade feed",
          "description": "Recent Orca Whirlpool swaps.",
          "canonical": {
            "source": "indexed_idl_records",
            "protocol_id": "orca-whirlpool-mainnet",
            "record_kind": "event",
            "record_name": "SwapEvent",
            "subject_input": "pool",
            "resource_input": "pool",
            "resource_field": "resource_id",
            "time_field": "event_time",
            "notes": "Recent canonical Orca swap records ordered by event time."
          },
          "projection": {
            "projection_kind": "feed",
            "group_by": [
              "subject_id"
            ],
            "sort_by": [
              {
                "field": "event_time",
                "dir": "desc"
              }
            ]
          }
        }
      },
      "market_cap_series": {
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          },
          "limit": {
            "type": "u16",
            "required": false,
            "default": 240
          },
          "from": {
            "type": "string",
            "required": false
          },
          "to": {
            "type": "string",
            "required": false
          },
          "interval": {
            "type": "string",
            "required": false,
            "default": "1m"
          },
          "mode": {
            "type": "string",
            "required": false,
            "default": "sparse"
          }
        },
        "read": {
          "kind": "series",
          "freshness": {
            "class": "near_realtime",
            "target_ms": 5000,
            "max_staleness_ms": 30000
          },
          "entity_type": "orca_market_series",
          "title": "Market series",
          "description": "Materialized Orca Whirlpool price series with 1m base buckets, interval rollups, and optional dense fill.",
          "canonical": {
            "source": "indexed_series_1m",
            "protocol_id": "orca-whirlpool-mainnet",
            "series_id": "orca.whirlpool.market.1m",
            "subject_input": "pool",
            "resource_input": "pool",
            "time_field": "bucket_start",
            "notes": "Canonical 1m Orca Whirlpool market series projected from canonical swap records."
          },
          "projection": {
            "projection_kind": "series",
            "source_operation": "trade_feed",
            "group_by": [
              "subject_id"
            ],
            "bucket": "1m",
            "fill_mode": "sparse",
            "aggregations": [
              {
                "name": "open",
                "field": "priceQuote",
                "fn": "first"
              },
              {
                "name": "high",
                "field": "priceQuote",
                "fn": "max"
              },
              {
                "name": "low",
                "field": "priceQuote",
                "fn": "min"
              },
              {
                "name": "close",
                "field": "priceQuote",
                "fn": "last"
              },
              {
                "name": "volumeQuote",
                "field": "quoteNotionalUi",
                "fn": "sum"
              },
              {
                "name": "tradeCount",
                "field": "*",
                "fn": "count"
              }
            ]
          }
        }
      },
      "list_pools": {
        "inputs": {
          "token_in_mint": {
            "type": "token_mint",
            "required": true
          },
          "token_out_mint": {
            "type": "token_mint",
            "required": true
          }
        },
        "validate": {
          "cross": [
            {
              "kind": "not_equal",
              "left": "$input.token_in_mint",
              "right": "$input.token_out_mint",
              "message": "token_in_mint and token_out_mint must be different."
            }
          ]
        },
        "read_output": {
          "type": "array",
          "source": "$items",
          "title": "Pools found",
          "emptyText": "No indexed Whirlpool pool found for this pair.",
          "maxItems": 20,
          "itemLabelFields": [
            "pool",
            "tickSpacing",
            "liquidityQuote"
          ]
        },
        "read": {
          "kind": "search",
          "freshness": {
            "class": "near_realtime",
            "target_ms": 10000,
            "max_staleness_ms": 60000
          },
          "entity_type": "whirlpool_pool",
          "title": "List pools",
          "description": "Find indexed Whirlpool pools for a token pair.",
          "canonical": {
            "source": "indexed_idl_state",
            "protocol_id": "orca-whirlpool-mainnet",
            "record_kind": "account",
            "record_name": "Whirlpool",
            "notes": "Canonical Whirlpool pool directory ordered by indexed liquidity."
          },
          "projection": {
            "projection_kind": "search",
            "filters": {
              "any": [
                {
                  "all": [
                    {
                      "field": "tokenMintA",
                      "op": "=",
                      "value": "$input.token_in_mint"
                    },
                    {
                      "field": "tokenMintB",
                      "op": "=",
                      "value": "$input.token_out_mint"
                    }
                  ]
                },
                {
                  "all": [
                    {
                      "field": "tokenMintA",
                      "op": "=",
                      "value": "$input.token_out_mint"
                    },
                    {
                      "field": "tokenMintB",
                      "op": "=",
                      "value": "$input.token_in_mint"
                    }
                  ]
                }
              ]
            },
            "sort_by": [
              {
                "field": "liquidityQuote",
                "dir": "desc"
              },
              {
                "field": "updatedAt",
                "dir": "desc"
              }
            ]
          }
        }
      }
    }
  },
  "computes": {
    "quote_exact_in": {
      "inputs": {
        "token_in_mint": {
          "type": "token_mint",
          "required": true
        },
        "token_out_mint": {
          "type": "token_mint",
          "required": true
        },
        "amount_in": {
          "type": "u64",
          "required": true,
          "validate": {
            "min": "1",
            "message": "amount_in must be greater than 0."
          }
        },
        "slippage_bps": {
          "type": "u16",
          "required": true,
          "validate": {
            "min": 0,
            "max": 5000,
            "message": "slippage_bps must be between 0 and 5000."
          }
        },
        "whirlpool": {
          "type": "pubkey",
          "required": true
        }
      },
      "validate": {
        "cross": [
          {
            "kind": "not_equal",
            "left": "$input.token_in_mint",
            "right": "$input.token_out_mint",
            "message": "token_in_mint and token_out_mint must be different."
          }
        ]
      },
      "use": [
        {
          "template": "orca.swap_exact_in.v2",
          "with": {
            "token_in_mint": "$input.token_in_mint",
            "amount_in": "$input.amount_in",
            "slippage_bps": "$input.slippage_bps",
            "estimated_out": "0"
          }
        }
      ],
      "read_output": {
        "type": "object",
        "source": "$derived",
        "title": "Swap quote preview"
      }
    }
  },
  "executions": {
    "swap_exact_in": {
      "inputs": {
        "token_in_mint": {
          "type": "token_mint",
          "required": true
        },
        "token_out_mint": {
          "type": "token_mint",
          "required": true
        },
        "amount_in": {
          "type": "u64",
          "required": true,
          "validate": {
            "min": "1",
            "message": "amount_in must be greater than 0."
          }
        },
        "slippage_bps": {
          "type": "u16",
          "required": true,
          "validate": {
            "min": 0,
            "max": 5000,
            "message": "slippage_bps must be between 0 and 5000."
          }
        },
        "estimated_out": {
          "type": "u64",
          "required": false,
          "default": "0",
          "bind_from": "$derived.estimated_out_auto"
        },
        "whirlpool": {
          "type": "pubkey",
          "required": true
        },
        "unwrap_sol_output": {
          "type": "bool",
          "required": false,
          "default": true
        }
      },
      "validate": {
        "cross": [
          {
            "kind": "not_equal",
            "left": "$input.token_in_mint",
            "right": "$input.token_out_mint",
            "message": "token_in_mint and token_out_mint must be different."
          }
        ]
      },
      "use": [
        {
          "template": "orca.swap_exact_in.v2",
          "with": {
            "token_in_mint": "$input.token_in_mint",
            "amount_in": "$input.amount_in",
            "slippage_bps": "$input.slippage_bps",
            "estimated_out": "$input.estimated_out"
          }
        }
      ]
    }
  },
  "templates": {
    "orca.swap_exact_in.v2": {
      "params": {
        "token_in_mint": {
          "type": "token_mint"
        },
        "amount_in": {
          "type": "u64"
        },
        "slippage_bps": {
          "type": "u16"
        },
        "estimated_out": {
          "type": "u64"
        }
      },
      "expand": {
        "instruction": "swap_v2",
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "whirlpool_data",
            "resolver": "decode_account",
            "address": "$input.whirlpool",
            "account_type": "Whirlpool"
          },
          {
            "name": "token_owner_account_a",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_a"
          },
          {
            "name": "token_owner_account_b",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_b"
          },
          {
            "name": "oracle",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:oracle",
              "$input.whirlpool"
            ]
          }
        ],
        "args": {
          "amount": "$param.amount_in",
          "other_amount_threshold": "$other_amount_threshold",
          "sqrt_price_limit": "0",
          "amount_specified_is_input": true,
          "a_to_b": "$a_to_b",
          "remaining_accounts_info": null
        },
        "accounts": {
          "token_program_a": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
          "token_program_b": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
          "memo_program": "MemoSq4gqABAXKb96qnH8TysNcWxMyWCqXgDLGmfcHr",
          "token_authority": "$wallet",
          "whirlpool": "$input.whirlpool",
          "token_mint_a": "$whirlpool_data.token_mint_a",
          "token_mint_b": "$whirlpool_data.token_mint_b",
          "token_owner_account_a": "$token_owner_account_a",
          "token_vault_a": "$whirlpool_data.token_vault_a",
          "token_owner_account_b": "$token_owner_account_b",
          "token_vault_b": "$whirlpool_data.token_vault_b",
          "tick_array_0": "$tick_arrays.0",
          "tick_array_1": "$tick_arrays.1",
          "tick_array_2": "$tick_arrays.2",
          "oracle": "$oracle"
        },
        "pre": [
          {
            "kind": "spl_ata_create_idempotent",
            "payer": "$wallet",
            "ata": "$token_owner_account_a",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_a"
          },
          {
            "kind": "spl_ata_create_idempotent",
            "payer": "$wallet",
            "ata": "$token_owner_account_b",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_b"
          },
          {
            "kind": "system_transfer",
            "from": "$wallet",
            "to": "$token_owner_account_a",
            "lamports": "$param.amount_in",
            "when": {
              "all": [
                {
                  "equals": [
                    "$a_to_b",
                    true
                  ]
                },
                {
                  "equals": [
                    "$input.token_in_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          },
          {
            "kind": "spl_token_sync_native",
            "account": "$token_owner_account_a",
            "when": {
              "all": [
                {
                  "equals": [
                    "$a_to_b",
                    true
                  ]
                },
                {
                  "equals": [
                    "$input.token_in_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          },
          {
            "kind": "system_transfer",
            "from": "$wallet",
            "to": "$token_owner_account_b",
            "lamports": "$param.amount_in",
            "when": {
              "all": [
                {
                  "equals": [
                    "$a_to_b",
                    false
                  ]
                },
                {
                  "equals": [
                    "$input.token_in_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          },
          {
            "kind": "spl_token_sync_native",
            "account": "$token_owner_account_b",
            "when": {
              "all": [
                {
                  "equals": [
                    "$a_to_b",
                    false
                  ]
                },
                {
                  "equals": [
                    "$input.token_in_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          }
        ],
        "post": [
          {
            "kind": "spl_token_close_account",
            "account": "$token_owner_account_a",
            "destination": "$wallet",
            "owner": "$wallet",
            "when": {
              "all": [
                {
                  "equals": [
                    "$input.unwrap_sol_output",
                    true
                  ]
                },
                {
                  "equals": [
                    "$a_to_b",
                    false
                  ]
                },
                {
                  "equals": [
                    "$input.token_out_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          },
          {
            "kind": "spl_token_close_account",
            "account": "$token_owner_account_b",
            "destination": "$wallet",
            "owner": "$wallet",
            "when": {
              "all": [
                {
                  "equals": [
                    "$input.unwrap_sol_output",
                    true
                  ]
                },
                {
                  "equals": [
                    "$a_to_b",
                    true
                  ]
                },
                {
                  "equals": [
                    "$input.token_out_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          }
        ],
        "compute": [
          {
            "name": "a_to_b",
            "compute": "compare.equals",
            "left": "$whirlpool_data.token_mint_a",
            "right": "$param.token_in_mint"
          },
          {
            "name": "tick_array_direction",
            "compute": "logic.if",
            "condition": "$a_to_b",
            "then": -1,
            "else": 1
          },
          {
            "name": "ticks_per_array",
            "compute": "math.mul",
            "values": [
              "$whirlpool_data.tick_spacing",
              88
            ]
          },
          {
            "name": "direction_step",
            "compute": "math.mul",
            "values": [
              "$ticks_per_array",
              "$tick_array_direction"
            ]
          },
          {
            "name": "current_array_index",
            "compute": "math.floor_div",
            "dividend": "$whirlpool_data.tick_current_index",
            "divisor": "$ticks_per_array"
          },
          {
            "name": "current_start_index",
            "compute": "math.mul",
            "values": [
              "$current_array_index",
              "$ticks_per_array"
            ]
          },
          {
            "name": "tick_array_starts",
            "compute": "list.range_map",
            "base": "$current_start_index",
            "step": "$direction_step",
            "count": 3
          },
          {
            "name": "tick_arrays",
            "compute": "pda(seed_spec)",
            "program_id": "$protocol.programId",
            "map_over": "$tick_array_starts",
            "seeds": [
              {
                "kind": "utf8",
                "value": "tick_array"
              },
              {
                "kind": "pubkey",
                "value": "$input.whirlpool"
              },
              {
                "kind": "item_utf8"
              }
            ]
          },
          {
            "name": "spot_price_numerator",
            "compute": "math.mul",
            "values": [
              "$whirlpool_data.sqrt_price",
              "$whirlpool_data.sqrt_price"
            ]
          },
          {
            "name": "estimated_out_a_to_b_numerator",
            "compute": "math.mul",
            "values": [
              "$param.amount_in",
              "$spot_price_numerator"
            ]
          },
          {
            "name": "estimated_out_a_to_b",
            "compute": "math.floor_div",
            "dividend": "$estimated_out_a_to_b_numerator",
            "divisor": "340282366920938463463374607431768211456"
          },
          {
            "name": "estimated_out_b_to_a_numerator",
            "compute": "math.mul",
            "values": [
              "$param.amount_in",
              "340282366920938463463374607431768211456"
            ]
          },
          {
            "name": "estimated_out_b_to_a",
            "compute": "math.floor_div",
            "dividend": "$estimated_out_b_to_a_numerator",
            "divisor": "$spot_price_numerator"
          },
          {
            "name": "estimated_out_spot",
            "compute": "logic.if",
            "condition": "$a_to_b",
            "then": "$estimated_out_a_to_b",
            "else": "$estimated_out_b_to_a"
          },
          {
            "name": "estimated_out_auto",
            "compute": "coalesce",
            "values": [
              "$estimated_out_spot"
            ]
          },
          {
            "name": "slippage_keep_bps",
            "compute": "math.sub",
            "values": [
              "10000",
              "$param.slippage_bps"
            ]
          },
          {
            "name": "estimated_out_override_provided",
            "compute": "compare.gt",
            "left": "$param.estimated_out",
            "right": "0"
          },
          {
            "name": "estimated_out_effective",
            "compute": "logic.if",
            "condition": "$estimated_out_override_provided",
            "then": "$param.estimated_out",
            "else": "$estimated_out_auto"
          },
          {
            "name": "other_amount_threshold_numerator",
            "compute": "math.mul",
            "values": [
              "$estimated_out_effective",
              "$slippage_keep_bps"
            ]
          },
          {
            "name": "other_amount_threshold",
            "compute": "math.floor_div",
            "dividend": "$other_amount_threshold_numerator",
            "divisor": "10000"
          }
        ]
      }
    }
  }
}
