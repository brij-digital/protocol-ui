{
  "$schema": "/idl/solana_agent_runtime.schema.v1.json",
  "schema": "solana-agent-runtime.v1",
  "protocol": {
    "protocolId": "orca-whirlpool-mainnet",
    "programId": "$protocol.programId",
    "codamaPath": "/idl/orca_whirlpool.codama.json"
  },
  "computes": {
    "quote_exact_in": {
      "instruction": "swap_v2",
      "inputs": {
        "token_in_mint": {
          "type": "token_mint",
          "required": true
        },
        "token_out_mint": {
          "type": "token_mint",
          "required": true
        },
        "amount_in": {
          "type": "u64",
          "required": true
        },
        "slippage_bps": {
          "type": "u16",
          "required": true
        },
        "whirlpool": {
          "type": "pubkey",
          "required": true
        }
      },
      "resolve": [
        {
          "name": "wallet",
          "kind": "wallet_pubkey"
        },
        {
          "name": "whirlpool_data",
          "kind": "decode_account",
          "address": "$input.whirlpool",
          "account_type": "Whirlpool"
        }
      ],
      "compute": [
        {
          "name": "a_to_b",
          "kind": "compare.equals",
          "left": "$whirlpool_data.token_mint_a",
          "right": "$input.token_in_mint"
        },
        {
          "name": "tick_array_direction",
          "kind": "logic.if",
          "condition": "$a_to_b",
          "then": -1,
          "else": 1
        },
        {
          "name": "ticks_per_array",
          "kind": "math.mul",
          "values": [
            "$whirlpool_data.tick_spacing",
            88
          ]
        },
        {
          "name": "direction_step",
          "kind": "math.mul",
          "values": [
            "$ticks_per_array",
            "$tick_array_direction"
          ]
        },
        {
          "name": "current_array_index",
          "kind": "math.floor_div",
          "dividend": "$whirlpool_data.tick_current_index",
          "divisor": "$ticks_per_array"
        },
        {
          "name": "current_start_index",
          "kind": "math.mul",
          "values": [
            "$current_array_index",
            "$ticks_per_array"
          ]
        },
        {
          "name": "tick_array_starts",
          "kind": "list.range_map",
          "base": "$current_start_index",
          "step": "$direction_step",
          "count": 3
        },
        {
          "name": "tick_arrays",
          "kind": "pda(seed_spec)",
          "program_id": "$protocol.programId",
          "map_over": "$tick_array_starts",
          "seeds": [
            {
              "kind": "utf8",
              "value": "tick_array"
            },
            {
              "kind": "pubkey",
              "value": "$input.whirlpool"
            },
            {
              "kind": "item_utf8"
            }
          ]
        },
        {
          "name": "spot_price_numerator",
          "kind": "math.mul",
          "values": [
            "$whirlpool_data.sqrt_price",
            "$whirlpool_data.sqrt_price"
          ]
        },
        {
          "name": "estimated_out_a_to_b_numerator",
          "kind": "math.mul",
          "values": [
            "$input.amount_in",
            "$spot_price_numerator"
          ]
        },
        {
          "name": "estimated_out_a_to_b",
          "kind": "math.floor_div",
          "dividend": "$estimated_out_a_to_b_numerator",
          "divisor": "340282366920938463463374607431768211456"
        },
        {
          "name": "estimated_out_b_to_a_numerator",
          "kind": "math.mul",
          "values": [
            "$input.amount_in",
            "340282366920938463463374607431768211456"
          ]
        },
        {
          "name": "estimated_out_b_to_a",
          "kind": "math.floor_div",
          "dividend": "$estimated_out_b_to_a_numerator",
          "divisor": "$spot_price_numerator"
        },
        {
          "name": "estimated_out_spot",
          "kind": "logic.if",
          "condition": "$a_to_b",
          "then": "$estimated_out_a_to_b",
          "else": "$estimated_out_b_to_a"
        },
        {
          "name": "estimated_out_auto",
          "kind": "coalesce",
          "values": [
            "$estimated_out_spot"
          ]
        },
        {
          "name": "slippage_keep_bps",
          "kind": "math.sub",
          "values": [
            "10000",
            "$input.slippage_bps"
          ]
        },
        {
          "name": "estimated_out_override_provided",
          "kind": "compare.gt",
          "left": "0",
          "right": "0"
        },
        {
          "name": "estimated_out_effective",
          "kind": "logic.if",
          "condition": "$estimated_out_override_provided",
          "then": "0",
          "else": "$estimated_out_auto"
        },
        {
          "name": "other_amount_threshold_numerator",
          "kind": "math.mul",
          "values": [
            "$estimated_out_effective",
            "$slippage_keep_bps"
          ]
        },
        {
          "name": "other_amount_threshold",
          "kind": "math.floor_div",
          "dividend": "$other_amount_threshold_numerator",
          "divisor": "10000"
        },
        {
          "name": "whirlpool",
          "kind": "coalesce",
          "values": [
            "$input.whirlpool"
          ]
        },
        {
          "name": "token_in_mint",
          "kind": "coalesce",
          "values": [
            "$input.token_in_mint"
          ]
        },
        {
          "name": "token_out_mint",
          "kind": "coalesce",
          "values": [
            "$input.token_out_mint"
          ]
        },
        {
          "name": "amount_in",
          "kind": "coalesce",
          "values": [
            "$input.amount_in"
          ]
        },
        {
          "name": "slippage_bps",
          "kind": "coalesce",
          "values": [
            "$input.slippage_bps"
          ]
        },
        {
          "name": "estimated_out",
          "kind": "coalesce",
          "values": [
            "$estimated_out_effective"
          ]
        },
        {
          "name": "minimum_out",
          "kind": "coalesce",
          "values": [
            "$other_amount_threshold"
          ]
        },
        {
          "name": "pool_fee_bps",
          "kind": "coalesce",
          "values": [
            "$whirlpool_data.fee_rate"
          ]
        }
      ],
      "args": {
        "amount": "$input.amount_in",
        "other_amount_threshold": "$other_amount_threshold",
        "sqrt_price_limit": "0",
        "amount_specified_is_input": true,
        "a_to_b": "$a_to_b",
        "remaining_accounts_info": null
      },
      "accounts": {
        "token_program_a": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
        "token_program_b": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
        "whirlpool": "$input.whirlpool",
        "token_mint_a": "$whirlpool_data.token_mint_a",
        "token_mint_b": "$whirlpool_data.token_mint_b",
        "token_vault_a": "$whirlpool_data.token_vault_a",
        "token_vault_b": "$whirlpool_data.token_vault_b",
        "tick_array0": "$tick_arrays.0",
        "tick_array1": "$tick_arrays.1",
        "tick_array2": "$tick_arrays.2"
      },
      "pre": [
        {
          "kind": "spl_ata_create_idempotent",
          "payer": "$wallet",
          "ata": "$instruction_accounts.token_owner_account_a",
          "owner": "$wallet",
          "mint": "$whirlpool_data.token_mint_a"
        },
        {
          "kind": "spl_ata_create_idempotent",
          "payer": "$wallet",
          "ata": "$instruction_accounts.token_owner_account_b",
          "owner": "$wallet",
          "mint": "$whirlpool_data.token_mint_b"
        },
        {
          "kind": "system_transfer",
          "from": "$wallet",
          "to": "$instruction_accounts.token_owner_account_a",
          "lamports": "$input.amount_in",
          "when": {
            "all": [
              {
                "equals": [
                  "$a_to_b",
                  true
                ]
              },
              {
                "equals": [
                  "$input.token_in_mint",
                  "So11111111111111111111111111111111111111112"
                ]
              }
            ]
          }
        },
        {
          "kind": "spl_token_sync_native",
          "account": "$instruction_accounts.token_owner_account_a",
          "when": {
            "all": [
              {
                "equals": [
                  "$a_to_b",
                  true
                ]
              },
              {
                "equals": [
                  "$input.token_in_mint",
                  "So11111111111111111111111111111111111111112"
                ]
              }
            ]
          }
        },
        {
          "kind": "system_transfer",
          "from": "$wallet",
          "to": "$instruction_accounts.token_owner_account_b",
          "lamports": "$input.amount_in",
          "when": {
            "all": [
              {
                "equals": [
                  "$a_to_b",
                  false
                ]
              },
              {
                "equals": [
                  "$input.token_in_mint",
                  "So11111111111111111111111111111111111111112"
                ]
              }
            ]
          }
        },
        {
          "kind": "spl_token_sync_native",
          "account": "$instruction_accounts.token_owner_account_b",
          "when": {
            "all": [
              {
                "equals": [
                  "$a_to_b",
                  false
                ]
              },
              {
                "equals": [
                  "$input.token_in_mint",
                  "So11111111111111111111111111111111111111112"
                ]
              }
            ]
          }
        }
      ],
      "post": [
        {
          "kind": "spl_token_close_account",
          "account": "$instruction_accounts.token_owner_account_a",
          "destination": "$wallet",
          "owner": "$wallet",
          "when": {
            "all": [
              {
                "equals": [
                  "$input.unwrap_sol_output",
                  true
                ]
              },
              {
                "equals": [
                  "$a_to_b",
                  false
                ]
              },
              {
                "equals": [
                  "$input.token_out_mint",
                  "So11111111111111111111111111111111111111112"
                ]
              }
            ]
          }
        },
        {
          "kind": "spl_token_close_account",
          "account": "$instruction_accounts.token_owner_account_b",
          "destination": "$wallet",
          "owner": "$wallet",
          "when": {
            "all": [
              {
                "equals": [
                  "$input.unwrap_sol_output",
                  true
                ]
              },
              {
                "equals": [
                  "$a_to_b",
                  true
                ]
              },
              {
                "equals": [
                  "$input.token_out_mint",
                  "So11111111111111111111111111111111111111112"
                ]
              }
            ]
          }
        }
      ],
      "read_output": {
        "type": "object",
        "source": "$derived",
        "object_schema": {
          "entity_type": "orca_quote_exact_in",
          "identity_fields": [
            "whirlpool"
          ],
          "fields": {
            "whirlpool": {
              "type": "pubkey",
              "required": true
            },
            "token_in_mint": {
              "type": "pubkey",
              "required": true
            },
            "token_out_mint": {
              "type": "pubkey",
              "required": true
            },
            "amount_in": {
              "type": "u64",
              "required": true
            },
            "slippage_bps": {
              "type": "u16",
              "required": true
            },
            "estimated_out": {
              "type": "u64",
              "required": true
            },
            "minimum_out": {
              "type": "u64",
              "required": true
            },
            "a_to_b": {
              "type": "bool",
              "required": true
            },
            "pool_fee_bps": {
              "type": "number",
              "required": false
            }
          }
        }
      }
    }
  },
