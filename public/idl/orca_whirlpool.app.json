{
  "$schema": "/idl/meta_app.schema.v0.1.json",
  "schema": "meta-app.v0.1",
  "version": "0.2.0",
  "protocolId": "orca-whirlpool-mainnet",
  "label": "Orca Whirlpool",
  "apps": {
    "swap_from_discovery": {
      "label": "Discover & Swap",
      "title": "Discover -> Swap",
      "description": "List pools for a pair, then execute swap on the selected pool.",
      "entry_step": "discover",
      "steps": [
        {
          "id": "discover",
          "label": "Discover Pools",
          "operation": "list_pools",
          "title": "Discover Pools",
          "description": "Fetch Whirlpool candidates sorted by liquidity.",
          "actions": [
            {
              "label": "Find Pools",
              "do": {
                "fn": "run",
                "mode": "view"
              }
            }
          ],
          "next_on_success": "swap",
          "status_text": {
            "running": "Searching pools...",
            "success": "Pool selected. Next: {next_step_title}.",
            "error": "Pool discovery failed: {error}"
          },
          "ui": {
            "kind": "select_from_derived",
            "source": "pool_candidates",
            "bind_to": "selected_pool",
            "value_path": "whirlpool",
            "label_fields": [
              "whirlpool",
              "tickSpacing",
              "liquidity"
            ],
            "require_selection": true,
            "auto_advance": true,
            "title": "Select a pool",
            "description": "Pick one discovered pool to continue to swap."
          },
          "requires_paths": []
        },
        {
          "id": "swap",
          "label": "Swap By Pool",
          "operation": "swap_exact_in",
          "title": "Swap By Pool",
          "description": "Run simulation or send on selected Whirlpool.",
          "actions": [
            {
              "label": "Swap",
              "do": {
                "fn": "run",
                "mode": "send"
              }
            }
          ],
          "status_text": {
            "running": "Simulating or sending swap...",
            "success": "Swap step completed.",
            "error": "Swap failed: {error}"
          },
          "input_from": {
            "token_in_mint": "$steps.discover.input.token_in_mint",
            "token_out_mint": "$steps.discover.input.token_out_mint",
            "whirlpool": "$steps.discover.derived.selected_pool.whirlpool"
          },
          "input_mode": {
            "token_in_mint": "readonly",
            "token_out_mint": "readonly",
            "whirlpool": "hidden"
          },
          "requires_paths": [
            "$steps.discover.derived.selected_pool.whirlpool"
          ]
        }
      ]
    }
  }
}
