    "market_cap_series": {
      "label": "Market Series",
      "inputs": {
        "pool": {
          "type": "pubkey",
          "required": true,
          "label": "Whirlpool"
        },
        "limit": {
          "type": "u16",
          "required": false,
          "default": 240,
          "label": "Limit"
        },
        "from": {
          "type": "string",
          "required": false,
          "label": "From ISO"
        },
        "to": {
          "type": "string",
          "required": false,
          "label": "To ISO"
        },
        "interval": {
          "type": "string",
          "required": false,
          "default": "1m",
          "label": "Interval"
        },
        "mode": {
          "type": "string",
          "required": false,
          "default": "sparse",
          "label": "Mode"
        }
      },
      "view": {
        "kind": "series",
        "source_kind": "materialized_series",
        "freshness": {
          "class": "near_realtime",
          "target_ms": 5000,
          "max_staleness_ms": 30000
        },
        "canonical": {
          "source": "indexed_series_1m",
          "protocol_id": "orca-whirlpool-mainnet",
          "series_id": "orca.whirlpool.market.1m",
          "subject_input": "pool",
          "resource_input": "pool",
          "time_field": "bucket_start",
          "notes": "Canonical 1m Orca Whirlpool market series projected from canonical swap records."
        },
        "projection": {
          "projection_kind": "series",
          "source_operation": "trade_feed",
