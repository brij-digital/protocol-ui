    "pool_snapshot": {
      "label": "Pool Snapshot",
      "inputs": {
        "pool": {
          "type": "pubkey",
          "required": true,
          "label": "Whirlpool"
        }
      },
      "view": {
        "kind": "account",
        "source_kind": "account_changes",
        "freshness": {
          "class": "near_realtime",
          "target_ms": 5000,
          "max_staleness_ms": 20000
        },
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "orca-whirlpool-mainnet",
          "record_kind": "account",
          "record_name": "Whirlpool",
          "resource_input": "pool",
          "resource_field": "resource_id",
          "notes": "Read the latest canonical Whirlpool state by pool address."
        },
        "projection": {
          "projection_kind": "snapshot",
          "group_by": [
            "resource_id"
          ]
        },
        "entity_type": "orca_whirlpool",
        "title": "Pool snapshot",
        "description": "Read the current Orca Whirlpool snapshot for a known pool address.",
        "target": {
          "address": "$input.pool",
          "account_type": "Whirlpool"
        },
        "select": {
          "whirlpool": "$account.pubkey"
        }
      },
      "use": []
    },
    "trade_feed": {
      "label": "Trade Feed",
      "inputs": {
        "pool": {
          "type": "pubkey",
          "required": true,
          "label": "Whirlpool"
        },
        "limit": {
          "type": "u16",
          "required": false,
          "default": 50,
          "label": "Limit"
        }
      },
      "view": {
        "kind": "feed",
        "source_kind": "materialized_feed",
        "freshness": {
          "class": "near_realtime",
          "target_ms": 1000,
          "max_staleness_ms": 5000
        },
        "canonical": {
          "source": "indexed_idl_records",
          "protocol_id": "orca-whirlpool-mainnet",
          "record_kind": "event",
          "record_name": "SwapEvent",
          "subject_input": "pool",
          "resource_input": "pool",
          "resource_field": "resource_id",
          "time_field": "event_time",
          "notes": "Recent canonical Orca swap records ordered by event time."
        },
        "projection": {
          "projection_kind": "feed",
          "group_by": [
            "subject_id"
          ],
          "sort_by": [
            {
              "field": "event_time",
              "dir": "desc"
            }
          ]
        },
        "entity_type": "orca_swap",
        "title": "Trade feed",
        "description": "Recent Orca Whirlpool swaps."
      },
      "use": []
