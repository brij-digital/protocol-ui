{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espressocash.com/schemas/meta-idl.v0.1.json",
  "title": "Espresso Meta IDL v0.1",
  "type": "object",
  "required": ["schema", "version", "protocolId", "actions"],
  "properties": {
    "schema": {
      "const": "meta-idl.v0.1"
    },
    "version": {
      "type": "string"
    },
    "protocolId": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sourceSpec"
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/actionSpec"
      }
    }
  },
  "$defs": {
    "sourceSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": { "const": "inline" },
            "items": { "type": "array", "items": {} }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "url"],
          "properties": {
            "kind": { "const": "http_json" },
            "url": { "type": "string" },
            "items_path": { "type": "string" },
            "ttl_ms": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      ]
    },
    "actionInputSpec": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "default": {}
      },
      "additionalProperties": false
    },
    "resolverBase": {
      "type": "object",
      "required": ["resolver"],
      "properties": {
        "resolver": {
          "enum": [
            "wallet_pubkey",
            "decode_account",
            "ata",
            "pda",
            "orca_swap_quote",
            "lookup"
          ]
        },
        "address": {},
        "account_type": { "type": "string" },
        "owner": {},
        "mint": {},
        "program_id": {},
        "seeds": { "type": "array", "items": {} },
        "whirlpool": {},
        "amount": {},
        "a_to_b": {},
        "slippage_bps": {},
        "source": { "type": "string" },
        "where": {},
        "select": {},
        "mode": { "enum": ["first", "all"] }
      },
      "additionalProperties": false
    },
    "deriveStep": {
      "type": "object",
      "required": ["name", "resolver"],
      "properties": {
        "name": { "type": "string" },
        "resolver": {
          "enum": [
            "wallet_pubkey",
            "decode_account",
            "ata",
            "pda",
            "orca_swap_quote",
            "lookup"
          ]
        },
        "address": {},
        "account_type": { "type": "string" },
        "owner": {},
        "mint": {},
        "program_id": {},
        "seeds": { "type": "array", "items": {} },
        "whirlpool": {},
        "amount": {},
        "a_to_b": {},
        "slippage_bps": {},
        "source": { "type": "string" },
        "where": {},
        "select": {},
        "mode": { "enum": ["first", "all"] },
        "fallback": { "$ref": "#/$defs/resolverBase" }
      },
      "additionalProperties": false
    },
    "metaCondition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["equals"],
          "properties": {
            "equals": {
              "type": "array",
              "items": {},
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "items": { "$ref": "#/$defs/metaCondition" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "items": { "$ref": "#/$defs/metaCondition" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not"],
          "properties": {
            "not": { "$ref": "#/$defs/metaCondition" }
          },
          "additionalProperties": false
        }
      ]
    },
    "postStep": {
      "type": "object",
      "required": ["kind", "account", "destination", "owner"],
      "properties": {
        "kind": { "const": "spl_token_close_account" },
        "account": {},
        "destination": {},
        "owner": {},
        "token_program": {},
        "when": { "$ref": "#/$defs/metaCondition" }
      },
      "additionalProperties": false
    },
    "actionSpec": {
      "type": "object",
      "required": ["instruction", "inputs", "derive", "args", "accounts"],
      "properties": {
        "instruction": { "type": "string" },
        "inputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/actionInputSpec" }
        },
        "derive": {
          "type": "array",
          "items": { "$ref": "#/$defs/deriveStep" }
        },
        "args": {
          "type": "object",
          "additionalProperties": {}
        },
        "accounts": {
          "type": "object",
          "additionalProperties": {}
        },
        "post": {
          "type": "array",
          "items": { "$ref": "#/$defs/postStep" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
