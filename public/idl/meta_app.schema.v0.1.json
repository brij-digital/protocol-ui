{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espressocash.com/schemas/meta-app.v0.1.json",
  "title": "Meta App v0.1 (App description only)",
  "type": "object",
  "properties": {
    "schema": {
      "const": "meta-app.v0.1"
    },
    "version": {
      "type": "string"
    },
    "protocolId": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sourceSpec"
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/templateSpec"
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/actionSpec"
      }
    },
    "apps": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/userAppSpec"
      }
    }
  },
  "required": [
    "schema",
    "version",
    "protocolId",
    "label",
    "apps"
  ],
  "$defs": {
    "sourceSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "items"
          ],
          "properties": {
            "kind": {
              "const": "inline"
            },
            "items": {
              "type": "array",
              "items": {}
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "url"
          ],
          "properties": {
            "kind": {
              "const": "http_json"
            },
            "url": {
              "type": "string"
            },
            "items_path": {
              "type": "string"
            },
            "ttl_ms": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "actionInputSpec": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "placeholder": {
          "type": "string"
        },
        "help": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "display_order": {
          "type": "number"
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "read_from": {
          "type": "string",
          "minLength": 1
        },
        "validate": {
          "type": "object",
          "additionalProperties": true
        },
        "ui_mode": {
          "type": "string",
          "enum": [
            "edit",
            "readonly",
            "hidden"
          ]
        }
      },
      "additionalProperties": true
    },
    "actionSpec": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "instruction": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/actionInputSpec"
          }
        },
        "discover": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "derive": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "compute": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "args": {
          "type": "object",
          "additionalProperties": true
        },
        "accounts": {
          "type": "object",
          "additionalProperties": true
        },
        "remaining_accounts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "read_output": {
          "type": "object",
          "additionalProperties": true
        },
        "view": {
          "type": "object",
          "additionalProperties": true
        },
        "pre": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "post": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "use": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "validate": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "templateSpec": {
      "type": "object",
      "properties": {
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "expand": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "expand"
      ],
      "additionalProperties": false
    },
    "userAppActionSpec": {
      "type": "object",
      "required": [
        "label",
        "do"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "do": {
          "type": "object",
          "required": [
            "fn"
          ],
          "properties": {
            "fn": {
              "enum": [
                "run",
                "back",
                "reset"
              ]
            },
            "mode": {
              "enum": [
                "view",
                "simulate",
                "send"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "do": {
                "properties": {
                  "fn": {
                    "const": "run"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "do": {
                "required": [
                  "mode"
                ]
              }
            }
          },
          "else": {
            "properties": {
              "do": {
                "not": {
                  "required": [
                    "mode"
                  ]
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "userAppStatusTextSpec": {
      "type": "object",
      "properties": {
        "idle": {
          "type": "string"
        },
        "running": {
          "type": "string"
        },
        "success": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "userAppStepUiSpec": {
      "type": "object",
      "required": [
        "kind",
        "source",
        "bind_to",
        "value_path",
        "require_selection",
        "auto_advance"
      ],
      "properties": {
        "kind": {
          "const": "select_from_derived"
        },
        "source": {
          "type": "string"
        },
        "bind_to": {
          "type": "string"
        },
        "value_path": {
          "type": "string"
        },
        "label_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "require_selection": {
          "type": "boolean"
        },
        "auto_advance": {
          "type": "boolean"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "userAppStepSpec": {
      "type": "object",
      "required": [
        "id",
        "operation",
        "title",
        "label",
        "actions"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "next_on_success": {
          "type": "string"
        },
        "status_text": {
          "$ref": "#/$defs/userAppStatusTextSpec"
        },
        "input_from": {
          "type": "object",
          "additionalProperties": {}
        },
        "input_mode": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "edit",
              "readonly",
              "hidden"
            ]
          }
        },
        "requires_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/userAppActionSpec"
          }
        },
        "ui": {
          "$ref": "#/$defs/userAppStepUiSpec"
        }
      },
      "additionalProperties": false
    },
    "userAppSpec": {
      "type": "object",
      "required": [
        "title",
        "label",
        "entry_step",
        "steps"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "entry_step": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/userAppStepSpec"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
