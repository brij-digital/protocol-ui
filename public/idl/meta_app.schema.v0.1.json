{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espressocash.com/schemas/meta-app.v0.1.json",
  "title": "Meta App v0.1 (App description only)",
  "type": "object",
  "properties": {
    "schema": {
      "const": "meta-app.v0.1"
    },
    "version": {
      "type": "string"
    },
    "protocolId": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "apps": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/userAppSpec"
      }
    }
  },
  "required": [
    "schema",
    "version",
    "protocolId",
    "label",
    "apps"
  ],
  "$defs": {
    "userAppActionSpec": {
      "type": "object",
      "required": [
        "label",
        "do"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "do": {
          "type": "object",
          "required": [
            "fn"
          ],
          "properties": {
            "fn": {
              "enum": [
                "run",
                "back",
                "reset"
              ]
            },
            "mode": {
              "enum": [
                "view",
                "simulate",
                "send"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "do": {
                "properties": {
                  "fn": {
                    "const": "run"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "do": {
                "required": [
                  "mode"
                ]
              }
            }
          },
          "else": {
            "properties": {
              "do": {
                "not": {
                  "required": [
                    "mode"
                  ]
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "userAppStatusTextSpec": {
      "type": "object",
      "properties": {
        "idle": {
          "type": "string"
        },
        "running": {
          "type": "string"
        },
        "success": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "userAppStepUiSpec": {
      "type": "object",
      "required": [
        "kind",
        "source",
        "bind_to",
        "value_path",
        "require_selection",
        "auto_advance"
      ],
      "properties": {
        "kind": {
          "const": "select_from_derived"
        },
        "source": {
          "type": "string"
        },
        "bind_to": {
          "type": "string"
        },
        "value_path": {
          "type": "string"
        },
        "label_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "require_selection": {
          "type": "boolean"
        },
        "auto_advance": {
          "type": "boolean"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "userAppStepSpec": {
      "type": "object",
      "required": [
        "id",
        "operation",
        "title",
        "label",
        "actions"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "next_on_success": {
          "type": "string"
        },
        "status_text": {
          "$ref": "#/$defs/userAppStatusTextSpec"
        },
        "input_from": {
          "type": "object",
          "additionalProperties": {}
        },
        "input_mode": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "edit",
              "readonly",
              "hidden"
            ]
          }
        },
        "requires_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/userAppActionSpec"
          }
        },
        "ui": {
          "$ref": "#/$defs/userAppStepUiSpec"
        }
      },
      "additionalProperties": false
    },
    "userAppSpec": {
      "type": "object",
      "required": [
        "title",
        "label",
        "entry_step",
        "steps"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "entry_step": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/userAppStepSpec"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
