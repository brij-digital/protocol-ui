{
  "$schema": "/idl/meta_app.schema.v0.1.json",
  "schema": "meta-app.v0.1",
  "version": "0.2.0",
  "protocolId": "pump-amm-mainnet",
  "label": "Pump Amm Mainnet",
  "apps": {
    "token_terminal": {
      "title": "Pump Token Terminal",
      "description": "Step 1: list tokens. Step 2: pool snapshot. Step 3/4: buy or sell.",
      "entry_step": "discover",
      "steps": [
        {
          "id": "discover",
          "operation": "list_tokens",
          "title": "List Tokens",
          "description": "Discover Pump AMM tokens from quote mint and choose one token/pool.",
          "actions": [
            {
              "id": "discover_run",
              "kind": "run",
              "label": "Find Tokens",
              "mode": "view",
              "variant": "primary"
            }
          ],
          "blocking": {
            "depends_on": [],
            "requires_paths": []
          },
          "success": {
            "kind": "selection_made",
            "path": "$steps.discover.derived.selected_pool"
          },
          "next_on_success": "pool",
          "status_text": {
            "running": "Searching Pump AMM pools...",
            "success": "Token selected. Next: {next_step_title}.",
            "error": "Discovery failed: {error}"
          },
          "transitions": [
            {
              "on": "success",
              "to": "pool"
            }
          ],
          "ui": {
            "kind": "select_from_derived",
            "source": "pool_candidates",
            "bind_to": "selected_pool",
            "value_path": "pool",
            "label_fields": [
              "baseMint",
              "pool",
              "index",
              "lpSupply"
            ],
            "require_selection": true,
            "auto_advance": true,
            "title": "Select a token/pool",
            "description": "Pick one discovered token to open its pool details and trading actions."
          },
          "label": "List Tokens"
        },
        {
          "id": "pool",
          "operation": "view_pool",
          "title": "Pool Snapshot",
          "description": "Live pool snapshot from RPC before taking action.",
          "actions": [
            {
              "id": "pool_back",
              "kind": "back",
              "label": "Back to Tokens",
              "variant": "ghost"
            },
            {
              "id": "pool_run",
              "kind": "run",
              "label": "Refresh Snapshot",
              "mode": "view",
              "variant": "primary"
            }
          ],
          "blocking": {
            "depends_on": [
              "discover"
            ],
            "requires_paths": [
              "$steps.discover.derived.selected_pool.pool"
            ]
          },
          "success": {
            "kind": "operation_ok"
          },
          "status_text": {
            "running": "Loading pool snapshot...",
            "success": "Snapshot ready. Choose Buy or Sell step.",
            "error": "Pool snapshot failed: {error}"
          },
          "transitions": [],
          "input_from": {
            "base_mint": "$steps.discover.derived.selected_pool.baseMint",
            "quote_mint": "$steps.discover.derived.selected_pool.quoteMint"
          },
          "label": "Pool Snapshot"
        },
        {
          "id": "buy",
          "operation": "buy",
          "title": "Buy",
          "description": "Simulate then send buy transaction.",
          "actions": [
            {
              "id": "buy_back",
              "kind": "back",
              "label": "Back to Snapshot",
              "variant": "ghost"
            },
            {
              "id": "buy_simulate",
              "kind": "run",
              "label": "Simulate Buy",
              "mode": "simulate",
              "variant": "primary"
            },
            {
              "id": "buy_send",
              "kind": "run",
              "label": "Send Buy",
              "mode": "send",
              "variant": "secondary"
            }
          ],
          "blocking": {
            "depends_on": [
              "pool"
            ],
            "requires_paths": [
              "$steps.discover.derived.selected_pool.pool"
            ]
          },
          "success": {
            "kind": "operation_ok"
          },
          "next_on_error": "pool",
          "status_text": {
            "running": "Executing buy...",
            "success": "Buy step completed.",
            "error": "Buy failed: {error}"
          },
          "transitions": [
            {
              "on": "error",
              "to": "pool"
            }
          ],
          "input_from": {
            "base_mint": "$steps.discover.derived.selected_pool.baseMint",
            "quote_mint": "$steps.discover.derived.selected_pool.quoteMint",
            "pool": "$steps.discover.derived.selected_pool.pool"
          },
          "label": "Buy"
        },
        {
          "id": "sell",
          "operation": "sell",
          "title": "Sell",
          "description": "Simulate then send sell transaction.",
          "actions": [
            {
              "id": "sell_back",
              "kind": "back",
              "label": "Back to Snapshot",
              "variant": "ghost"
            },
            {
              "id": "sell_simulate",
              "kind": "run",
              "label": "Simulate Sell",
              "mode": "simulate",
              "variant": "primary"
            },
            {
              "id": "sell_send",
              "kind": "run",
              "label": "Send Sell",
              "mode": "send",
              "variant": "secondary"
            }
          ],
          "blocking": {
            "depends_on": [
              "pool"
            ],
            "requires_paths": [
              "$steps.discover.derived.selected_pool.pool"
            ]
          },
          "success": {
            "kind": "operation_ok"
          },
          "next_on_error": "pool",
          "status_text": {
            "running": "Executing sell...",
            "success": "Sell step completed.",
            "error": "Sell failed: {error}"
          },
          "transitions": [
            {
              "on": "error",
              "to": "pool"
            }
          ],
          "input_from": {
            "base_mint": "$steps.discover.derived.selected_pool.baseMint",
            "quote_mint": "$steps.discover.derived.selected_pool.quoteMint",
            "pool": "$steps.discover.derived.selected_pool.pool"
          },
          "label": "Sell"
        }
      ],
      "label": "Pump Token Terminal"
    },
    "buy_token": {
      "title": "Buy Token (Pump AMM)",
      "description": "Buy a graduated token directly on Pump AMM.",
      "entry_step": "buy",
      "steps": [
        {
          "id": "buy",
          "operation": "buy",
          "title": "Buy",
          "description": "Simulate first, then send with the same inputs.",
          "actions": [
            {
              "id": "buy_simulate",
              "kind": "run",
              "label": "Simulate Buy",
              "mode": "simulate",
              "variant": "primary"
            },
            {
              "id": "buy_send",
              "kind": "run",
              "label": "Send Buy",
              "mode": "send",
              "variant": "secondary"
            }
          ],
          "blocking": {
            "depends_on": [],
            "requires_paths": []
          },
          "success": {
            "kind": "operation_ok"
          },
          "status_text": {
            "running": "Executing buy...",
            "success": "Buy step completed.",
            "error": "Buy failed: {error}"
          },
          "transitions": [],
          "label": "Buy"
        }
      ],
      "label": "Buy Token (Pump AMM)"
    }
  }
}
