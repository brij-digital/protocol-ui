{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espressocash.com/schemas/meta-idl.v0.3.json",
  "title": "Espresso Meta IDL v0.3",
  "type": "object",
  "required": ["schema", "version", "protocolId", "actions"],
  "properties": {
    "schema": {
      "const": "meta-idl.v0.3"
    },
    "version": {
      "type": "string"
    },
    "protocolId": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sourceSpec"
      }
    },
    "macros": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/macroSpec"
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/actionSpec"
      }
    }
  },
  "$defs": {
    "sourceSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": { "const": "inline" },
            "items": { "type": "array", "items": {} }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "url"],
          "properties": {
            "kind": { "const": "http_json" },
            "url": { "type": "string" },
            "items_path": { "type": "string" },
            "ttl_ms": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      ]
    },
    "actionInputSpec": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "default": {}
      },
      "additionalProperties": false
    },
    "resolverBase": {
      "type": "object",
      "required": ["resolver"],
      "properties": {
        "resolver": {
          "enum": [
            "wallet_pubkey",
            "decode_account",
            "ata",
            "pda",
            "lookup",
            "unix_timestamp"
          ]
        },
        "address": {},
        "account_type": { "type": "string" },
        "owner": {},
        "mint": {},
        "program_id": {},
        "seeds": { "type": "array", "items": {} },
        "source": { "type": "string" },
        "where": {},
        "select": {},
        "mode": { "enum": ["first", "all"] }
      },
      "additionalProperties": false
    },
    "deriveStep": {
      "type": "object",
      "required": ["name", "resolver"],
      "properties": {
        "name": { "type": "string" },
        "resolver": {
          "enum": [
            "wallet_pubkey",
            "decode_account",
            "ata",
            "pda",
            "lookup",
            "unix_timestamp"
          ]
        },
        "address": {},
        "account_type": { "type": "string" },
        "owner": {},
        "mint": {},
        "program_id": {},
        "seeds": { "type": "array", "items": {} },
        "source": { "type": "string" },
        "where": {},
        "select": {},
        "mode": { "enum": ["first", "all"] },
        "fallback": { "$ref": "#/$defs/resolverBase" }
      },
      "additionalProperties": false
    },
    "pdaSeedSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "utf8" },
            "value": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "pubkey" },
            "value": {}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "i32_le" },
            "value": {}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "const": "item_i32_le" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "const": "item_utf8" }
          },
          "additionalProperties": false
        }
      ]
    },
    "computeStep": {
      "oneOf": [
        {
          "type": "object",
          "required": ["name", "compute", "values"],
          "properties": {
            "name": { "type": "string" },
            "compute": { "const": "math.add" },
            "values": { "type": "array", "items": {}, "minItems": 2 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["name", "compute", "values"],
          "properties": {
            "name": { "type": "string" },
            "compute": { "const": "math.mul" },
            "values": { "type": "array", "items": {}, "minItems": 2 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["name", "compute", "dividend", "divisor"],
          "properties": {
            "name": { "type": "string" },
            "compute": { "const": "math.floor_div" },
            "dividend": {},
            "divisor": {}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["name", "compute", "base", "step", "count"],
          "properties": {
            "name": { "type": "string" },
            "compute": { "const": "list.range_map" },
            "base": {},
            "step": {},
            "count": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["name", "compute", "seeds"],
          "properties": {
            "name": { "type": "string" },
            "compute": { "const": "pda(seed_spec)" },
            "program_id": {},
            "map_over": {},
            "seeds": {
              "type": "array",
              "items": { "$ref": "#/$defs/pdaSeedSpec" },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "metaCondition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["equals"],
          "properties": {
            "equals": {
              "type": "array",
              "items": {},
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "items": { "$ref": "#/$defs/metaCondition" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "items": { "$ref": "#/$defs/metaCondition" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not"],
          "properties": {
            "not": { "$ref": "#/$defs/metaCondition" }
          },
          "additionalProperties": false
        }
      ]
    },
    "postStep": {
      "type": "object",
      "required": ["kind", "account", "destination", "owner"],
      "properties": {
        "kind": { "const": "spl_token_close_account" },
        "account": {},
        "destination": {},
        "owner": {},
        "token_program": {},
        "when": { "$ref": "#/$defs/metaCondition" }
      },
      "additionalProperties": false
    },
    "macroParamSpec": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "required": { "type": "boolean" },
            "default": {}
          },
          "additionalProperties": false
        }
      ]
    },
    "macroUseSpec": {
      "type": "object",
      "required": ["macro"],
      "properties": {
        "macro": { "type": "string" },
        "with": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "additionalProperties": false
    },
    "macroSpec": {
      "type": "object",
      "required": ["expand"],
      "properties": {
        "params": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/macroParamSpec" }
        },
        "expand": { "$ref": "#/$defs/actionFragment" }
      },
      "additionalProperties": false
    },
    "actionFragment": {
      "type": "object",
      "properties": {
        "instruction": { "type": "string" },
        "inputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/actionInputSpec" }
        },
        "derive": {
          "type": "array",
          "items": { "$ref": "#/$defs/deriveStep" }
        },
        "compute": {
          "type": "array",
          "items": { "$ref": "#/$defs/computeStep" }
        },
        "args": {
          "type": "object",
          "additionalProperties": {}
        },
        "accounts": {
          "type": "object",
          "additionalProperties": {}
        },
        "post": {
          "type": "array",
          "items": { "$ref": "#/$defs/postStep" }
        }
      },
      "additionalProperties": false
    },
    "actionSpec": {
      "type": "object",
      "properties": {
        "instruction": { "type": "string" },
        "inputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/actionInputSpec" }
        },
        "derive": {
          "type": "array",
          "items": { "$ref": "#/$defs/deriveStep" }
        },
        "compute": {
          "type": "array",
          "items": { "$ref": "#/$defs/computeStep" }
        },
        "args": {
          "type": "object",
          "additionalProperties": {}
        },
        "accounts": {
          "type": "object",
          "additionalProperties": {}
        },
        "post": {
          "type": "array",
          "items": { "$ref": "#/$defs/postStep" }
        },
        "use": {
          "type": "array",
          "items": { "$ref": "#/$defs/macroUseSpec" },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["instruction"] },
        { "required": ["use"] }
      ]
    }
  },
  "additionalProperties": false
}
