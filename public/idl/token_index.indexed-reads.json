{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "protocolId": "token-index-mainnet",
  "active_window_days": null,
  "label": "Token Index Indexed Reads",
  "programId": "11111111111111111111111111111111",
  "operations": {
    "tokens_get": {
      "index_view": {
        "kind": "search",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "token-index-mainnet",
          "record_kind": "account",
          "record_name": "Token",
          "notes": "Manual token directory seeded directly into canonical state."
        },
        "projection": {
          "projection_kind": "search",
          "filters": {
            "field": "symbol",
            "op": "ieq",
            "value": "$input.symbol"
          },
          "sort_by": [
            {
              "field": "symbol",
              "dir": "asc"
            }
          ]
        },
        "inputs": {
          "symbol": {
            "type": "string",
            "required": true
          }
        },
        "read_output": {
          "type": "object",
          "source": "$items.0",
          "object_schema": {
            "entity_type": "token",
            "identity_fields": [
              "mint"
            ],
            "fields": {
              "symbol": {
                "type": "string",
                "required": true
              },
              "name": {
                "type": "string",
                "required": true
              },
              "mint": {
                "type": "token_mint",
                "required": true
              },
              "decimals": {
                "type": "u16",
                "required": true
              }
            }
          }
        }
      }
    },
    "tokens_index": {
      "index_view": {
        "kind": "search",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "token-index-mainnet",
          "record_kind": "account",
          "record_name": "Token",
          "notes": "Manual token directory seeded directly into canonical state."
        },
        "projection": {
          "projection_kind": "search",
          "sort_by": [
            {
              "field": "symbol",
              "dir": "asc"
            }
          ]
        },
        "inputs": {},
        "read_output": {
          "type": "array",
          "source": "$rows",
          "item_schema": {
            "entity_type": "token",
            "identity_fields": [
              "mint"
            ],
            "fields": {
              "symbol": {
                "type": "string",
                "required": true
              },
              "name": {
                "type": "string",
                "required": true
              },
              "mint": {
                "type": "token_mint",
                "required": true
              },
              "decimals": {
                "type": "u16",
                "required": true
              }
            }
          }
        }
      }
    }
  }
}
