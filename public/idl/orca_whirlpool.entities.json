{
  "$schema": "/idl/entity_schema.v1.json",
  "indexingId": "orca-whirlpool-mainnet",
  "sourceProtocolIds": [
    "orca-whirlpool-mainnet"
  ],
  "entities": {
    "Pool": {
      "source": {
        "from": "state",
        "recordKind": "account",
        "recordName": "Whirlpool"
      },
      "transform": {
        "extract": {
          "subjectId": "$raw.subject_id",
          "resourceId": "$raw.resource_id",
          "pool": "$raw.subject_id",
          "marketType": "$state.marketType",
          "tokenMintA": "$state.tokenMintA",
          "tokenMintB": "$state.tokenMintB",
          "tokenVaultA": "$state.tokenVaultA",
          "tokenVaultB": "$state.tokenVaultB",
          "tickSpacing": "$state.tickSpacing",
          "feeRateRaw": "$state.feeRateRaw",
          "feeRateBps": "$state.feeRateBps",
          "liquidity": "$state.liquidity",
          "tickCurrentIndex": "$state.tickCurrentIndex",
          "sqrtPrice": "$state.sqrtPrice",
          "observedAt": "$state.observedAt",
          "updatedAt": "$raw.updated_at",
          "lastEventTime": "$raw.last_event_time"
        }
      },
      "emit": {
        "id": "pool",
        "indexes": [
          [
            "tokenMintA",
            "updatedAt:desc"
          ],
          [
            "tokenMintB",
            "updatedAt:desc"
          ],
          [
            "liquidity:desc",
            "updatedAt:desc"
          ]
        ],
        "timeField": "updatedAt",
        "defaultOrderBy": [
          "liquidity:desc",
          "updatedAt:desc"
        ],
        "fields": {
          "subjectId": {
            "type": "TEXT",
            "filterable": true
          },
          "resourceId": {
            "type": "TEXT"
          },
          "pool": {
            "type": "TEXT",
            "primaryKey": true,
            "filterable": true
          },
          "marketType": {
            "type": "TEXT"
          },
          "tokenMintA": {
            "type": "TEXT",
            "filterable": true
          },
          "tokenMintB": {
            "type": "TEXT",
            "filterable": true
          },
          "tokenVaultA": {
            "type": "TEXT"
          },
          "tokenVaultB": {
            "type": "TEXT"
          },
          "tickSpacing": {
            "type": "INTEGER"
          },
          "feeRateRaw": {
            "type": "INTEGER"
          },
          "feeRateBps": {
            "type": "NUMERIC"
          },
          "liquidity": {
            "type": "NUMERIC",
            "filterable": true
          },
          "tickCurrentIndex": {
            "type": "INTEGER"
          },
          "sqrtPrice": {
            "type": "NUMERIC"
          },
          "observedAt": {
            "type": "TIMESTAMPTZ",
            "filterable": true
          },
          "updatedAt": {
            "type": "TIMESTAMPTZ",
            "filterable": true
          },
          "lastEventTime": {
            "type": "TIMESTAMPTZ"
          }
        }
      }
    },
    "Position": {
      "source": {
        "from": "state",
        "recordKind": "account",
        "recordName": "Position"
      },
      "transform": {
        "extract": {
          "subjectId": "$raw.subject_id",
          "resourceId": "$raw.resource_id",
          "position": "$raw.subject_id",
          "whirlpool": "$state.whirlpool",
          "positionMint": "$state.positionMint",
          "liquidity": "$state.liquidity",
          "tickLowerIndex": "$state.tickLowerIndex",
          "tickUpperIndex": "$state.tickUpperIndex",
          "feeGrowthCheckpointA": "$state.feeGrowthCheckpointA",
          "feeOwedA": "$state.feeOwedA",
          "feeGrowthCheckpointB": "$state.feeGrowthCheckpointB",
          "feeOwedB": "$state.feeOwedB",
          "observedAt": "$state.observedAt",
          "updatedAt": "$raw.updated_at",
          "lastEventTime": "$raw.last_event_time"
        }
      },
      "emit": {
        "id": "position",
        "indexes": [
          [
            "whirlpool",
            "updatedAt:desc"
          ],
          [
            "positionMint",
            "updatedAt:desc"
          ],
          [
            "liquidity:desc",
            "updatedAt:desc"
          ]
        ],
        "timeField": "updatedAt",
        "defaultOrderBy": [
          "updatedAt:desc"
        ],
        "fields": {
          "subjectId": {
            "type": "TEXT",
            "filterable": true
          },
          "resourceId": {
            "type": "TEXT"
          },
          "position": {
            "type": "TEXT",
            "primaryKey": true,
            "filterable": true
          },
          "whirlpool": {
            "type": "TEXT",
            "filterable": true
          },
          "positionMint": {
            "type": "TEXT",
            "filterable": true
          },
          "liquidity": {
            "type": "NUMERIC",
            "filterable": true
          },
          "tickLowerIndex": {
            "type": "INTEGER"
          },
          "tickUpperIndex": {
            "type": "INTEGER"
          },
          "feeGrowthCheckpointA": {
            "type": "NUMERIC"
          },
          "feeOwedA": {
            "type": "NUMERIC"
          },
          "feeGrowthCheckpointB": {
            "type": "NUMERIC"
          },
          "feeOwedB": {
            "type": "NUMERIC"
          },
          "observedAt": {
            "type": "TIMESTAMPTZ",
            "filterable": true
          },
          "updatedAt": {
            "type": "TIMESTAMPTZ",
            "filterable": true
          },
          "lastEventTime": {
            "type": "TIMESTAMPTZ"
          }
        }
      }
    },
    "Swap": {
      "source": {
        "from": "record",
        "recordKind": "event",
        "recordName": "SwapEvent"
      },
      "transform": {
        "extract": {
          "recordId": "$raw.record_id",
          "signature": "$raw.signature",
          "pool": "$raw.subject_id",
          "trader": "$payload.trader",
          "side": "$payload.side",
          "eventTime": "$raw.event_time",
          "aToB": "$payload.aToB",
          "inputAmountAtomic": "$payload.inputAmountAtomic",
          "outputAmountAtomic": "$payload.outputAmountAtomic",
          "inputTransferFeeAtomic": "$payload.inputTransferFeeAtomic",
          "outputTransferFeeAtomic": "$payload.outputTransferFeeAtomic",
          "preSqrtPrice": "$payload.preSqrtPrice",
          "postSqrtPrice": "$payload.postSqrtPrice",
          "lpFeeAtomic": "$payload.lpFeeAtomic",
          "protocolFeeAtomic": "$payload.protocolFeeAtomic"
        }
      },
      "emit": {
        "id": "recordId",
        "indexes": [
          [
            "pool",
            "eventTime:desc"
          ],
          [
            "trader",
            "eventTime:desc"
          ]
        ],
        "timeField": "eventTime",
        "defaultOrderBy": [
          "eventTime:desc"
        ],
        "fields": {
          "recordId": {
            "type": "TEXT",
            "primaryKey": true,
            "filterable": true
          },
          "signature": {
            "type": "TEXT",
            "filterable": true
          },
          "pool": {
            "type": "TEXT",
            "filterable": true
          },
          "trader": {
            "type": "TEXT",
            "filterable": true
          },
          "side": {
            "type": "TEXT"
          },
          "eventTime": {
            "type": "TIMESTAMPTZ",
            "filterable": true
          },
          "aToB": {
            "type": "BOOLEAN"
          },
          "inputAmountAtomic": {
            "type": "NUMERIC"
          },
          "outputAmountAtomic": {
            "type": "NUMERIC"
          },
          "inputTransferFeeAtomic": {
            "type": "NUMERIC"
          },
          "outputTransferFeeAtomic": {
            "type": "NUMERIC"
          },
          "preSqrtPrice": {
            "type": "NUMERIC"
          },
          "postSqrtPrice": {
            "type": "NUMERIC"
          },
          "lpFeeAtomic": {
            "type": "NUMERIC"
          },
          "protocolFeeAtomic": {
            "type": "NUMERIC"
          }
        }
      }
    }
  }
}
