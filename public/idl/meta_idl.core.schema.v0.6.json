{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espressocash.com/schemas/meta-idl.core.v0.6.json",
  "title": "Meta IDL Core v0.6 (Protocol-only)",
  "type": "object",
  "properties": {
    "schema": {
      "const": "meta-idl.core.v0.6"
    },
    "version": {
      "type": "string"
    },
    "protocolId": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["rpc_transaction_crawler"]
          },
          "programId": {
            "type": "string"
          },
          "decoderFamily": {
            "type": "string",
            "enum": ["anchor_events"]
          },
          "decoder": {
            "type": "string"
          },
          "commitment": {
            "type": "string",
            "enum": ["processed", "confirmed", "finalized"]
          },
          "filters": {
            "type": "object"
          },
          "handlers": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "action": {
                  "type": "string",
                  "enum": [
                    "emit_state",
                    "emit_record_and_state"
                  ]
                },
                "side": {
                  "type": "string",
                  "enum": ["buy", "sell"]
                },
                "resolve": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "compute": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "emit": {
                  "type": "object",
                  "properties": {
                    "record": {
                      "type": "object",
                      "properties": {
                        "recordName": { "type": "string" },
                        "payload": {}
                      },
                      "required": ["recordName", "payload"],
                      "additionalProperties": true
                    },
                    "state": {
                      "type": "object",
                      "properties": {
                        "recordName": { "type": "string" },
                        "payload": {}
                      },
                      "required": ["recordName", "payload"],
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": ["action"],
              "additionalProperties": true
            }
          }
        },
        "required": ["kind", "programId", "decoder"],
        "additionalProperties": true
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "required": [
    "schema",
    "version",
    "protocolId",
    "label",
    "operations"
  ],
  "additionalProperties": false
}
