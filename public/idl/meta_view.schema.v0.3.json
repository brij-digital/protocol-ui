{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentform.app/schemas/meta_view.v0.3.json",
  "title": "Meta View v0.3",
  "description": "View specification for current-state account/search reads plus time-series and feed views.",
  "oneOf": [
    { "$ref": "#/$defs/accountViewSpec" },
    { "$ref": "#/$defs/searchViewSpec" },
    { "$ref": "#/$defs/seriesViewSpec" },
    { "$ref": "#/$defs/feedViewSpec" }
  ],
  "$defs": {
    "freshnessSpec": {
      "type": "object",
      "required": ["class"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["realtime", "near_realtime", "best_effort", "historical"]
        },
        "target_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_staleness_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "filterValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" }
      ]
    },
    "conditionSpec": {
      "type": "object",
      "required": ["field", "op", "value"],
      "properties": {
        "field": { "type": "string" },
        "op": {
          "type": "string",
          "enum": ["=", "!=", ">", ">=", "<", "<=", "in"]
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "filterGroupAll": {
      "type": "object",
      "required": ["all"],
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/conditionSpec" }
        }
      },
      "additionalProperties": false
    },
    "filterGroupAny": {
      "type": "object",
      "required": ["any"],
      "properties": {
        "any": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/filterGroupAll" },
              { "$ref": "#/$defs/conditionSpec" }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "sortSpec": {
      "type": "object",
      "required": ["field", "dir"],
      "properties": {
        "field": { "type": "string" },
        "dir": { "type": "string", "enum": ["asc", "desc"] },
        "mode": {
          "type": "string",
          "enum": ["indexed", "live", "indexed_then_live_refine"]
        },
        "candidate_limit": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "bootstrapFilterSpec": {
      "type": "object",
      "properties": {
        "memcmp": {
          "type": "object",
          "required": ["offset"],
          "properties": {
            "offset": { "type": "integer", "minimum": 0 },
            "bytes": { "type": "string" },
            "bytesFrom": { "type": "string" }
          },
          "additionalProperties": false,
          "anyOf": [
            { "required": ["bytes"] },
            { "required": ["bytesFrom"] }
          ]
        }
      },
      "additionalProperties": false,
      "required": ["memcmp"]
    },
    "bootstrapSpec": {
      "type": "object",
      "required": ["kind", "source", "program_id", "account_type"],
      "properties": {
        "kind": { "const": "scan_accounts" },
        "source": { "const": "rpc.getProgramAccounts" },
        "program_id": { "type": "string" },
        "account_type": { "type": "string" },
        "lookback_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "max_pages": {
          "type": "integer",
          "minimum": 1
        },
        "retention_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/bootstrapFilterSpec" }
        }
      },
      "additionalProperties": false
    },
    "refreshSpec": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["stream", "poll", "on_demand", "manual"]
        },
        "source": { "type": "string" },
        "interval_ms": { "type": "integer", "minimum": 0 },
        "cursor_path": { "type": "string" },
        "account_keys_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "hydrateSpec": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "accounts"]
        },
        "candidate_limit": {
          "type": "integer",
          "minimum": 1
        },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "decodeSpec": {
      "type": "object",
      "required": ["account_type"],
      "properties": {
        "account_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "querySpec": {
      "type": "object",
      "required": ["select"],
      "properties": {
        "indexed_filters": {
          "oneOf": [
            { "$ref": "#/$defs/filterGroupAll" },
            { "$ref": "#/$defs/filterGroupAny" }
          ]
        },
        "filters": {
          "oneOf": [
            { "$ref": "#/$defs/filterGroupAll" },
            { "$ref": "#/$defs/filterGroupAny" }
          ]
        },
        "hydrate": { "$ref": "#/$defs/hydrateSpec" },
        "decode": { "$ref": "#/$defs/decodeSpec" },
        "sort": {
          "type": "array",
          "items": { "$ref": "#/$defs/sortSpec" }
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        },
        "select": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "additionalProperties": false
    },
    "accountTargetSpec": {
      "type": "object",
      "required": ["address", "account_type"],
      "properties": {
        "address": {},
        "account_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "metricSpec": {
      "type": "object",
      "required": ["name", "field", "agg"],
      "properties": {
        "name": { "type": "string" },
        "field": { "type": "string" },
        "agg": {
          "type": "string",
          "enum": ["first", "last", "min", "max", "sum", "avg", "count"]
        }
      },
      "additionalProperties": false
    },
    "timeSpec": {
      "type": "object",
      "required": ["field", "bucket"],
      "properties": {
        "field": { "type": "string" },
        "bucket": { "type": "string" },
        "from": {},
        "to": {},
        "timezone": { "type": "string" }
      },
      "additionalProperties": false
    },
    "entitySpec": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string" },
        "id": {}
      },
      "additionalProperties": false
    },
    "canonicalSpec": {
      "type": "object",
      "required": ["source", "protocol_id"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["indexed_idl_records", "indexed_idl_state", "indexed_series_1m"]
        },
        "protocol_id": { "type": "string" },
        "record_kind": { "type": "string" },
        "record_name": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          ]
        },
        "series_id": { "type": "string" },
        "market_type": { "type": "string" },
        "subject_input": { "type": "string" },
        "resource_input": { "type": "string" },
        "subject_field": { "type": "string" },
        "resource_field": { "type": "string" },
        "time_field": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "projectionAggregationSpec": {
      "type": "object",
      "required": ["name", "field", "fn"],
      "properties": {
        "name": { "type": "string" },
        "field": { "type": "string" },
        "fn": {
          "type": "string",
          "enum": ["first", "last", "min", "max", "sum", "avg", "count", "count_distinct"]
        }
      },
      "additionalProperties": false
    },
    "projectionSpec": {
      "type": "object",
      "required": ["projection_kind"],
      "properties": {
        "projection_kind": {
          "type": "string",
          "enum": ["snapshot", "feed", "series", "ranking", "context"]
        },
        "source_operation": { "type": "string" },
        "group_by": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bucket": { "type": "string" },
        "fill_mode": {
          "type": "string",
          "enum": ["sparse", "dense"]
        },
        "aggregations": {
          "type": "array",
          "items": { "$ref": "#/$defs/projectionAggregationSpec" }
        },
        "ranking": {
          "type": "object",
          "properties": {
            "state_operation": { "type": "string" },
            "window_hours_input": { "type": "string" },
            "max_activity_age_minutes_input": { "type": "string" },
            "min_liquidity_input": { "type": "string" },
            "min_volume_input": { "type": "string" },
            "default_window_hours": { "type": "integer", "minimum": 1 },
            "default_max_activity_age_minutes": { "type": "integer", "minimum": 1 },
            "quote_mint_input": { "type": "string" },
            "default_quote_mint": { "type": "string" },
            "event_fields": {
              "type": "object",
              "properties": {
                "market_type": { "type": "string" },
                "participant": { "type": "string" },
                "side": { "type": "string" },
                "volume": { "type": "string" }
              }
            },
            "state_fields": {
              "type": "object",
              "properties": {
                "market_type": { "type": "string" },
                "quote_mint": { "type": "string" },
                "liquidity": { "type": "string" },
                "price": { "type": "string" },
                "market_cap": { "type": "string" },
                "pool": { "type": "string" }
              }
            }
          }
        },
        "sort_by": {
          "type": "array",
          "items": { "$ref": "#/$defs/sortSpec" }
        }
      },
      "additionalProperties": false
    },
    "accountViewSpec": {
      "type": "object",
      "required": ["kind", "target", "select"],
      "properties": {
        "kind": { "const": "account" },
        "source_kind": { "type": "string" },
        "freshness": { "$ref": "#/$defs/freshnessSpec" },
        "entity_type": { "type": "string" },
        "target": { "$ref": "#/$defs/accountTargetSpec" },
        "refresh": { "$ref": "#/$defs/refreshSpec" },
        "canonical": { "$ref": "#/$defs/canonicalSpec" },
        "projection": { "$ref": "#/$defs/projectionSpec" },
        "select": {
          "type": "object",
          "additionalProperties": {}
        },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "searchViewSpec": {
      "type": "object",
      "required": ["kind", "entity_type", "bootstrap", "query"],
      "properties": {
        "kind": { "const": "search" },
        "source_kind": { "type": "string" },
        "freshness": { "$ref": "#/$defs/freshnessSpec" },
        "entity_type": { "type": "string" },
        "sync_disabled": { "type": "boolean" },
        "bootstrap": { "$ref": "#/$defs/bootstrapSpec" },
        "refresh": { "$ref": "#/$defs/refreshSpec" },
        "canonical": { "$ref": "#/$defs/canonicalSpec" },
        "projection": { "$ref": "#/$defs/projectionSpec" },
        "query": { "$ref": "#/$defs/querySpec" },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "seriesViewSpec": {
      "type": "object",
      "required": ["kind", "entity_type"],
      "properties": {
        "kind": { "const": "series" },
        "source_kind": { "type": "string" },
        "freshness": { "$ref": "#/$defs/freshnessSpec" },
        "entity_type": { "type": "string" },
        "entity": { "$ref": "#/$defs/entitySpec" },
        "canonical": { "$ref": "#/$defs/canonicalSpec" },
        "projection": { "$ref": "#/$defs/projectionSpec" },
        "time": { "$ref": "#/$defs/timeSpec" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metricSpec" }
        },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "feedViewSpec": {
      "type": "object",
      "required": ["kind", "entity_type"],
      "properties": {
        "kind": { "const": "feed" },
        "source_kind": { "type": "string" },
        "freshness": { "$ref": "#/$defs/freshnessSpec" },
        "entity_type": { "type": "string" },
        "entity": { "$ref": "#/$defs/entitySpec" },
        "canonical": { "$ref": "#/$defs/canonicalSpec" },
        "projection": { "$ref": "#/$defs/projectionSpec" },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
