              },
              "quoteMint": {
                "type": "pubkey",
                "required": false
              },
              "priceQuote": {
                "type": "number",
                "required": false
              },
              "marketCapQuote": {
                "type": "number",
                "required": false
              },
              "liquidityQuote": {
                "type": "number",
