            "BondingCurve"
          ],
          "notes": "Canonical Pump AMM market search by base and quote mint."
        },
        "projection": {
          "projection_kind": "search",
          "filters": {
            "all": [
              {
                "field": "mint",
                "op": "=",
                "value": "$input.base_mint"
              },
              {
                "field": "quoteMint",
                "op": "=",
                "value": "$input.quote_mint"
              }
            ]
          },
          "sort_by": [
            {
              "field": "liquidityQuote",
              "dir": "desc"
            },
            {
              "field": "updatedAt",
              "dir": "desc"
            }
          ]
        },
        "inputs": {
          "base_mint": {
            "type": "pubkey",
            "required": true
          },
          "quote_mint": {
            "type": "pubkey",
            "required": false,
            "default": "So11111111111111111111111111111111111111112"
          }
        },
        "read_output": {
          "source": "$items",
          "type": "array",
          "item_schema": {
            "entity_type": "pump_pool",
            "identity_fields": [
              "pool"
            ],
            "fields": {
              "mint": {
