          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "compute",
            "base",
            "step",
            "count"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "compute": {
              "const": "list.range_map"
            },
            "base": {},
            "step": {},
            "count": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
