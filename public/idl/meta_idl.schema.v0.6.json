{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espressocash.com/schemas/meta-idl.v0.6.json",
  "title": "Espresso Meta IDL v0.6 (App-first)",
  "type": "object",
  "properties": {
    "schema": {
      "const": "meta-idl.v0.6"
    },
    "version": {
      "type": "string"
    },
    "protocolId": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sourceSpec"
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/templateSpec"
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/actionSpec"
      }
    },
    "apps": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/userAppSpec"
      }
    }
  },
  "required": [
    "schema",
    "version",
    "protocolId",
    "label",
    "operations",
    "apps"
  ],
  "$defs": {
    "sourceSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "items"
          ],
          "properties": {
            "kind": {
              "const": "inline"
            },
            "items": {
              "type": "array",
              "items": {}
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "url"
          ],
          "properties": {
            "kind": {
              "const": "http_json"
            },
            "url": {
              "type": "string"
            },
            "items_path": {
              "type": "string"
            },
            "ttl_ms": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "actionInputSpec": {
      "type": "object",
      "required": [
        "type",
        "label"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "placeholder": {
          "type": "string"
        },
        "help": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "display_order": {
          "type": "number"
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "read_from": {
          "type": "string",
          "minLength": 1
        },
        "validate": {
          "$ref": "#/$defs/inputValidationSpec"
        },
        "ui_editable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "inputValidationSpec": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean"
        },
        "min": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "max": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "pattern": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "operationValidationCrossRule": {
      "type": "object",
      "required": [
        "kind",
        "left",
        "right"
      ],
      "properties": {
        "kind": {
          "const": "not_equal"
        },
        "left": {
          "type": "string"
        },
        "right": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "operationValidationSpec": {
      "type": "object",
      "properties": {
        "cross": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/operationValidationCrossRule"
          }
        }
      },
      "additionalProperties": false
    },
    "readOutputSpec": {
      "type": "object",
      "required": [
        "type",
        "source"
      ],
      "properties": {
        "type": {
          "enum": [
            "array",
            "object",
            "scalar"
          ]
        },
        "source": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "empty_text": {
          "type": "string"
        },
        "max_items": {
          "type": "integer",
          "minimum": 1
        },
        "item_label_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "viewSpec": {
      "type": "object",
      "required": [
        "bootstrap",
        "mapping",
        "entity_keys"
      ],
      "properties": {
        "bootstrap": {
          "type": "object",
          "required": [
            "kind",
            "steps"
          ],
          "properties": {
            "kind": {
              "const": "query"
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        },
        "stream": {
          "type": "object",
          "required": [
            "kind",
            "source",
            "filter"
          ],
          "properties": {
            "kind": {
              "const": "event"
            },
            "source": {
              "type": "string"
            },
            "filter": {
              "type": "string"
            },
            "cursor_path": {
              "type": "string"
            },
            "account_keys_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "mapping": {
          "type": "object",
          "required": [
            "source"
          ],
          "properties": {
            "source": {
              "type": "string"
            },
            "select": {
              "type": "object",
              "additionalProperties": {}
            },
            "transforms": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "entity_keys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "userAppStatusTextSpec": {
      "type": "object",
      "properties": {
        "idle": {
          "type": "string"
        },
        "running": {
          "type": "string"
        },
        "success": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "userAppActionSpec": {
      "type": "object",
      "required": [
        "label",
        "do"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "do": {
          "type": "object",
          "required": [
            "fn"
          ],
          "properties": {
            "fn": {
              "enum": [
                "run",
                "back",
                "reset"
              ]
            },
            "mode": {
              "enum": [
                "view",
                "simulate",
                "send"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "do": {
                "properties": {
                  "fn": {
                    "const": "run"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "do": {
                "required": [
                  "mode"
                ]
              }
            }
          },
          "else": {
            "properties": {
              "do": {
                "not": {
                  "required": [
                    "mode"
                  ]
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "userAppStepSpec": {
      "type": "object",
      "required": [
        "id",
        "operation",
        "title",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "next_on_success": {
          "type": "string"
        },
        "status_text": {
          "$ref": "#/$defs/userAppStatusTextSpec"
        },
        "input_from": {
          "type": "object",
          "additionalProperties": {}
        },
        "requires_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/userAppActionSpec"
          }
        },
        "ui": {
          "type": "object",
          "required": [
            "kind",
            "source",
            "bind_to",
            "value_path",
            "require_selection",
            "auto_advance"
          ],
          "properties": {
            "kind": {
              "const": "select_from_derived"
            },
            "source": {
              "type": "string"
            },
            "bind_to": {
              "type": "string"
            },
            "value_path": {
              "type": "string"
            },
            "label_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "require_selection": {
              "type": "boolean"
            },
            "auto_advance": {
              "type": "boolean"
            },
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "userAppSpec": {
      "type": "object",
      "required": [
        "title",
        "label",
        "entry_step",
        "steps"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "entry_step": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/userAppStepSpec"
          }
        }
      },
      "additionalProperties": false
    },
    "deriveStep": {
      "type": "object",
      "required": [
        "name",
        "resolver"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "resolver": {
          "enum": [
            "wallet_pubkey",
            "decode_account",
            "account_owner",
            "token_supply",
            "token_account_balance",
            "ata",
            "pda",
            "lookup",
            "unix_timestamp"
          ]
        },
        "address": {},
        "account_type": {
          "type": "string"
        },
        "owner": {},
        "mint": {},
        "allow_owner_off_curve": {
          "type": "boolean"
        },
        "program_id": {},
        "seeds": {
          "type": "array",
          "items": {}
        },
        "source": {
          "type": "string"
        },
        "where": {},
        "select": {},
        "mode": {
          "enum": [
            "first",
            "all"
          ]
        }
      },
      "additionalProperties": false
    },
    "pdaSeedSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "utf8"
            },
            "value": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "pubkey"
            },
            "value": {}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "i32_le"
            },
            "value": {}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "item_i32_le"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "item_utf8"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "computeStep": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "name",
            "compute",
            "values"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "compute": {
              "const": "math.add"
            },
            "values": {
              "type": "array",
              "items": {},
              "minItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "compute",
            "values"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "compute": {
              "const": "math.mul"
            },
            "values": {
              "type": "array",
              "items": {},
              "minItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "compute",
            "dividend",
            "divisor"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "compute": {
