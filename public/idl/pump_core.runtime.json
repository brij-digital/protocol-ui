{
  "$schema": "/idl/solana_agent_runtime.schema.v1.json",
  "schema": "solana-agent-runtime.v1",
  "reads": {
    "preview_buy_exact_sol_in": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true
        },
        "spendable_sol_in": {
          "type": "u64",
          "required": true
        },
        "slippage_bps": {
          "type": "u16",
          "required": true
        },
        "track_volume": {
          "type": "bool",
          "required": false,
          "default": false
        }
      },
      "load": [
        {
          "name": "wallet",
          "kind": "wallet_pubkey"
        },
        {
          "name": "token_program",
          "kind": "account_owner",
          "address": "$input.base_mint"
        },
        {
          "name": "global",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:global"
          ]
        },
        {
          "name": "global_data",
          "kind": "decode_account",
          "address": "$global",
          "account_type": "Global"
        },
        {
          "name": "bonding_curve",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:bonding-curve",
            "$input.base_mint"
          ]
        },
        {
          "name": "bonding_curve_v2",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:bonding-curve-v2",
            "$input.base_mint"
          ]
        },
        {
          "name": "bonding_curve_data",
          "kind": "decode_account",
          "address": "$bonding_curve",
          "account_type": "BondingCurve"
        },
        {
          "name": "associated_bonding_curve",
          "kind": "ata",
          "owner": "$bonding_curve",
          "mint": "$input.base_mint",
          "token_program": "$token_program",
          "allow_owner_off_curve": true
        },
        {
          "name": "associated_user",
          "kind": "ata",
          "owner": "$wallet",
          "mint": "$input.base_mint",
          "token_program": "$token_program"
        },
        {
          "name": "creator_vault",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:creator-vault",
            "$bonding_curve_data.creator"
          ]
        },
        {
          "name": "event_authority",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:__event_authority"
          ]
        },
        {
          "name": "global_volume_accumulator",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:global_volume_accumulator"
          ]
        },
        {
          "name": "user_volume_accumulator",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:user_volume_accumulator",
            "$wallet"
          ]
        },
        {
          "name": "fee_config",
          "kind": "pda",
          "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
          "seeds": [
            "utf8:fee_config",
            "$protocol.programId"
          ]
        }
      ],
      "transform": [
        "preview_buy_exact_sol_in__transform"
      ],
      "output": {
        "type": "object",
        "source": "$derived",
        "object_schema": {
          "entity_type": "pump_core_preview_buy_exact_sol_in",
          "fields": {
            "base_mint": {
              "type": "pubkey",
              "required": false
            },
            "spendable_sol_in": {
              "type": "u64",
              "required": false
            },
            "slippage_bps": {
              "type": "u16",
              "required": false
            },
            "estimated_out_auto": {
              "type": "u64",
              "required": false
            },
            "min_tokens_out_auto": {
              "type": "u64",
              "required": false
            },
            "total_fee_bps": {
              "type": "u16",
              "required": false
            }
          }
        }
      }
    }
  },
  "writes": {
    "buy_exact_sol_in": {
      "instruction": "buy_exact_sol_in",
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true
        },
        "spendable_sol_in": {
          "type": "u64",
          "required": true
        },
        "slippage_bps": {
          "type": "u16",
          "required": true
        },
        "track_volume": {
          "type": "bool",
          "required": false,
          "default": false
        }
      },
      "load": [
        {
          "name": "wallet",
          "kind": "wallet_pubkey"
        },
        {
          "name": "token_program",
          "kind": "account_owner",
          "address": "$input.base_mint"
        },
        {
          "name": "global",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:global"
          ]
        },
        {
          "name": "global_data",
          "kind": "decode_account",
          "address": "$global",
          "account_type": "Global"
        },
        {
          "name": "bonding_curve",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:bonding-curve",
            "$input.base_mint"
          ]
        },
        {
          "name": "bonding_curve_v2",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:bonding-curve-v2",
            "$input.base_mint"
          ]
        },
        {
          "name": "bonding_curve_data",
          "kind": "decode_account",
          "address": "$bonding_curve",
          "account_type": "BondingCurve"
        },
        {
          "name": "associated_bonding_curve",
          "kind": "ata",
          "owner": "$bonding_curve",
          "mint": "$input.base_mint",
          "token_program": "$token_program",
          "allow_owner_off_curve": true
        },
        {
          "name": "associated_user",
          "kind": "ata",
          "owner": "$wallet",
          "mint": "$input.base_mint",
          "token_program": "$token_program"
        },
        {
          "name": "creator_vault",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:creator-vault",
            "$bonding_curve_data.creator"
          ]
        },
        {
          "name": "event_authority",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:__event_authority"
          ]
        },
        {
          "name": "global_volume_accumulator",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:global_volume_accumulator"
          ]
        },
        {
          "name": "user_volume_accumulator",
          "kind": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:user_volume_accumulator",
            "$wallet"
          ]
        },
        {
          "name": "fee_config",
          "kind": "pda",
          "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
          "seeds": [
            "utf8:fee_config",
            "$protocol.programId"
          ]
        }
      ],
      "transform": [
        "buy_exact_sol_in__transform"
      ],
      "args": {
        "spendable_sol_in": "$input.spendable_sol_in",
        "min_tokens_out": "$min_tokens_out_auto",
        "track_volume": "$input.track_volume"
      },
      "accounts": {
        "fee_recipient": "$global_data.fee_recipient",
        "mint": "$input.base_mint",
        "associated_user": "$associated_user",
        "token_program": "$token_program",
        "creator_vault": "$creator_vault"
      },
      "pre": [
        {
          "kind": "spl_ata_create_idempotent",
          "payer": "$wallet",
          "ata": "$associated_user",
          "owner": "$wallet",
          "mint": "$input.base_mint",
          "token_program": "$token_program"
        }
      ]
    }
  },
  "transforms": {
    "preview_buy_exact_sol_in__transform": [
      {
        "name": "creator_is_default",
        "kind": "compare.equals",
        "left": "$bonding_curve_data.creator",
        "right": "11111111111111111111111111111111"
      },
      {
        "name": "creator_fee_bps_effective",
        "kind": "logic.if",
        "condition": "$creator_is_default",
        "then": "0",
        "else": "$global_data.creator_fee_basis_points"
      },
      {
        "name": "total_fee_bps",
        "kind": "math.add",
        "values": [
          "$global_data.fee_basis_points",
          "$creator_fee_bps_effective"
        ]
      },
      {
        "name": "net_sol_numerator",
        "kind": "math.mul",
        "values": [
          "$input.spendable_sol_in",
          "10000"
        ]
      },
      {
        "name": "net_sol_denominator",
        "kind": "math.add",
        "values": [
          "10000",
          "$total_fee_bps"
        ]
      },
      {
        "name": "net_sol_raw",
        "kind": "math.floor_div",
        "dividend": "$net_sol_numerator",
        "divisor": "$net_sol_denominator"
      },
      {
        "name": "net_sol_minus_one_candidate",
        "kind": "math.sub",
        "values": [
          "$net_sol_raw",
          "1"
        ]
      },
      {
        "name": "net_sol_gt_one",
        "kind": "compare.gt",
        "left": "$net_sol_raw",
        "right": "1"
      },
      {
        "name": "net_sol_minus_one",
        "kind": "logic.if",
        "condition": "$net_sol_gt_one",
        "then": "$net_sol_minus_one_candidate",
        "else": "0"
      },
      {
        "name": "estimated_out_numerator",
        "kind": "math.mul",
        "values": [
          "$net_sol_minus_one",
          "$bonding_curve_data.virtual_token_reserves"
        ]
      },
      {
        "name": "estimated_out_denominator",
        "kind": "math.add",
        "values": [
          "$bonding_curve_data.virtual_sol_reserves",
          "$net_sol_minus_one"
        ]
      },
      {
        "name": "estimated_out_auto",
        "kind": "math.floor_div",
        "dividend": "$estimated_out_numerator",
        "divisor": "$estimated_out_denominator"
      },
      {
        "name": "slippage_keep_bps",
        "kind": "math.sub",
        "values": [
          "10000",
          "$input.slippage_bps"
        ]
      },
      {
        "name": "min_tokens_out_auto_numerator",
        "kind": "math.mul",
        "values": [
          "$estimated_out_auto",
          "$slippage_keep_bps"
        ]
      },
      {
        "name": "min_tokens_out_auto",
        "kind": "math.floor_div",
        "dividend": "$min_tokens_out_auto_numerator",
        "divisor": "10000"
      }
    ],
    "buy_exact_sol_in__transform": [
      {
        "name": "creator_is_default",
        "kind": "compare.equals",
        "left": "$bonding_curve_data.creator",
        "right": "11111111111111111111111111111111"
      },
      {
        "name": "creator_fee_bps_effective",
        "kind": "logic.if",
        "condition": "$creator_is_default",
        "then": "0",
        "else": "$global_data.creator_fee_basis_points"
      },
      {
        "name": "total_fee_bps",
        "kind": "math.add",
        "values": [
          "$global_data.fee_basis_points",
          "$creator_fee_bps_effective"
        ]
      },
      {
        "name": "net_sol_numerator",
        "kind": "math.mul",
        "values": [
          "$input.spendable_sol_in",
          "10000"
        ]
      },
      {
        "name": "net_sol_denominator",
        "kind": "math.add",
        "values": [
          "10000",
          "$total_fee_bps"
        ]
      },
      {
        "name": "net_sol_raw",
        "kind": "math.floor_div",
        "dividend": "$net_sol_numerator",
        "divisor": "$net_sol_denominator"
      },
      {
        "name": "net_sol_minus_one_candidate",
        "kind": "math.sub",
        "values": [
          "$net_sol_raw",
          "1"
        ]
      },
      {
        "name": "net_sol_gt_one",
        "kind": "compare.gt",
        "left": "$net_sol_raw",
        "right": "1"
      },
      {
        "name": "net_sol_minus_one",
        "kind": "logic.if",
        "condition": "$net_sol_gt_one",
        "then": "$net_sol_minus_one_candidate",
        "else": "0"
      },
      {
        "name": "estimated_out_numerator",
        "kind": "math.mul",
        "values": [
          "$net_sol_minus_one",
          "$bonding_curve_data.virtual_token_reserves"
        ]
      },
      {
        "name": "estimated_out_denominator",
        "kind": "math.add",
        "values": [
          "$bonding_curve_data.virtual_sol_reserves",
          "$net_sol_minus_one"
        ]
      },
      {
        "name": "estimated_out_auto",
        "kind": "math.floor_div",
        "dividend": "$estimated_out_numerator",
        "divisor": "$estimated_out_denominator"
      },
      {
        "name": "slippage_keep_bps",
        "kind": "math.sub",
        "values": [
          "10000",
          "$input.slippage_bps"
        ]
      },
      {
        "name": "min_tokens_out_auto_numerator",
        "kind": "math.mul",
        "values": [
          "$estimated_out_auto",
          "$slippage_keep_bps"
        ]
      },
      {
        "name": "min_tokens_out_auto",
        "kind": "math.floor_div",
        "dividend": "$min_tokens_out_auto_numerator",
        "divisor": "10000"
      }
    ]
  }
}
