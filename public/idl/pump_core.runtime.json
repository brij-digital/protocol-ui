{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "protocolId": "pump-core-mainnet",
  "label": "Pump Core Declarative Runtime",
  "programId": "$protocol.programId",
  "decoderArtifacts": {
    "pumpfun": {
      "kind": "generated_idl_decoder",
      "family": "codama",
      "codamaPath": "/idl/pump_core.codama.json",
      "codecIdlPath": "/idl/pump_core.json",
      "artifact": "pumpfun"
    }
  },
  "sources": {
    "pump_core_crawler": {
      "kind": "rpc_transaction_crawler",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "pumpfun",
      "decodeTargets": [
        "instruction",
        "log_event"
      ],
      "filters": {}
    }
  },
  "matchRules": [
    {
      "source": "pump_core_crawler",
      "match": {
        "decodedType": "event",
        "name": "CreateEvent"
      },
      "pipeline": "curve_create"
    },
    {
      "source": "pump_core_crawler",
      "match": {
        "decodedType": "event",
        "name": "TradeEvent"
      },
      "pipeline": "curve_trade"
    }
  ],
  "pipelines": {
    "curve_create": {
      "extract": {
        "mint": "$decoded.mint",
        "pool": "$decoded.mint",
        "marketType": "core",
        "quoteMint": "So11111111111111111111111111111111111111112",
        "quoteDecimals": 9,
        "creator": "$decoded.creator",
        "complete": false,
        "observedAt": "$update.eventTime",
        "virtualTokenReservesAtomic": "$decoded.virtual_token_reserves",
        "virtualSolReservesAtomic": "$decoded.virtual_sol_reserves",
        "realTokenReservesAtomic": "$decoded.real_token_reserves",
        "tokenTotalSupplyAtomic": "$decoded.token_total_supply"
      },
      "resolve": [
        {
          "name": "baseSupply",
          "resolve": "rpc.token_supply",
          "mint": "$ctx.mint"
        }
      ],
      "compute": [
        {
          "name": "virtualTokenReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.virtualTokenReservesAtomic",
          "decimals": "$baseSupply.decimals"
        },
        {
          "name": "quoteReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.virtualSolReservesAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "priceQuote",
          "compute": "math.safe_div",
          "dividend": "$quoteReserveUi",
          "divisor": "$virtualTokenReserveUi"
        },
        {
          "name": "supplyPositive",
          "compute": "compare.gt",
          "left": "$baseSupply.supplyUi",
          "right": 0
        },
        {
          "name": "marketCapRaw",
          "compute": "math.mul",
          "values": [
            "$priceQuote",
            "$baseSupply.supplyUi"
          ]
        },
        {
          "name": "marketCapQuote",
          "compute": "logic.if",
          "condition": "$supplyPositive",
          "then": "$marketCapRaw",
          "else": "$null"
        },
        {
          "name": "baseReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.realTokenReservesAtomic",
          "decimals": "$baseSupply.decimals"
        },
        {
          "name": "liquidityQuote",
          "compute": "math.add",
          "values": [
            "$quoteReserveUi"
          ]
        },
        {
          "name": "initialRealTokenReservesUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.tokenTotalSupplyAtomic",
          "decimals": "$baseSupply.decimals"
        },
        {
          "name": "initialPositive",
          "compute": "compare.gt",
          "left": "$initialRealTokenReservesUi",
          "right": 0
        },
        {
          "name": "progressNumerator",
          "compute": "math.sub",
          "values": [
            "$initialRealTokenReservesUi",
            "$baseReserveUi"
          ]
        },
        {
          "name": "progressRatio",
          "compute": "math.safe_div",
          "dividend": "$progressNumerator",
          "divisor": "$initialRealTokenReservesUi"
        },
        {
          "name": "progressPctRaw",
          "compute": "math.mul",
          "values": [
            "$progressRatio",
            100
          ]
        },
        {
          "name": "bondingCurveProgressPct",
          "compute": "logic.if",
          "condition": "$initialPositive",
          "then": "$progressPctRaw",
          "else": "$null"
        }
      ],
      "emit": {
        "state": {
          "recordKind": "state",
          "recordName": "BondingCurve",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "quoteMint": "$ctx.quoteMint",
            "baseDecimals": "$baseSupply.decimals",
            "quoteDecimals": "$ctx.quoteDecimals",
            "priceQuote": "$priceQuote",
            "marketCapQuote": "$marketCapQuote",
            "liquidityQuote": "$liquidityQuote",
            "baseReserveUi": "$baseReserveUi",
            "quoteReserveUi": "$quoteReserveUi",
            "baseSupplyUi": "$baseSupply.supplyUi",
            "creator": "$ctx.creator",
            "bondingCurveProgressPct": "$bondingCurveProgressPct",
            "complete": "$ctx.complete",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "curve_trade": {
      "extract": {
        "mint": "$decoded.mint",
        "pool": "$decoded.mint",
        "marketType": "core",
        "quoteMint": "So11111111111111111111111111111111111111112",
        "quoteDecimals": 9,
        "creator": "$decoded.creator",
        "complete": false,
        "observedAt": "$update.eventTime",
        "participant": "$decoded.user",
        "isBuy": "$decoded.is_buy",
        "baseAmountAtomic": "$decoded.token_amount",
        "quoteAmountAtomic": "$decoded.sol_amount",
        "virtualTokenReservesAtomic": "$decoded.virtual_token_reserves",
        "virtualSolReservesAtomic": "$decoded.virtual_sol_reserves",
        "realTokenReservesAtomic": "$decoded.real_token_reserves",
        "realSolReservesAtomic": "$decoded.real_sol_reserves",
        "totalUnclaimedTokensAtomic": "$decoded.total_unclaimed_tokens",
        "totalClaimedTokensAtomic": "$decoded.total_claimed_tokens",
        "signature": "$update.signature",
        "slot": "$update.slot"
      },
      "resolve": [
        {
          "name": "baseSupply",
          "resolve": "rpc.token_supply",
          "mint": "$ctx.mint"
        }
      ],
      "compute": [
        {
          "name": "side",
          "compute": "logic.if",
          "condition": "$ctx.isBuy",
          "then": "buy",
          "else": "sell"
        },
        {
          "name": "virtualTokenReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.virtualTokenReservesAtomic",
          "decimals": "$baseSupply.decimals"
        },
        {
          "name": "virtualSolReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.virtualSolReservesAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "priceQuote",
          "compute": "math.safe_div",
          "dividend": "$virtualSolReserveUi",
          "divisor": "$virtualTokenReserveUi"
        },
        {
          "name": "supplyPositive",
          "compute": "compare.gt",
          "left": "$baseSupply.supplyUi",
          "right": 0
        },
        {
          "name": "marketCapRaw",
          "compute": "math.mul",
          "values": [
            "$priceQuote",
            "$baseSupply.supplyUi"
          ]
        },
        {
          "name": "marketCapQuote",
          "compute": "logic.if",
          "condition": "$supplyPositive",
          "then": "$marketCapRaw",
          "else": "$null"
        },
        {
          "name": "quoteAmountUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.quoteAmountAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "baseReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.realTokenReservesAtomic",
          "decimals": "$baseSupply.decimals"
        },
        {
          "name": "quoteReserveUi",
          "compute": "math.amount_ui",
          "amount": "$ctx.realSolReservesAtomic",
          "decimals": "$ctx.quoteDecimals"
        },
        {
          "name": "liquidityQuote",
          "compute": "math.add",
          "values": [
            "$quoteReserveUi"
          ]
        },
        {
          "name": "initialRealTokenReservesAtomic",
          "compute": "math.add",
          "values": [
            "$ctx.realTokenReservesAtomic",
            "$ctx.totalUnclaimedTokensAtomic",
            "$ctx.totalClaimedTokensAtomic"
          ]
        },
        {
          "name": "initialRealTokenReservesUi",
          "compute": "math.amount_ui",
          "amount": "$initialRealTokenReservesAtomic",
          "decimals": "$baseSupply.decimals"
        },
        {
          "name": "initialPositive",
          "compute": "compare.gt",
          "left": "$initialRealTokenReservesUi",
          "right": 0
        },
        {
          "name": "progressNumerator",
          "compute": "math.sub",
          "values": [
            "$initialRealTokenReservesUi",
            "$baseReserveUi"
          ]
        },
        {
          "name": "progressRatio",
          "compute": "math.safe_div",
          "dividend": "$progressNumerator",
          "divisor": "$initialRealTokenReservesUi"
        },
        {
          "name": "progressPctRaw",
          "compute": "math.mul",
          "values": [
            "$progressRatio",
            100
          ]
        },
        {
          "name": "bondingCurveProgressPct",
          "compute": "logic.if",
          "condition": "$initialPositive",
          "then": "$progressPctRaw",
          "else": "$null"
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "TradeEvent",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.participant",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "participant": "$ctx.participant",
            "side": "$ctx.side",
            "priceQuote": "$priceQuote",
            "marketCapQuote": "$marketCapQuote",
            "quoteAmountUi": "$quoteAmountUi",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "BondingCurve",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "quoteMint": "$ctx.quoteMint",
            "baseDecimals": "$baseSupply.decimals",
            "quoteDecimals": "$ctx.quoteDecimals",
            "priceQuote": "$priceQuote",
            "marketCapQuote": "$marketCapQuote",
            "liquidityQuote": "$liquidityQuote",
            "baseReserveUi": "$baseReserveUi",
            "quoteReserveUi": "$quoteReserveUi",
            "baseSupplyUi": "$baseSupply.supplyUi",
            "creator": "$ctx.creator",
            "bondingCurveProgressPct": "$bondingCurveProgressPct",
            "complete": "$ctx.complete",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    }
  },
  "operations": {
    "buy_exact_sol_in": {
      "instruction": "buy_exact_sol_in",
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true,
          "label": "Token",
          "placeholder": "Token mint address",
          "help": "Enter the token you want to buy.",
          "group": "market",
          "display_order": 1
        },
        "spendable_sol_in": {
          "type": "u64",
          "required": true,
          "label": "Amount in SOL",
          "placeholder": "0.01",
          "help": "How much SOL to spend.",
          "group": "trade",
          "display_order": 2
        },
        "slippage_bps": {
          "type": "u16",
          "required": true,
          "label": "Slippage",
          "placeholder": "1.00",
          "help": "Max price movement you accept, in percent.",
          "group": "trade",
          "display_order": 3
        },
        "min_tokens_out": {
          "type": "u64",
          "required": false,
          "read_from": "$args.min_tokens_out",
          "ui_mode": "readonly",
          "label": "Minimum tokens received",
          "help": "Calculated automatically.",
          "group": "trade",
          "display_order": 4
        },
        "track_volume": {
          "type": "bool",
          "required": false,
          "default": false,
          "ui_mode": "hidden",
          "label": "Track Volume"
        }
      },
      "derive": [
        {
          "name": "wallet",
          "resolver": "wallet_pubkey"
        },
        {
          "name": "token_program",
          "resolver": "account_owner",
          "address": "$input.base_mint"
        },
        {
          "name": "global",
          "resolver": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:global"
          ]
        },
        {
          "name": "global_data",
          "resolver": "decode_account",
          "address": "$global",
          "account_type": "Global"
        },
        {
          "name": "bonding_curve",
          "resolver": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:bonding-curve",
            "$input.base_mint"
          ]
        },
        {
          "name": "bonding_curve_v2",
          "resolver": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:bonding-curve-v2",
            "$input.base_mint"
          ]
        },
        {
          "name": "bonding_curve_data",
          "resolver": "decode_account",
          "address": "$bonding_curve",
          "account_type": "BondingCurve"
        },
        {
          "name": "associated_bonding_curve",
          "resolver": "ata",
          "owner": "$bonding_curve",
          "mint": "$input.base_mint",
          "token_program": "$token_program",
          "allow_owner_off_curve": true
        },
        {
          "name": "associated_user",
          "resolver": "ata",
          "owner": "$wallet",
          "mint": "$input.base_mint",
          "token_program": "$token_program"
        },
        {
          "name": "creator_vault",
          "resolver": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:creator-vault",
            "$bonding_curve_data.creator"
          ]
        },
        {
          "name": "event_authority",
          "resolver": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:__event_authority"
          ]
        },
        {
          "name": "global_volume_accumulator",
          "resolver": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:global_volume_accumulator"
          ]
        },
        {
          "name": "user_volume_accumulator",
          "resolver": "pda",
          "program_id": "$protocol.programId",
          "seeds": [
            "utf8:user_volume_accumulator",
            "$wallet"
          ]
        },
        {
          "name": "fee_config",
          "resolver": "pda",
          "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
          "seeds": [
            "utf8:fee_config",
            "$protocol.programId"
          ]
        }
      ],
      "compute": [
        {
          "name": "creator_is_default",
          "compute": "compare.equals",
          "left": "$bonding_curve_data.creator",
          "right": "11111111111111111111111111111111"
        },
        {
          "name": "creator_fee_bps_effective",
          "compute": "logic.if",
          "condition": "$creator_is_default",
          "then": "0",
          "else": "$global_data.creator_fee_basis_points"
        },
        {
          "name": "total_fee_bps",
          "compute": "math.add",
          "values": [
            "$global_data.fee_basis_points",
            "$creator_fee_bps_effective"
          ]
        },
        {
          "name": "net_sol_numerator",
          "compute": "math.mul",
          "values": [
            "$input.spendable_sol_in",
            "10000"
          ]
        },
        {
          "name": "net_sol_denominator",
          "compute": "math.add",
          "values": [
            "10000",
            "$total_fee_bps"
          ]
        },
        {
          "name": "net_sol_raw",
          "compute": "math.floor_div",
          "dividend": "$net_sol_numerator",
          "divisor": "$net_sol_denominator"
        },
        {
          "name": "net_sol_minus_one_candidate",
          "compute": "math.sub",
          "values": [
            "$net_sol_raw",
            "1"
          ]
        },
        {
          "name": "net_sol_gt_one",
          "compute": "compare.gt",
          "left": "$net_sol_raw",
          "right": "1"
        },
        {
          "name": "net_sol_minus_one",
          "compute": "logic.if",
          "condition": "$net_sol_gt_one",
          "then": "$net_sol_minus_one_candidate",
          "else": "0"
        },
        {
          "name": "estimated_out_numerator",
          "compute": "math.mul",
          "values": [
            "$net_sol_minus_one",
            "$bonding_curve_data.virtual_token_reserves"
          ]
        },
        {
          "name": "estimated_out_denominator",
          "compute": "math.add",
          "values": [
            "$bonding_curve_data.virtual_sol_reserves",
            "$net_sol_minus_one"
          ]
        },
        {
          "name": "estimated_out_auto",
          "compute": "math.floor_div",
          "dividend": "$estimated_out_numerator",
          "divisor": "$estimated_out_denominator"
        },
        {
          "name": "slippage_keep_bps",
          "compute": "math.sub",
          "values": [
            "10000",
            "$input.slippage_bps"
          ]
        },
        {
          "name": "min_tokens_out_auto_numerator",
          "compute": "math.mul",
          "values": [
            "$estimated_out_auto",
            "$slippage_keep_bps"
          ]
        },
        {
          "name": "min_tokens_out_auto",
          "compute": "math.floor_div",
          "dividend": "$min_tokens_out_auto_numerator",
          "divisor": "10000"
        }
      ],
      "args": {
        "spendable_sol_in": "$input.spendable_sol_in",
        "min_tokens_out": "$min_tokens_out_auto",
        "track_volume": "$input.track_volume"
      },
      "pre": [
        {
          "kind": "spl_ata_create_idempotent",
          "payer": "$wallet",
          "ata": "$associated_user",
          "owner": "$wallet",
          "mint": "$input.base_mint",
          "token_program": "$token_program"
        }
      ],
      "accounts": {
        "global": "$global",
        "fee_recipient": "$global_data.fee_recipient",
        "mint": "$input.base_mint",
        "bonding_curve": "$bonding_curve",
        "bonding_curve_v2": "$bonding_curve_v2",
        "associated_bonding_curve": "$associated_bonding_curve",
        "associated_user": "$associated_user",
        "user": "$wallet",
        "system_program": "11111111111111111111111111111111",
        "token_program": "$token_program",
        "creator_vault": "$creator_vault",
        "event_authority": "$event_authority",
        "program": "$protocol.programId",
        "global_volume_accumulator": "$global_volume_accumulator",
        "user_volume_accumulator": "$user_volume_accumulator",
        "fee_config": "$fee_config",
        "fee_program": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ"
      },
      "label": "Buy Exact Sol In"
    }
  }
}
