{
  "$schema": "/idl/meta_idl.schema.v0.3.json",
  "schema": "meta-idl.v0.3",
  "version": "0.3.0",
  "protocolId": "orca-whirlpool-mainnet",
  "sources": {
    "orca_whirlpool_directory": {
      "kind": "http_json",
      "url": "/idl/orca_whirlpool.directory.db.json",
      "items_path": "pools",
      "ttl_ms": 15000
    }
  },
  "macros": {
    "orca.swap_exact_in.v1": {
      "params": {
        "token_in_mint": { "type": "pubkey" },
        "token_out_mint": { "type": "pubkey" },
        "amount_in": { "type": "u64" },
        "slippage_bps": { "type": "u16" }
      },
      "expand": {
        "instruction": "swap_v2",
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "selected_pool",
            "resolver": "lookup",
            "source": "orca_whirlpool_directory",
            "where": {
              "tokenInMint": "$param.token_in_mint",
              "tokenOutMint": "$param.token_out_mint"
            },
            "mode": "first"
          },
          {
            "name": "whirlpool_data",
            "resolver": "decode_account",
            "address": "$selected_pool.whirlpool",
            "account_type": "Whirlpool"
          },
          {
            "name": "token_owner_account_a",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_a"
          },
          {
            "name": "token_owner_account_b",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_b"
          },
          {
            "name": "oracle",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": ["utf8:oracle", "$selected_pool.whirlpool"]
          }
        ],
        "compute": [
          {
            "name": "ticks_per_array",
            "compute": "math.mul",
            "values": ["$whirlpool_data.tick_spacing", 88]
          },
          {
            "name": "direction_step",
            "compute": "math.mul",
            "values": ["$ticks_per_array", "$selected_pool.tickArrayDirection"]
          },
          {
            "name": "current_array_index",
            "compute": "math.floor_div",
            "dividend": "$whirlpool_data.tick_current_index",
            "divisor": "$ticks_per_array"
          },
          {
            "name": "current_start_index",
            "compute": "math.mul",
            "values": ["$current_array_index", "$ticks_per_array"]
          },
          {
            "name": "tick_array_starts",
            "compute": "list.range_map",
            "base": "$current_start_index",
            "step": "$direction_step",
            "count": 3
          },
          {
            "name": "tick_arrays",
            "compute": "pda(seed_spec)",
            "program_id": "$protocol.programId",
            "map_over": "$tick_array_starts",
            "seeds": [
              { "kind": "utf8", "value": "tick_array" },
              { "kind": "pubkey", "value": "$selected_pool.whirlpool" },
              { "kind": "item_utf8" }
            ]
          }
        ],
        "args": {
          "amount": "$param.amount_in",
          "other_amount_threshold": "1",
          "sqrt_price_limit": "0",
          "amount_specified_is_input": true,
          "a_to_b": "$selected_pool.aToB",
          "remaining_accounts_info": null
        },
        "accounts": {
          "token_program_a": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
          "token_program_b": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
          "memo_program": "MemoSq4gqABAXKb96qnH8TysNcWxMyWCqXgDLGmfcHr",
          "token_authority": "$wallet",
          "whirlpool": "$selected_pool.whirlpool",
          "token_mint_a": "$whirlpool_data.token_mint_a",
          "token_mint_b": "$whirlpool_data.token_mint_b",
          "token_owner_account_a": "$token_owner_account_a",
          "token_vault_a": "$whirlpool_data.token_vault_a",
          "token_owner_account_b": "$token_owner_account_b",
          "token_vault_b": "$whirlpool_data.token_vault_b",
          "tick_array_0": "$tick_arrays.0",
          "tick_array_1": "$tick_arrays.1",
          "tick_array_2": "$tick_arrays.2",
          "oracle": "$oracle"
        },
        "post": [
          {
            "kind": "spl_token_close_account",
            "account": "$token_owner_account_a",
            "destination": "$wallet",
            "owner": "$wallet",
            "when": {
              "all": [
                { "equals": ["$input.unwrap_sol_output", true] },
                { "equals": ["$selected_pool.aToB", false] },
                { "equals": ["$selected_pool.tokenOutMint", "So11111111111111111111111111111111111111112"] }
              ]
            }
          },
          {
            "kind": "spl_token_close_account",
            "account": "$token_owner_account_b",
            "destination": "$wallet",
            "owner": "$wallet",
            "when": {
              "all": [
                { "equals": ["$input.unwrap_sol_output", true] },
                { "equals": ["$selected_pool.aToB", true] },
                { "equals": ["$selected_pool.tokenOutMint", "So11111111111111111111111111111111111111112"] }
              ]
            }
          }
        ]
      }
    }
  },
  "actions": {
    "swap_exact_in": {
      "inputs": {
        "token_in_mint": { "type": "pubkey", "required": true },
        "token_out_mint": { "type": "pubkey", "required": true },
        "amount_in": { "type": "u64", "required": true },
        "slippage_bps": { "type": "u16", "required": false, "default": 50 },
        "unwrap_sol_output": { "type": "bool", "required": false, "default": true }
      },
      "use": [
        {
          "macro": "orca.swap_exact_in.v1",
          "with": {
            "token_in_mint": "$input.token_in_mint",
            "token_out_mint": "$input.token_out_mint",
            "amount_in": "$input.amount_in",
            "slippage_bps": "$input.slippage_bps"
          }
        }
      ]
    }
  }
}
