{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "sourceProtocolIds": [
    "pump-amm-mainnet"
  ],
  "label": "Pump AMM Declarative Runtime",
  "programId": "$protocol.programId",
  "decoderArtifacts": {
    "pump_swap": {
      "kind": "generated_idl_decoder",
      "family": "codama",
      "codamaPath": "/idl/pump_amm.codama.json",
      "artifact": "pump_swap"
    }
  },
  "sources": {
    "pump_swap_crawler": {
      "kind": "rpc_transaction_crawler",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "pump_swap",
      "decodeTargets": [
        "instruction",
        "log_event",
        "account"
      ],
      "filters": {}
    }
  },
  "matchRules": [
    {
      "source": "pump_swap_crawler",
      "match": {
        "decodedType": "account",
        "name": "Pool"
      },
      "pipeline": "pool_snapshot"
    },
    {
      "source": "pump_swap_crawler",
      "match": {
        "decodedType": "event",
        "name": "CreatePoolEvent"
      },
      "pipeline": "pool_create"
    },
    {
      "source": "pump_swap_crawler",
      "match": {
        "decodedType": "event",
        "name": "BuyEvent"
      },
      "pipeline": "trade_buy"
    },
    {
      "source": "pump_swap_crawler",
      "match": {
        "decodedType": "event",
        "name": "SellEvent"
      },
      "pipeline": "trade_sell"
    }
  ],
  "pipelines": {
    "pool_snapshot": {
      "extract": {
        "pool": "$update.pubkey",
        "mint": "$decoded.base_mint",
        "quoteMint": "$decoded.quote_mint",
        "coinCreator": "$decoded.coin_creator",
        "isCashbackCoin": "$decoded.is_cashback_coin",
        "observedAt": "$update.eventTime"
      },
      "emit": {
        "state": {
          "recordKind": "account",
          "recordName": "PoolMetadata",
          "retention": "90d",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "mint": "$ctx.mint",
            "quoteMint": "$ctx.quoteMint",
            "coinCreator": "$ctx.coinCreator",
            "isCashbackCoin": "$ctx.isCashbackCoin",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "pool_create": {
      "extract": {
        "pool": "$decoded.pool",
        "mint": "$decoded.base_mint",
        "quoteMint": "$decoded.quote_mint",
        "baseDecimals": "$decoded.base_mint_decimals",
        "quoteDecimals": "$decoded.quote_mint_decimals",
        "coinCreator": "$decoded.coin_creator",
        "observedAt": "$update.eventTime"
      },
      "emit": {
        "state": {
          "recordKind": "state",
          "recordName": "PoolMetadata",
          "retention": "90d",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "mint": "$ctx.mint",
            "quoteMint": "$ctx.quoteMint",
            "baseDecimals": "$ctx.baseDecimals",
            "quoteDecimals": "$ctx.quoteDecimals",
            "coinCreator": "$ctx.coinCreator",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "trade_buy": {
      "extract": {
        "pool": "$decoded.pool",
        "participant": "$decoded.user",
        "side": "buy",
        "baseAmountAtomic": "$decoded.base_amount_out",
        "quoteAmountAtomic": "$decoded.quote_amount_in",
        "poolBaseReservesAtomic": "$decoded.pool_base_token_reserves",
        "poolQuoteReservesAtomic": "$decoded.pool_quote_token_reserves",
        "coinCreator": "$decoded.coin_creator",
        "signature": "$update.signature",
        "slot": "$update.slot",
        "observedAt": "$update.eventTime"
      },
      "resolve": [
        {
          "name": "poolMetadata",
          "from": "indexed_idl_state",
          "where": {
            "protocol_id": "$protocolId",
            "record_name": "PoolMetadata",
            "resource_id": "$ctx.pool"
          },
          "fields": [
            "mint",
            "quoteMint",
            "baseDecimals",
            "quoteDecimals",
            "coinCreator"
          ],
          "optional": true
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "BuyEvent",
          "retention": "14d",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.participant",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "participant": "$ctx.participant",
            "side": "$ctx.side",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "mint": "$poolMetadata.mint",
            "quoteMint": "$poolMetadata.quoteMint",
            "baseDecimals": "$poolMetadata.baseDecimals",
            "quoteDecimals": "$poolMetadata.quoteDecimals",
            "poolBaseReservesAtomic": "$ctx.poolBaseReservesAtomic",
            "poolQuoteReservesAtomic": "$ctx.poolQuoteReservesAtomic",
            "coinCreator": "$poolMetadata.coinCreator",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "Pool",
          "retention": "90d",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "side": "$ctx.side",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "mint": "$poolMetadata.mint",
            "quoteMint": "$poolMetadata.quoteMint",
            "baseDecimals": "$poolMetadata.baseDecimals",
            "quoteDecimals": "$poolMetadata.quoteDecimals",
            "poolBaseReservesAtomic": "$ctx.poolBaseReservesAtomic",
            "poolQuoteReservesAtomic": "$ctx.poolQuoteReservesAtomic",
            "coinCreator": "$poolMetadata.coinCreator",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "trade_sell": {
      "extract": {
        "pool": "$decoded.pool",
        "participant": "$decoded.user",
        "side": "sell",
        "baseAmountAtomic": "$decoded.base_amount_in",
        "quoteAmountAtomic": "$decoded.quote_amount_out",
        "poolBaseReservesAtomic": "$decoded.pool_base_token_reserves",
        "poolQuoteReservesAtomic": "$decoded.pool_quote_token_reserves",
        "coinCreator": "$decoded.coin_creator",
        "signature": "$update.signature",
        "slot": "$update.slot",
        "observedAt": "$update.eventTime"
      },
      "resolve": [
        {
          "name": "poolMetadata",
          "from": "indexed_idl_state",
          "where": {
            "protocol_id": "$protocolId",
            "record_name": "PoolMetadata",
            "resource_id": "$ctx.pool"
          },
          "fields": [
            "mint",
            "quoteMint",
            "baseDecimals",
            "quoteDecimals",
            "coinCreator"
          ],
          "optional": true
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "SellEvent",
          "retention": "14d",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.participant",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "participant": "$ctx.participant",
            "side": "$ctx.side",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "mint": "$poolMetadata.mint",
            "quoteMint": "$poolMetadata.quoteMint",
            "baseDecimals": "$poolMetadata.baseDecimals",
            "quoteDecimals": "$poolMetadata.quoteDecimals",
            "poolBaseReservesAtomic": "$ctx.poolBaseReservesAtomic",
            "poolQuoteReservesAtomic": "$ctx.poolQuoteReservesAtomic",
            "coinCreator": "$poolMetadata.coinCreator",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "Pool",
          "retention": "90d",
          "subjectId": "$ctx.pool",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "pool": "$ctx.pool",
            "side": "$ctx.side",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "mint": "$poolMetadata.mint",
            "quoteMint": "$poolMetadata.quoteMint",
            "baseDecimals": "$poolMetadata.baseDecimals",
            "quoteDecimals": "$poolMetadata.quoteDecimals",
            "poolBaseReservesAtomic": "$ctx.poolBaseReservesAtomic",
            "poolQuoteReservesAtomic": "$ctx.poolQuoteReservesAtomic",
            "coinCreator": "$poolMetadata.coinCreator",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    }
  }
}
