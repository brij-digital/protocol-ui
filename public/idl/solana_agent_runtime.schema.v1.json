{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/idl/solana_agent_runtime.schema.v1.json",
  "title": "Solana Agent Runtime Spec V1",
  "type": "object",
  "required": [
    "schema",
    "protocol",
    "index_views",
    "computes",
    "contract_writes"
  ],
  "properties": {
    "schema": {
      "const": "solana-agent-runtime.v1"
    },
    "protocol": {
      "$ref": "#/$defs/protocolSpec"
    },
    "index_views": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/indexViewSpec"
      }
    },
    "computes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/computeSpec"
      }
    },
    "contract_writes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/executionSpec"
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    },
    "protocolSpec": {
      "type": "object",
      "required": [
        "protocolId",
        "programId",
        "codamaPath"
      ],
      "properties": {
        "protocolId": {
          "type": "string"
        },
        "programId": {
          "type": "string"
        },
        "codamaPath": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "inputSpec": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "additionalProperties": false
    },
    "outputFieldSpec": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "outputObjectSchemaSpec": {
      "type": "object",
      "required": [
        "fields"
      ],
      "properties": {
        "entity_type": {
          "type": "string"
        },
        "identity_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/outputFieldSpec"
          }
        }
      },
      "additionalProperties": false
    },
    "readOutputSpec": {
      "type": "object",
      "required": [
        "type",
        "source"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "array",
            "object",
            "scalar",
            "list"
          ]
        },
        "source": {
          "type": "string"
        },
        "object_schema": {
          "$ref": "#/$defs/outputObjectSchemaSpec"
        },
        "item_schema": {
          "$ref": "#/$defs/outputObjectSchemaSpec"
        },
        "scalar_type": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "indexViewSpec": {
      "type": "object",
      "properties": {
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputSpec"
          }
        },
        "read_output": {
          "$ref": "#/$defs/readOutputSpec"
        },
        "read": {
          "$ref": "#/$defs/readSpec"
        }
      },
      "required": [
        "read"
      ],
      "additionalProperties": false
    },
    "computeSpec": {
      "type": "object",
      "properties": {
        "instruction": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputSpec"
          }
        },
        "resolve": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resolveStepSpec"
          }
        },
        "compute": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/computeStepSpec"
          }
        },
        "read_output": {
          "$ref": "#/$defs/readOutputSpec"
        }
      },
      "additionalProperties": false
    },
    "executionSpec": {
      "type": "object",
      "properties": {
        "instruction": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputSpec"
          }
        },
        "resolve": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resolveStepSpec"
          }
        },
        "compute": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/computeStepSpec"
          }
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        "accounts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        "remaining_accounts": {
          "$ref": "#/$defs/jsonValue"
        },
        "pre": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/preInstructionSpec"
          }
        },
        "post": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/postInstructionSpec"
          }
        },
        "read_output": {
          "$ref": "#/$defs/readOutputSpec"
        }
      },
      "additionalProperties": false
    },
    "readCommonSpec": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "entity_type": { "type": "string" },
        "freshness": {
          "type": "object",
          "properties": {
            "class": { "type": "string" },
            "target_ms": { "type": "number" },
            "max_staleness_ms": { "type": "number" }
          },
          "required": ["class", "target_ms", "max_staleness_ms"],
          "additionalProperties": false
        },
        "canonical": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        },
        "projection": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      }
    },
    "readSpec": {
      "oneOf": [
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "index" } } }], "unevaluatedProperties": false },
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "search" } } }], "unevaluatedProperties": false },
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "get" } } }], "unevaluatedProperties": false },
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "resolve" } } }], "unevaluatedProperties": false },
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "feed" } } }], "unevaluatedProperties": false },
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "series" } } }], "unevaluatedProperties": false },
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "ranking" } } }], "unevaluatedProperties": false },
        { "allOf": [{ "$ref": "#/$defs/readCommonSpec" }, { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "context" } } }], "unevaluatedProperties": false }
      ]
    },
    "metaConditionSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "equals"
          ],
          "properties": {
            "equals": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "$ref": "#/$defs/jsonValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "all"
          ],
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/metaConditionSpec"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "any"
          ],
          "properties": {
            "any": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/metaConditionSpec"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "not"
          ],
          "properties": {
            "not": {
              "$ref": "#/$defs/metaConditionSpec"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "resolveSeedSpec": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/jsonValue"
        }
      ]
    },
    "resolveStepSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "name",
            "kind"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "wallet_pubkey"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "address",
            "account_type"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "decode_account"
            },
            "address": {
              "$ref": "#/$defs/jsonValue"
            },
            "account_type": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "address"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "account_owner"
            },
            "address": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "address"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "token_account_balance"
            },
            "address": {
              "$ref": "#/$defs/jsonValue"
            },
            "allow_missing": {
              "$ref": "#/$defs/jsonValue"
            },
            "default": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "mint"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "token_supply"
            },
            "mint": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "owner",
            "mint"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "ata"
            },
            "owner": {
              "$ref": "#/$defs/jsonValue"
            },
            "mint": {
              "$ref": "#/$defs/jsonValue"
            },
            "token_program": {
              "$ref": "#/$defs/jsonValue"
            },
            "allow_owner_off_curve": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "program_id"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "pda"
            },
            "program_id": {
              "$ref": "#/$defs/jsonValue"
            },
            "seeds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/resolveSeedSpec"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "unix_timestamp"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "listWhereClauseSpec": {
      "type": "object",
      "required": [
        "path",
        "value"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "op": {
          "type": "string",
          "enum": [
            "=",
            "==",
            "!=",
            ">",
            ">=",
            "<",
            "<="
          ]
        },
        "value": {
          "$ref": "#/$defs/jsonValue"
        }
      },
      "additionalProperties": false
    },
    "pdaSeedSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "utf8"
            },
            "value": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "pubkey"
            },
            "value": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "i32_le"
            },
            "value": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "item_i32_le"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "item_utf8"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "computeStepSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "values"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "math.add"
            },
            "values": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/jsonValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "values"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "math.sum"
            },
            "values": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/jsonValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "values"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "math.mul"
            },
            "values": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/jsonValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "values"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "math.sub"
            },
            "values": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/jsonValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "dividend",
            "divisor"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "math.floor_div"
            },
            "dividend": {
              "$ref": "#/$defs/jsonValue"
            },
            "divisor": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "base",
            "step",
            "count"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "list.range_map"
            },
            "base": {
              "$ref": "#/$defs/jsonValue"
            },
            "step": {
              "$ref": "#/$defs/jsonValue"
            },
            "count": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "values",
            "index"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "list.get"
            },
            "values": {
              "$ref": "#/$defs/jsonValue"
            },
            "index": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "items"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "list.filter"
            },
            "items": {
              "$ref": "#/$defs/jsonValue"
            },
            "where": {
              "oneOf": [
                {
                  "$ref": "#/$defs/listWhereClauseSpec"
                },
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/listWhereClauseSpec"
                  }
                }
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "items"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "list.first"
            },
            "items": {
              "$ref": "#/$defs/jsonValue"
            },
            "allow_empty": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "items",
            "path"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "list.min_by"
            },
            "items": {
              "$ref": "#/$defs/jsonValue"
            },
            "path": {
              "type": "string"
            },
            "allow_empty": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "items",
            "path"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "list.max_by"
            },
            "items": {
              "$ref": "#/$defs/jsonValue"
            },
            "path": {
              "type": "string"
            },
            "allow_empty": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "values"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "coalesce"
            },
            "values": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/jsonValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "seeds"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "pda(seed_spec)"
            },
            "program_id": {
              "$ref": "#/$defs/jsonValue"
            },
            "seeds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/pdaSeedSpec"
              }
            },
            "map_over": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "left",
            "right"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "compare.equals"
            },
            "left": {
              "$ref": "#/$defs/jsonValue"
            },
            "right": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "left",
            "right"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "compare.not_equals"
            },
            "left": {
              "$ref": "#/$defs/jsonValue"
            },
            "right": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "left",
            "right"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "const": "compare.gt"
            },
            "left": {
              "$ref": "#/$defs/jsonValue"
            },
            "right": {
              "$ref": "#/$defs/jsonValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "name",
            "kind",
            "left",
            "right"
