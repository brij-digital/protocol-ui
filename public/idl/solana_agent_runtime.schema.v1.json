{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/idl/solana_agent_runtime.schema.v1.json",
  "title": "Solana Agent Runtime Spec V1",
  "type": "object",
  "required": ["schema", "protocol", "index_views", "computes", "contract_writes"],
  "properties": {
    "schema": {
      "const": "solana-agent-runtime.v1"
    },
    "protocol": {
      "$ref": "#/$defs/protocolSpec"
    },
    "index_views": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/indexViewSpec"
      }
    },
    "computes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/computeSpec"
      }
    },
    "contract_writes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/executionSpec"
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    },
    "protocolSpec": {
      "type": "object",
      "required": ["protocolId", "programId", "codamaPath"],
      "properties": {
        "protocolId": { "type": "string" },
        "programId": { "type": "string" },
        "codamaPath": { "type": "string" }
      },
      "additionalProperties": true
    },
    "inputSpec": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "default": { "$ref": "#/$defs/jsonValue" },
        "validate": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "outputFieldSpec": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "outputObjectSchemaSpec": {
      "type": "object",
      "required": ["fields"],
      "properties": {
        "entity_type": { "type": "string" },
        "identity_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/outputFieldSpec"
          }
        }
      },
      "additionalProperties": false
    },
    "readOutputSpec": {
      "type": "object",
      "required": ["type", "source"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["array", "object", "scalar", "list"]
        },
        "source": { "type": "string" },
        "object_schema": {
          "$ref": "#/$defs/outputObjectSchemaSpec"
        },
        "item_schema": {
          "$ref": "#/$defs/outputObjectSchemaSpec"
        },
        "scalar_type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "indexViewSpec": {
      "type": "object",
      "properties": {
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputSpec"
          }
        },
        "validate": {
          "type": "object",
          "additionalProperties": true
        },
        "read_output": {
          "$ref": "#/$defs/readOutputSpec"
        },
        "read": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["index", "get", "resolve", "feed", "series", "ranking", "context"]
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["read"],
      "additionalProperties": true
    },
    "computeSpec": {
      "type": "object",
      "properties": {
        "instruction": { "type": "string" },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputSpec"
          }
        },
        "validate": {
          "type": "object",
          "additionalProperties": true
        },
        "derive": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        "compute": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        "read_output": {
          "$ref": "#/$defs/readOutputSpec"
        }
      },
      "additionalProperties": true
    },
    "executionSpec": {
      "type": "object",
      "properties": {
        "instruction": { "type": "string" },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputSpec"
          }
        },
        "validate": {
          "type": "object",
          "additionalProperties": true
        },
        "derive": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        "compute": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        "args": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        },
        "accounts": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        },
        "remaining_accounts": { "$ref": "#/$defs/jsonValue" },
        "pre": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        "post": {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        "read_output": {
          "$ref": "#/$defs/readOutputSpec"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
