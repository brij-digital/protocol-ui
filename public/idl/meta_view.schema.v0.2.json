{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentform.app/schemas/meta_view.v0.2.json",
  "title": "Meta View v0.2",
  "description": "Standalone view specification for account reads and searchable entity views. This schema intentionally describes business-facing view intent, not indexing infrastructure internals.",
  "oneOf": [
    { "$ref": "#/$defs/accountViewSpec" },
    { "$ref": "#/$defs/searchViewSpec" }
  ],
  "$defs": {
    "filterValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" }
      ]
    },
    "conditionSpec": {
      "type": "object",
      "required": ["field", "op", "value"],
      "properties": {
        "field": { "type": "string" },
        "op": {
          "type": "string",
          "enum": ["=", "!=", ">", ">=", "<", "<=", "in"]
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "filterGroupAll": {
      "type": "object",
      "required": ["all"],
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/conditionSpec" }
        }
      },
      "additionalProperties": false
    },
    "filterGroupAny": {
      "type": "object",
      "required": ["any"],
      "properties": {
        "any": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/filterGroupAll" },
              { "$ref": "#/$defs/conditionSpec" }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "sortSpec": {
      "type": "object",
      "required": ["field", "dir"],
      "properties": {
        "field": { "type": "string" },
        "dir": { "type": "string", "enum": ["asc", "desc"] },
        "mode": {
          "type": "string",
          "enum": ["indexed", "live", "indexed_then_live_refine"]
        },
        "candidate_limit": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "bootstrapFilterSpec": {
      "type": "object",
      "properties": {
        "memcmp": {
          "type": "object",
          "required": ["offset"],
          "properties": {
            "offset": { "type": "integer", "minimum": 0 },
            "bytes": { "type": "string" },
            "bytesFrom": { "type": "string" }
          },
          "additionalProperties": false,
          "anyOf": [
            { "required": ["bytes"] },
            { "required": ["bytesFrom"] }
          ]
        }
      },
      "additionalProperties": false,
      "required": ["memcmp"]
    },
    "bootstrapSpec": {
      "type": "object",
      "required": ["kind", "source", "program_id", "account_type"],
      "properties": {
        "kind": { "const": "scan_accounts" },
        "source": { "const": "rpc.getProgramAccounts" },
        "program_id": { "type": "string" },
        "account_type": { "type": "string" },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/bootstrapFilterSpec" }
        }
      },
      "additionalProperties": false
    },
    "refreshSpec": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["stream", "poll", "on_demand", "manual"]
        },
        "source": { "type": "string" },
        "interval_ms": { "type": "integer", "minimum": 0 },
        "cursor_path": { "type": "string" },
        "account_keys_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "hydrateSpec": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "accounts"]
        },
        "candidate_limit": {
          "type": "integer",
          "minimum": 1
        },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "decodeSpec": {
      "type": "object",
      "required": ["account_type"],
      "properties": {
        "account_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "querySpec": {
      "type": "object",
      "required": ["select"],
      "properties": {
        "filters": {
          "oneOf": [
            { "$ref": "#/$defs/filterGroupAll" },
            { "$ref": "#/$defs/filterGroupAny" }
          ]
        },
        "hydrate": { "$ref": "#/$defs/hydrateSpec" },
        "decode": { "$ref": "#/$defs/decodeSpec" },
        "sort": {
          "type": "array",
          "items": { "$ref": "#/$defs/sortSpec" }
        },
        "limit": {
          "type": "integer",
          "minimum": 1
        },
        "select": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "additionalProperties": false
    },
    "accountTargetSpec": {
      "type": "object",
      "required": ["address", "account_type"],
      "properties": {
        "address": {},
        "account_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "accountViewSpec": {
      "type": "object",
      "required": ["kind", "source", "target", "select"],
      "properties": {
        "kind": { "const": "account" },
        "source": {
          "type": "string",
          "enum": ["rpc", "indexed", "hybrid"]
        },
        "entity_type": { "type": "string" },
        "target": { "$ref": "#/$defs/accountTargetSpec" },
        "refresh": { "$ref": "#/$defs/refreshSpec" },
        "select": {
          "type": "object",
          "additionalProperties": {}
        },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "searchViewSpec": {
      "type": "object",
      "required": ["kind", "source", "entity_type", "bootstrap", "query"],
      "properties": {
        "kind": { "const": "search" },
        "source": {
          "type": "string",
          "enum": ["rpc", "indexed", "hybrid"]
        },
        "entity_type": { "type": "string" },
        "bootstrap": { "$ref": "#/$defs/bootstrapSpec" },
        "refresh": { "$ref": "#/$defs/refreshSpec" },
        "query": { "$ref": "#/$defs/querySpec" },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
