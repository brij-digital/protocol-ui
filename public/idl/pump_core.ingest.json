{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "sourceProtocolIds": [
    "pump-core-mainnet"
  ],
  "label": "Pump Core Declarative Runtime",
  "programId": "$protocol.programId",
  "decoderArtifacts": {
    "pumpfun": {
      "kind": "generated_idl_decoder",
      "family": "codama",
      "codamaPath": "/idl/pump_core.codama.json",
      "artifact": "pumpfun"
    }
  },
  "sources": {
    "pump_core_crawler": {
      "kind": "rpc_transaction_crawler",
      "programId": "$protocol.programId",
      "commitment": "confirmed",
      "decoderRef": "pumpfun",
      "decodeTargets": [
        "instruction",
        "log_event",
        "account"
      ],
      "filters": {}
    }
  },
  "matchRules": [
    {
      "source": "pump_core_crawler",
      "match": {
        "decodedType": "account",
        "name": "BondingCurve"
      },
      "pipeline": "curve_account_snapshot"
    },
    {
      "source": "pump_core_crawler",
      "match": {
        "decodedType": "event",
        "name": "CreateEvent"
      },
      "pipeline": "curve_create"
    },
    {
      "source": "pump_core_crawler",
      "match": {
        "decodedType": "event",
        "name": "TradeEvent"
      },
      "pipeline": "curve_trade"
    }
  ],
  "pipelines": {
    "curve_account_snapshot": {
      "extract": {
        "bondingCurve": "$update.pubkey",
        "creator": "$decoded.creator",
        "complete": "$decoded.complete",
        "virtualTokenReservesAtomic": "$decoded.virtual_token_reserves",
        "virtualSolReservesAtomic": "$decoded.virtual_sol_reserves",
        "realTokenReservesAtomic": "$decoded.real_token_reserves",
        "realSolReservesAtomic": "$decoded.real_sol_reserves",
        "tokenTotalSupplyAtomic": "$decoded.token_total_supply",
        "isMayhemMode": "$decoded.is_mayhem_mode",
        "isCashbackCoin": "$decoded.is_cashback_coin",
        "observedAt": "$update.eventTime"
      },
      "emit": {
        "state": {
          "recordKind": "account",
          "recordName": "BondingCurveAccount",
          "retention": "90d",
          "subjectId": "$ctx.bondingCurve",
          "resourceId": "$ctx.bondingCurve",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "bondingCurve": "$ctx.bondingCurve",
            "creator": "$ctx.creator",
            "complete": "$ctx.complete",
            "virtualTokenReservesAtomic": "$ctx.virtualTokenReservesAtomic",
            "virtualSolReservesAtomic": "$ctx.virtualSolReservesAtomic",
            "realTokenReservesAtomic": "$ctx.realTokenReservesAtomic",
            "realSolReservesAtomic": "$ctx.realSolReservesAtomic",
            "tokenTotalSupplyAtomic": "$ctx.tokenTotalSupplyAtomic",
            "isMayhemMode": "$ctx.isMayhemMode",
            "isCashbackCoin": "$ctx.isCashbackCoin",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "curve_create": {
      "extract": {
        "mint": "$decoded.mint",
        "pool": "$decoded.mint",
        "marketType": "core",
        "quoteMint": "So11111111111111111111111111111111111111112",
        "quoteDecimals": 9,
        "creator": "$decoded.creator",
        "complete": false,
        "observedAt": "$update.eventTime",
        "virtualTokenReservesAtomic": "$decoded.virtual_token_reserves",
        "virtualSolReservesAtomic": "$decoded.virtual_sol_reserves",
        "realTokenReservesAtomic": "$decoded.real_token_reserves",
        "tokenTotalSupplyAtomic": "$decoded.token_total_supply"
      },
      "compute": [
        {
          "ref": "math.amount_ui",
          "inputs": {
            "amount": "$ctx.virtualSolReservesAtomic",
            "decimals": "$ctx.quoteDecimals"
          },
          "output": "quoteReserveUi"
        }
      ],
      "emit": {
        "state": {
          "recordKind": "state",
          "recordName": "BondingCurve",
          "retention": "90d",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "quoteMint": "$ctx.quoteMint",
            "quoteDecimals": "$ctx.quoteDecimals",
            "quoteReserveUi": "$quoteReserveUi",
            "creator": "$ctx.creator",
            "complete": "$ctx.complete",
            "virtualTokenReservesAtomic": "$ctx.virtualTokenReservesAtomic",
            "virtualSolReservesAtomic": "$ctx.virtualSolReservesAtomic",
            "realTokenReservesAtomic": "$ctx.realTokenReservesAtomic",
            "tokenTotalSupplyAtomic": "$ctx.tokenTotalSupplyAtomic",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    },
    "curve_trade": {
      "extract": {
        "mint": "$decoded.mint",
        "pool": "$decoded.mint",
        "marketType": "core",
        "quoteMint": "So11111111111111111111111111111111111111112",
        "quoteDecimals": 9,
        "creator": "$decoded.creator",
        "complete": false,
        "observedAt": "$update.eventTime",
        "participant": "$decoded.user",
        "isBuy": "$decoded.is_buy",
        "baseAmountAtomic": "$decoded.token_amount",
        "quoteAmountAtomic": "$decoded.sol_amount",
        "virtualTokenReservesAtomic": "$decoded.virtual_token_reserves",
        "virtualSolReservesAtomic": "$decoded.virtual_sol_reserves",
        "realTokenReservesAtomic": "$decoded.real_token_reserves",
        "realSolReservesAtomic": "$decoded.real_sol_reserves",
        "totalUnclaimedTokensAtomic": "$decoded.total_unclaimed_tokens",
        "totalClaimedTokensAtomic": "$decoded.total_claimed_tokens",
        "signature": "$update.signature",
        "slot": "$update.slot"
      },
      "compute": [
        {
          "ref": "logic.if_then_else",
          "inputs": {
            "condition": "$ctx.isBuy",
            "then_value": "buy",
            "else_value": "sell"
          },
          "output": "side"
        },
        {
          "ref": "math.amount_ui",
          "inputs": {
            "amount": "$ctx.quoteAmountAtomic",
            "decimals": "$ctx.quoteDecimals"
          },
          "output": "quoteAmountUi"
        }
      ],
      "emit": {
        "record": {
          "recordKind": "event",
          "recordName": "TradeEvent",
          "retention": "14d",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "participantId": "$ctx.participant",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "participant": "$ctx.participant",
            "side": "$side",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "quoteAmountUi": "$quoteAmountUi",
            "virtualTokenReservesAtomic": "$ctx.virtualTokenReservesAtomic",
            "virtualSolReservesAtomic": "$ctx.virtualSolReservesAtomic",
            "realTokenReservesAtomic": "$ctx.realTokenReservesAtomic",
            "realSolReservesAtomic": "$ctx.realSolReservesAtomic",
            "totalUnclaimedTokensAtomic": "$ctx.totalUnclaimedTokensAtomic",
            "totalClaimedTokensAtomic": "$ctx.totalClaimedTokensAtomic",
            "signature": "$ctx.signature",
            "slot": "$ctx.slot",
            "observedAt": "$ctx.observedAt"
          }
        },
        "state": {
          "recordKind": "state",
          "recordName": "BondingCurve",
          "retention": "90d",
          "subjectId": "$ctx.mint",
          "resourceId": "$ctx.pool",
          "signature": "$ctx.signature",
          "slot": "$ctx.slot",
          "eventTime": "$ctx.observedAt",
          "payload": {
            "mint": "$ctx.mint",
            "pool": "$ctx.pool",
            "marketType": "$ctx.marketType",
            "quoteMint": "$ctx.quoteMint",
            "quoteDecimals": "$ctx.quoteDecimals",
            "creator": "$ctx.creator",
            "complete": "$ctx.complete",
            "baseAmountAtomic": "$ctx.baseAmountAtomic",
            "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
            "quoteAmountUi": "$quoteAmountUi",
            "virtualTokenReservesAtomic": "$ctx.virtualTokenReservesAtomic",
            "virtualSolReservesAtomic": "$ctx.virtualSolReservesAtomic",
            "realTokenReservesAtomic": "$ctx.realTokenReservesAtomic",
            "realSolReservesAtomic": "$ctx.realSolReservesAtomic",
            "totalUnclaimedTokensAtomic": "$ctx.totalUnclaimedTokensAtomic",
            "totalClaimedTokensAtomic": "$ctx.totalClaimedTokensAtomic",
            "observedAt": "$ctx.observedAt"
          }
        }
      }
    }
  }
}
