{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "protocolId": "pump-amm-mainnet",
  "active_window_days": 30,
  "label": "Pump AMM Indexed Reads",
  "programId": "$protocol.programId",
  "operations": {
    "list_tokens": {
      "index_view": {
        "kind": "search",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "pump-amm-mainnet",
          "record_kind": "account",
          "record_name": "PoolMetadata",
          "notes": "Canonical Pump AMM metadata directory ordered by latest indexed metadata."
        },
        "projection": {
          "projection_kind": "search",
          "filters": {
            "field": "quoteMint",
            "op": "=",
            "value": "$input.quote_mint"
          },
          "sort_by": [
            {
              "field": "updatedAt",
              "dir": "desc"
            }
          ]
        },
        "inputs": {
          "quote_mint": {
            "type": "pubkey",
            "required": false,
            "default": "So11111111111111111111111111111111111111112"
          },
          "min_last_seen_slot": {
            "type": "u64",
            "required": false,
            "default": "0"
          }
        },
        "read_output": {
          "source": "$items",
          "type": "array",
          "item_schema": {
            "entity_type": "pump_pool",
            "identity_fields": [
              "pool"
            ],
            "fields": {
              "mint": {
                "type": "pubkey",
                "required": false
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "quoteMint": {
                "type": "pubkey",
                "required": false
              },
              "baseDecimals": {
                "type": "u8",
                "required": false
              },
              "quoteDecimals": {
                "type": "u8",
                "required": false
              },
              "coinCreator": {
                "type": "pubkey",
                "required": false
              },
              "isCashbackCoin": {
                "type": "bool",
                "required": false
              },
              "observedAt": {
                "type": "timestamp",
                "required": false
              }
            }
          }
        }
      }
    },
    "view_pool": {
      "index_view": {
        "kind": "search",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "pump-amm-mainnet",
          "record_kind": "account",
          "record_name": "PoolMetadata",
          "notes": "Canonical Pump AMM market search by base and quote mint."
        },
        "projection": {
          "projection_kind": "search",
          "filters": {
            "all": [
              {
                "field": "mint",
                "op": "=",
                "value": "$input.base_mint"
              },
              {
                "field": "quoteMint",
                "op": "=",
                "value": "$input.quote_mint"
              }
            ]
          },
          "sort_by": [
            {
              "field": "updatedAt",
              "dir": "desc"
            }
          ]
        },
        "inputs": {
          "base_mint": {
            "type": "pubkey",
            "required": true
          },
          "quote_mint": {
            "type": "pubkey",
            "required": false,
            "default": "So11111111111111111111111111111111111111112"
          }
        },
        "read_output": {
          "source": "$items",
          "type": "array",
          "item_schema": {
            "entity_type": "pump_pool",
            "identity_fields": [
              "pool"
            ],
            "fields": {
              "mint": {
                "type": "pubkey",
                "required": false
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "quoteMint": {
                "type": "pubkey",
                "required": false
              },
              "baseDecimals": {
                "type": "u8",
                "required": false
              },
              "quoteDecimals": {
                "type": "u8",
                "required": false
              },
              "coinCreator": {
                "type": "pubkey",
                "required": false
              },
              "isCashbackCoin": {
                "type": "bool",
                "required": false
              },
              "observedAt": {
                "type": "timestamp",
                "required": false
              }
            }
          }
        }
      }
    },
    "resolve_pool": {
      "index_view": {
        "kind": "account",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "pump-amm-mainnet",
          "record_kind": "account",
          "record_name": "PoolMetadata",
          "resource_field": "resource_id",
          "notes": "Resolve a pool to its current raw metadata snapshot.",
          "resource_input": "pool"
        },
        "projection": {
          "projection_kind": "snapshot",
          "group_by": [
            "subject_id"
          ]
        },
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          }
        },
        "read_output": {
          "type": "object",
          "source": "$items.0",
          "object_schema": {
            "entity_type": "pump_pool",
            "identity_fields": [
              "pool"
            ],
            "fields": {
              "mint": {
                "type": "pubkey",
                "required": false
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "quoteMint": {
                "type": "pubkey",
                "required": false
              },
              "baseDecimals": {
                "type": "u8",
                "required": false
              },
              "quoteDecimals": {
                "type": "u8",
                "required": false
              },
              "coinCreator": {
                "type": "pubkey",
                "required": false
              },
              "isCashbackCoin": {
                "type": "bool",
                "required": false
              },
              "observedAt": {
                "type": "timestamp",
                "required": false
              }
            }
          }
        }
      }
    },
    "pool_snapshot": {
      "index_view": {
        "kind": "account",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "pump-amm-mainnet",
          "record_kind": "account",
          "record_name": "PoolMetadata",
          "resource_input": "pool",
          "resource_field": "resource_id",
          "notes": "Read the latest projected state row by pool/resource id."
        },
        "projection": {
          "projection_kind": "snapshot",
          "group_by": [
            "resource_id"
          ]
        },
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          }
        },
        "read_output": {
          "type": "object",
          "source": "$items.0",
          "object_schema": {
            "entity_type": "pump_pool",
            "identity_fields": [
              "pool"
            ],
            "fields": {
              "mint": {
                "type": "pubkey",
                "required": false
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "quoteMint": {
                "type": "pubkey",
                "required": false
              },
              "baseDecimals": {
                "type": "u8",
                "required": false
              },
              "quoteDecimals": {
                "type": "u8",
                "required": false
              },
              "coinCreator": {
                "type": "pubkey",
                "required": false
              },
              "isCashbackCoin": {
                "type": "bool",
                "required": false
              },
              "observedAt": {
                "type": "timestamp",
                "required": false
              }
            }
          }
        }
      }
    },
    "trade_feed": {
      "index_view": {
        "kind": "feed",
        "canonical": {
          "source": "indexed_idl_records",
          "protocol_id": "pump-amm-mainnet",
          "record_kind": "event",
          "record_name": [
            "BuyEvent",
            "SellEvent"
          ],
          "subject_input": "pool",
          "subject_field": "subject_id",
          "resource_input": "pool",
          "resource_field": "resource_id",
          "time_field": "event_time",
          "notes": "Recent raw Pump AMM trade records from the canonical append-only IDL log."
        },
        "projection": {
          "projection_kind": "feed",
          "group_by": [
            "subject_id"
          ],
          "sort_by": [
            {
              "field": "event_time",
              "dir": "desc"
            }
          ]
        },
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          },
          "limit": {
            "type": "u16",
            "required": false,
            "default": 50
          }
        },
        "read_output": {
          "type": "array",
          "source": "$items",
          "item_schema": {
            "entity_type": "pump_trade",
            "identity_fields": [
              "signature"
            ],
            "fields": {
              "signature": {
                "type": "string",
                "required": true
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "participant": {
                "type": "pubkey",
                "required": false
              },
              "side": {
                "type": "string",
                "required": true
              },
              "eventTime": {
                "type": "timestamp",
                "required": true
              },
              "baseAmountAtomic": {
                "type": "u64",
                "required": true
              },
              "quoteAmountAtomic": {
                "type": "u64",
                "required": true
              },
              "poolBaseReservesAtomic": {
                "type": "u64",
                "required": false
              },
              "poolQuoteReservesAtomic": {
                "type": "u64",
                "required": false
              },
              "coinCreator": {
                "type": "pubkey",
                "required": false
              }
            }
          }
        }
      }
    },
    "market_cap_series": {
      "index_view": {
        "kind": "series",
        "canonical": {
          "source": "indexed_series_1m",
          "protocol_id": "pump-amm-mainnet",
          "series_id": "pump.market.1m",
          "subject_input": "pool",
          "subject_field": "subject_id",
          "resource_input": "pool",
          "time_field": "bucket_start",
          "notes": "Raw 1m Pump AMM trade amount series projected from canonical trade records."
        },
        "projection": {
          "projection_kind": "series",
          "source_operation": "trade_feed",
          "group_by": [
            "subject_id"
          ],
          "bucket": "1m",
          "fill_mode": "sparse",
          "aggregations": [
            {
              "name": "open",
              "field": "quoteAmountAtomic",
              "fn": "first"
            },
            {
              "name": "high",
              "field": "quoteAmountAtomic",
              "fn": "max"
            },
            {
              "name": "low",
              "field": "quoteAmountAtomic",
              "fn": "min"
            },
            {
              "name": "close",
              "field": "quoteAmountAtomic",
              "fn": "last"
            },
            {
              "name": "volumeQuote",
              "field": "quoteAmountAtomic",
              "fn": "sum"
            },
            {
              "name": "tradeCount",
              "field": "*",
              "fn": "count"
            }
          ]
        },
        "inputs": {
          "pool": {
            "type": "pubkey",
            "required": true
          },
          "limit": {
            "type": "u16",
            "required": false,
            "default": 240
          },
          "from": {
            "type": "string",
            "required": false
          },
          "to": {
            "type": "string",
            "required": false
          },
          "interval": {
            "type": "string",
            "required": false,
            "default": "1m"
          },
          "mode": {
            "type": "string",
            "required": false,
            "default": "sparse"
          }
        },
        "read_output": {
          "type": "array",
          "source": "$items",
          "item_schema": {
            "entity_type": "pump_market_series_point",
            "identity_fields": [
              "bucketStart"
            ],
            "fields": {
              "bucketStart": {
                "type": "timestamp",
                "required": true
              },
              "open": {
                "type": "number",
                "required": false
              },
              "high": {
                "type": "number",
                "required": false
              },
              "low": {
                "type": "number",
                "required": false
              },
              "close": {
                "type": "number",
                "required": false
              },
              "volumeQuote": {
                "type": "number",
                "required": true
              },
              "tradeCount": {
                "type": "u32",
                "required": true
              }
            }
          }
        }
      }
    },
    "ranked_active_tokens": {
      "index_view": {
        "kind": "ranking",
        "canonical": {
          "source": "indexed_idl_records",
          "protocol_id": "pump-amm-mainnet",
          "record_kind": "event",
          "record_name": [
            "BuyEvent",
            "SellEvent"
          ],
          "time_field": "event_time",
          "notes": "Ranking is computed from raw Pump AMM trades plus raw pool metadata."
        },
        "projection": {
          "projection_kind": "ranking",
          "group_by": [
            "subject_id"
          ],
          "ranking": {
            "state_operation": "resolve_pool",
            "window_hours_input": "window_hours",
            "max_activity_age_minutes_input": "max_activity_age_minutes",
            "min_liquidity_input": "min_liquidity",
            "min_volume_input": "min_volume",
            "default_window_hours": 24,
            "default_max_activity_age_minutes": 30,
            "quote_mint_input": "quote_mint",
            "default_quote_mint": "So11111111111111111111111111111111111111112",
            "event_fields": {
              "market_type": "marketType",
              "participant": "participant",
              "side": "side",
              "volume": "quoteAmountAtomic"
            },
            "state_fields": {
              "market_type": "marketType",
              "quote_mint": "quoteMint",
              "liquidity": "poolQuoteReservesAtomic",
              "pool": "pool",
              "mint": "mint"
            }
          }
        },
        "inputs": {
          "quote_mint": {
            "type": "pubkey",
            "required": false,
            "default": "So11111111111111111111111111111111111111112"
          },
          "window_hours": {
            "type": "u32",
            "required": false,
            "default": 24
          },
          "max_activity_age_minutes": {
            "type": "u32",
            "required": false,
            "default": 30
          },
          "min_liquidity": {
            "type": "u64",
            "required": false,
            "default": 0
          },
          "min_volume": {
            "type": "u64",
            "required": false,
            "default": 0
          }
        },
        "read_output": {
          "type": "array",
          "source": "$items",
          "item_schema": {
            "entity_type": "pump_ranked_token",
            "identity_fields": [
              "mint"
            ],
            "fields": {
              "mint": {
                "type": "pubkey",
                "required": false
              },
              "pool": {
                "type": "pubkey",
                "required": true
              },
              "marketType": {
                "type": "string",
                "required": true
              },
              "quoteMint": {
                "type": "pubkey",
                "required": false
              },
              "liquidityQuote": {
                "type": "number",
                "required": true
              },
              "volumeWindowQuote": {
                "type": "number",
                "required": true
              },
              "tradeCountWindow": {
                "type": "u32",
                "required": true
              },
              "uniqueTradersWindow": {
                "type": "u32",
                "required": true
              },
              "buyCountWindow": {
                "type": "u32",
                "required": true
              },
              "sellCountWindow": {
                "type": "u32",
                "required": true
              },
              "lastTradeAt": {
                "type": "timestamp",
                "required": false
              },
              "warnings": {
                "type": "string[]",
                "required": true
              },
              "score": {
                "type": "number",
                "required": true
              }
            }
          }
        }
      }
    }
  }
}
