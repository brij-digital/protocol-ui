{
  "kind": "aidl.v0.1",
  "target": {
    "output": "public/idl/pump_amm.meta.json",
    "schema": "meta-idl.v0.6",
    "schemaPath": "/idl/meta_idl.schema.v0.6.json",
    "version": "0.2.0",
    "protocolId": "pump-amm-mainnet"
  },
  "templates": {
    "pump.buy.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey"
        },
        "quote_amount_in": {
          "type": "u64"
        },
        "slippage_bps": {
          "type": "u16"
        },
        "track_volume": {
          "type": "bool"
        }
      },
      "expand": {
        "instruction": "buy",
        "discover": [
          {
            "name": "pool_candidates",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": false,
            "commitment": "confirmed",
            "account_pubkeys": "$input.pool",
            "filters": [
              {
                "memcmp": {
                  "offset": 43,
                  "bytesFrom": "$param.base_mint"
                }
              },
              {
                "memcmp": {
                  "offset": 75,
                  "bytesFrom": "$param.quote_mint"
                }
              }
            ],
            "where": [
              {
                "path": "decoded.base_mint",
                "op": "=",
                "value": "$param.base_mint"
              },
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 10,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "lpSupply": "$decoded.lp_supply",
              "coinCreator": "$decoded.coin_creator"
            }
          },
          {
            "name": "selected_pool",
            "discover": "discover.pick_list_item_by_value",
            "items": "$pool_candidates",
            "value_path": "pool",
            "match_value": "$input.pool"
          }
        ],
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "pool_data",
            "resolver": "decode_account",
            "address": "$selected_pool.pool",
            "account_type": "Pool"
          },
          {
            "name": "global_config",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_config"
            ]
          },
          {
            "name": "global_config_data",
            "resolver": "decode_account",
            "address": "$global_config",
            "account_type": "GlobalConfig"
          },
          {
            "name": "base_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.base_mint"
          },
          {
            "name": "quote_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.quote_mint"
          },
          {
            "name": "user_base_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "name": "user_quote_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "name": "coin_creator_vault_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:creator_vault",
              "$pool_data.coin_creator"
            ]
          },
          {
            "name": "coin_creator_vault_ata",
            "resolver": "ata",
            "owner": "$coin_creator_vault_authority",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "global_volume_accumulator",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_volume_accumulator"
            ]
          },
          {
            "name": "user_volume_accumulator",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:user_volume_accumulator",
              "$wallet"
            ]
          },
          {
            "name": "user_volume_accumulator_wsol_ata",
            "resolver": "ata",
            "owner": "$user_volume_accumulator",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "event_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:__event_authority"
            ]
          },
          {
            "name": "fee_config",
            "resolver": "pda",
            "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
            "seeds": [
              "utf8:fee_config",
              "$protocol.programId"
            ]
          },
          {
            "name": "fee_config_data",
            "resolver": "decode_account",
            "address": "$fee_config",
            "account_type": "FeeConfig"
          },
          {
            "name": "pump_pool_authority",
            "resolver": "pda",
            "program_id": "6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P",
            "seeds": [
              "utf8:pool-authority",
              "$pool_data.base_mint"
            ]
          },
          {
            "name": "pool_base_reserve_atomic",
            "resolver": "token_account_balance",
            "address": "$pool_data.pool_base_token_account"
          },
          {
            "name": "pool_quote_reserve_atomic",
            "resolver": "token_account_balance",
            "address": "$pool_data.pool_quote_token_account"
          },
          {
            "name": "base_mint_supply_atomic",
            "resolver": "token_supply",
            "mint": "$pool_data.base_mint"
          },
          {
            "name": "pool_v2",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:pool-v2",
              "$pool_data.base_mint"
            ]
          }
        ],
        "compute_refs": [
          "pump.buy.v1.fees_and_amounts"
        ],
        "args": {
          "base_amount_out": "$base_amount_out",
          "max_quote_amount_in": "$max_quote_amount_in",
          "track_volume": "$param.track_volume"
        },
        "accounts": {
          "pool": "$selected_pool.pool",
          "user": "$wallet",
          "global_config": "$global_config",
          "base_mint": "$pool_data.base_mint",
          "quote_mint": "$pool_data.quote_mint",
          "user_base_token_account": "$user_base_token_account",
          "user_quote_token_account": "$user_quote_token_account",
          "pool_base_token_account": "$pool_data.pool_base_token_account",
          "pool_quote_token_account": "$pool_data.pool_quote_token_account",
          "protocol_fee_recipient": "$protocol_fee_recipient",
          "protocol_fee_recipient_token_account": "$protocol_fee_recipient_token_account",
          "base_token_program": "$base_token_program",
          "quote_token_program": "$quote_token_program",
          "system_program": "11111111111111111111111111111111",
          "associated_token_program": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
          "event_authority": "$event_authority",
          "program": "$protocol.programId",
          "coin_creator_vault_ata": "$coin_creator_vault_ata",
          "coin_creator_vault_authority": "$coin_creator_vault_authority",
          "global_volume_accumulator": "$global_volume_accumulator",
          "user_volume_accumulator": "$user_volume_accumulator",
          "fee_config": "$fee_config",
          "fee_program": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ"
        },
        "remaining_accounts": "$remaining_accounts"
      }
    },
    "pump.list_tokens.v1": {
      "params": {
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112"
        }
      },
      "expand": {
        "discover": [
          {
            "name": "pool_candidates",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": true,
            "commitment": "confirmed",
            "where": [
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.index",
                "dir": "desc"
              },
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 30,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "index": "$decoded.index",
              "lpSupply": "$decoded.lp_supply",
              "coinCreator": "$decoded.coin_creator",
              "isCashbackCoin": "$decoded.is_cashback_coin"
            },
            "or_filters": [
              [
                {
                  "memcmp": {
                    "offset": 75,
                    "bytesFrom": "$param.quote_mint"
                  }
                }
              ]
            ]
          }
        ]
      }
    },
    "pump.view_pool.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112"
        }
      },
      "expand": {
        "discover": [
          {
            "name": "pool_detail",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": true,
            "commitment": "confirmed",
            "or_filters": [
              [
                {
                  "memcmp": {
                    "offset": 43,
                    "bytesFrom": "$param.base_mint"
                  }
                },
                {
                  "memcmp": {
                    "offset": 75,
                    "bytesFrom": "$param.quote_mint"
                  }
                }
              ]
            ],
            "where": [
              {
                "path": "decoded.base_mint",
                "op": "=",
                "value": "$param.base_mint"
              },
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.index",
                "dir": "desc"
              },
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 1,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "index": "$decoded.index",
              "lpSupply": "$decoded.lp_supply",
              "poolBaseTokenAccount": "$decoded.pool_base_token_account",
              "poolQuoteTokenAccount": "$decoded.pool_quote_token_account",
              "coinCreator": "$decoded.coin_creator",
              "isCashbackCoin": "$decoded.is_cashback_coin"
            }
          }
        ]
      }
    },
    "pump.sell.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey"
        },
        "base_amount_in": {
          "type": "u64"
        },
        "min_quote_amount_out": {
          "type": "u64"
        }
      },
      "expand": {
        "instruction": "sell",
        "discover": [
          {
            "name": "pool_candidates",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": false,
            "commitment": "confirmed",
            "account_pubkeys": "$input.pool",
            "filters": [
              {
                "memcmp": {
                  "offset": 43,
                  "bytesFrom": "$param.base_mint"
                }
              },
              {
                "memcmp": {
                  "offset": 75,
                  "bytesFrom": "$param.quote_mint"
                }
              }
            ],
            "where": [
              {
                "path": "decoded.base_mint",
                "op": "=",
                "value": "$param.base_mint"
              },
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 10,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "lpSupply": "$decoded.lp_supply",
              "coinCreator": "$decoded.coin_creator"
            }
          },
          {
            "name": "selected_pool",
            "discover": "discover.pick_list_item_by_value",
            "items": "$pool_candidates",
            "value_path": "pool",
            "match_value": "$input.pool"
          }
        ],
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "pool_data",
            "resolver": "decode_account",
            "address": "$selected_pool.pool",
            "account_type": "Pool"
          },
          {
            "name": "global_config",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_config"
            ]
          },
          {
            "name": "global_config_data",
            "resolver": "decode_account",
            "address": "$global_config",
            "account_type": "GlobalConfig"
          },
          {
            "name": "base_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.base_mint"
          },
          {
            "name": "quote_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.quote_mint"
          },
          {
            "name": "user_base_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "name": "user_quote_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "name": "coin_creator_vault_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:creator_vault",
              "$pool_data.coin_creator"
            ]
          },
          {
            "name": "coin_creator_vault_ata",
            "resolver": "ata",
            "owner": "$coin_creator_vault_authority",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "event_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:__event_authority"
            ]
          },
          {
            "name": "fee_config",
            "resolver": "pda",
            "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
            "seeds": [
              "utf8:fee_config",
              "$protocol.programId"
            ]
          }
        ],
        "compute_refs": [
          "pump.sell.v1.fee_accounts"
        ],
        "args": {
          "base_amount_in": "$param.base_amount_in",
          "min_quote_amount_out": "$param.min_quote_amount_out"
        },
        "accounts": {
          "pool": "$selected_pool.pool",
          "user": "$wallet",
          "global_config": "$global_config",
          "base_mint": "$pool_data.base_mint",
          "quote_mint": "$pool_data.quote_mint",
          "user_base_token_account": "$user_base_token_account",
          "user_quote_token_account": "$user_quote_token_account",
          "pool_base_token_account": "$pool_data.pool_base_token_account",
          "pool_quote_token_account": "$pool_data.pool_quote_token_account",
          "protocol_fee_recipient": "$protocol_fee_recipient",
          "protocol_fee_recipient_token_account": "$protocol_fee_recipient_token_account",
          "base_token_program": "$base_token_program",
          "quote_token_program": "$quote_token_program",
          "system_program": "11111111111111111111111111111111",
          "associated_token_program": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
          "event_authority": "$event_authority",
          "program": "$protocol.programId",
          "coin_creator_vault_ata": "$coin_creator_vault_ata",
          "coin_creator_vault_authority": "$coin_creator_vault_authority",
          "fee_config": "$fee_config",
          "fee_program": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ"
        }
      }
    }
  },
  "operations": {
    "list_tokens": {
      "inputs": {
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "label": "Quote Mint"
        }
      },
      "useTemplate": [
        {
          "template": "pump.list_tokens.v1",
          "with": {
            "quote_mint": "$input.quote_mint"
          }
        }
      ],
      "view": {
        "kind": "list",
        "source": "rpc",
        "entity_keys": [
          "pool"
        ]
      },
      "read_output": {
        "source": "$derived.pool_candidates",
        "type": "list",
        "title": "Recent Pump AMM tokens",
        "itemLabelFields": [
          "baseMint",
          "pool",
          "index",
          "lpSupply"
        ],
        "maxItems": 20,
        "emptyText": "No Pump AMM token found for this quote mint."
      },
      "label": "List Tokens"
    },
    "view_pool": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true,
          "read_from": "$input.base_mint",
          "ui_editable": false,
          "label": "Base Mint"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "read_from": "$input.quote_mint",
          "ui_editable": false,
          "label": "Quote Mint"
        }
      },
      "useTemplate": [
        {
          "template": "pump.view_pool.v1",
          "with": {
            "base_mint": "$input.base_mint",
            "quote_mint": "$input.quote_mint"
          }
        }
      ],
      "view": {
        "kind": "list",
        "source": "rpc",
        "entity_keys": [
          "pool"
        ]
      },
      "read_output": {
        "source": "$derived.pool_detail",
        "type": "list",
        "title": "Pool snapshot (live RPC)",
        "itemLabelFields": [
          "baseMint",
          "pool",
          "lpSupply",
          "poolBaseTokenAccount",
          "poolQuoteTokenAccount"
        ],
        "maxItems": 1,
        "emptyText": "Pool not found."
      },
      "label": "View Pool"
    },
    "buy": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true,
          "read_from": "$input.base_mint",
          "ui_editable": false,
          "label": "Base Mint"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "read_from": "$input.quote_mint",
          "ui_editable": false,
          "label": "Quote Mint"
        },
        "quote_amount_in": {
          "type": "u64",
          "required": true,
          "label": "Quote Amount In"
        },
        "track_volume": {
          "type": "bool",
          "required": false,
          "default": true,
          "label": "Track Volume"
        },
        "pool": {
          "type": "pubkey",
          "required": false,
          "read_from": "$input.pool",
          "ui_editable": false,
          "label": "Pool"
        },
        "slippage_bps": {
          "type": "u16",
          "required": true,
          "label": "Slippage Bps"
        }
      },
      "useTemplate": [
        {
          "template": "pump.buy.v1",
          "with": {
            "base_mint": "$input.base_mint",
            "quote_mint": "$input.quote_mint",
            "quote_amount_in": "$input.quote_amount_in",
            "slippage_bps": "$input.slippage_bps",
            "track_volume": "$input.track_volume"
          }
        }
      ],
      "label": "Buy"
    },
    "sell": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true,
          "read_from": "$input.base_mint",
          "ui_editable": false,
          "label": "Base Mint"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "read_from": "$input.quote_mint",
          "ui_editable": false,
          "label": "Quote Mint"
        },
        "pool": {
          "type": "pubkey",
          "required": false,
          "read_from": "$input.pool",
          "ui_editable": false,
          "label": "Pool"
        },
        "base_amount_in": {
          "type": "u64",
          "required": true,
          "label": "Base Amount In"
        },
        "min_quote_amount_out": {
          "type": "u64",
          "required": false,
          "default": "1",
          "label": "Min Quote Amount Out"
        }
      },
      "useTemplate": [
        {
          "template": "pump.sell.v1",
          "with": {
            "base_mint": "$input.base_mint",
            "quote_mint": "$input.quote_mint",
            "base_amount_in": "$input.base_amount_in",
            "min_quote_amount_out": "$input.min_quote_amount_out"
          }
        }
      ],
      "label": "Sell"
    }
  },
  "apps": {
    "token_terminal": {
      "title": "Pump Token Terminal",
      "description": "Step 1: list tokens. Step 2: pool snapshot. Step 3/4: buy or sell.",
      "entry_step": "discover",
      "steps": [
