  "operations": {
    "list_tokens": {
      "inputs": {
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "label": "Quote Mint"
        },
        "min_last_seen_slot": {
          "type": "u64",
          "required": false,
          "default": "0",
          "label": "Min Last Seen Slot"
        }
      },
      "useTemplate": [
        {
          "template": "pump.list_tokens.v1",
          "with": {
            "quote_mint": "$input.quote_mint"
          }
        }
      ],
      "view": {
        "kind": "search",
        "source": "indexed",
        "entity_type": "pump_pool",
        "title": "List tokens",
        "description": "List Pump AMM pools for a quote mint.",
        "bootstrap": {
          "kind": "scan_accounts",
          "source": "rpc.getProgramAccounts",
          "program_id": "$protocol.programId",
          "account_type": "Pool",
          "lookback_seconds": 300,
          "max_pages": 5,
          "retention_seconds": 3600,
          "filters": []
        },
        "refresh": {
          "mode": "stream",
          "source": "program_account_updates"
        },
        "query": {
          "indexed_filters": {
            "all": [
              {
                "field": "memcmp.75",
                "op": "=",
                "value": "$input.quote_mint"
              }
            ]
          },
          "filters": {
            "all": [
              {
                "field": "decoded.quote_mint",
                "op": "=",
                "value": "$input.quote_mint"
              },
              {
                "field": "account.lastSeenSlot",
                "op": ">=",
                "value": "$input.min_last_seen_slot"
              },
              {
                "field": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ]
          },
          "hydrate": {
            "mode": "accounts",
            "candidate_limit": 30,
            "fields": [
              "pubkey",
              "data_bytes",
              "slot"
            ]
          },
          "decode": {
            "account_type": "Pool"
          },
          "sort": [
            {
              "field": "account.lastSeenSlot",
              "dir": "desc",
              "mode": "indexed"
            },
            {
              "field": "decoded.index",
              "dir": "desc",
              "mode": "indexed"
            },
            {
              "field": "decoded.lp_supply",
              "dir": "desc",
              "mode": "indexed_then_live_refine",
              "candidate_limit": 30
            }
          ],
          "limit": 30,
          "select": {
            "pool": "$account.pubkey",
            "baseMint": "$decoded.base_mint",
            "quoteMint": "$decoded.quote_mint",
            "index": "$decoded.index",
            "lpSupply": "$decoded.lp_supply",
            "coinCreator": "$decoded.coin_creator",
            "isCashbackCoin": "$decoded.is_cashback_coin"
          }
        }
      },
      "read_output": {
        "source": "$derived.pool_candidates",
        "type": "list",
        "title": "Recent Pump AMM tokens",
        "itemLabelFields": [
          "baseMint",
          "pool",
          "index",
          "lpSupply"
        ],
        "maxItems": 20,
        "emptyText": "No Pump AMM token found for this quote mint."
      },
      "label": "List Tokens"
    },
    "view_pool": {
      "inputs": {
        "base_mint": {
          "type": "pubkey",
          "required": true,
          "read_from": "$input.base_mint",
          "ui_mode": "readonly",
          "label": "Base Mint"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112",
          "read_from": "$input.quote_mint",
          "ui_mode": "readonly",
          "label": "Quote Mint"
        }
      },
      "useTemplate": [
        {
          "template": "pump.view_pool.v1",
          "with": {
            "base_mint": "$input.base_mint",
            "quote_mint": "$input.quote_mint"
          }
        }
      ],
      "view": {
        "kind": "search",
        "source": "indexed",
        "entity_type": "pump_pool",
        "title": "View pool",
        "description": "Find a Pump AMM pool for a base/quote pair.",
        "bootstrap": {
          "kind": "scan_accounts",
          "source": "rpc.getProgramAccounts",
          "program_id": "$protocol.programId",
          "account_type": "Pool",
          "lookback_seconds": 300,
          "max_pages": 5,
          "retention_seconds": 3600,
          "filters": []
        },
        "refresh": {
          "mode": "stream",
          "source": "program_account_updates"
        },
        "query": {
          "indexed_filters": {
            "all": [
              {
                "field": "memcmp.43",
                "op": "=",
                "value": "$input.base_mint"
              },
              {
                "field": "memcmp.75",
                "op": "=",
                "value": "$input.quote_mint"
              }
            ]
          },
          "filters": {
            "all": [
              {
                "field": "decoded.base_mint",
                "op": "=",
                "value": "$input.base_mint"
              },
              {
                "field": "decoded.quote_mint",
                "op": "=",
                "value": "$input.quote_mint"
              },
              {
                "field": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ]
          },
          "hydrate": {
            "mode": "accounts",
            "candidate_limit": 5,
            "fields": [
              "pubkey",
              "data_bytes",
              "slot"
            ]
          },
          "decode": {
            "account_type": "Pool"
          },
          "sort": [
            {
              "field": "decoded.index",
              "dir": "desc",
              "mode": "indexed"
            },
            {
              "field": "decoded.lp_supply",
              "dir": "desc",
              "mode": "indexed_then_live_refine",
              "candidate_limit": 5
            }
          ],
          "limit": 1,
          "select": {
            "pool": "$account.pubkey",
            "baseMint": "$decoded.base_mint",
            "quoteMint": "$decoded.quote_mint",
            "index": "$decoded.index",
            "lpSupply": "$decoded.lp_supply",
            "poolBaseTokenAccount": "$decoded.pool_base_token_account",
            "poolQuoteTokenAccount": "$decoded.pool_quote_token_account",
            "coinCreator": "$decoded.coin_creator",
            "isCashbackCoin": "$decoded.is_cashback_coin"
          }
        }
      },
      "read_output": {
        "source": "$derived.pool_detail",
        "type": "list",
        "title": "Pool snapshot (live RPC)",
        "itemLabelFields": [
          "baseMint",
          "pool",
          "lpSupply",
          "poolBaseTokenAccount",
          "poolQuoteTokenAccount"
        ],
        "maxItems": 1,
        "emptyText": "Pool not found."
      },
      "label": "View Pool"
    },
