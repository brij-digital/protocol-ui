{
  "kind": "aidl.v0.1",
  "target": {
    "output": "public/idl/orca_whirlpool.meta.json",
    "schema": "meta-idl.v0.6",
    "schemaPath": "/idl/meta_idl.schema.v0.6.json",
    "version": "0.2.0",
    "protocolId": "orca-whirlpool-mainnet"
  },
  "templates": {
    "orca.swap_exact_in.v2": {
      "params": {
        "token_in_mint": {
          "type": "token_mint"
        },
        "amount_in": {
          "type": "u64"
        },
        "slippage_bps": {
          "type": "u16"
        },
        "estimated_out": {
          "type": "u64"
        }
      },
      "expand": {
        "instruction": "swap_v2",
        "discover": [],
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "whirlpool_data",
            "resolver": "decode_account",
            "address": "$input.whirlpool",
            "account_type": "Whirlpool"
          },
          {
            "name": "token_owner_account_a",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_a"
          },
          {
            "name": "token_owner_account_b",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$whirlpool_data.token_mint_b"
          },
          {
            "name": "oracle",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:oracle",
              "$input.whirlpool"
            ]
          }
        ],
        "compute": [
          {
            "name": "a_to_b",
            "eq": [
              "$whirlpool_data.token_mint_a",
              "$param.token_in_mint"
            ]
          },
          {
            "name": "tick_array_direction",
            "if": {
              "condition": "$a_to_b",
              "then": -1,
              "else": 1
            }
          },
          {
            "name": "ticks_per_array",
            "mul": [
              "$whirlpool_data.tick_spacing",
              88
            ]
          },
          {
            "name": "direction_step",
            "mul": [
              "$ticks_per_array",
              "$tick_array_direction"
            ]
          },
          {
            "name": "current_array_index",
            "floor_div": [
              "$whirlpool_data.tick_current_index",
              "$ticks_per_array"
            ]
          },
          {
            "name": "current_start_index",
            "mul": [
              "$current_array_index",
              "$ticks_per_array"
            ]
          },
          {
            "name": "tick_array_starts",
            "compute": "list.range_map",
            "base": "$current_start_index",
            "step": "$direction_step",
            "count": 3
          },
          {
            "name": "tick_arrays",
            "pda": {
              "program_id": "$protocol.programId",
              "map_over": "$tick_array_starts",
              "seeds": [
                {
                  "kind": "utf8",
                  "value": "tick_array"
                },
                {
                  "kind": "pubkey",
                  "value": "$input.whirlpool"
                },
                {
                  "kind": "item_utf8"
                }
              ]
            }
          },
          {
            "name": "slippage_keep_bps",
            "sub": [
              "10000",
              "$param.slippage_bps"
            ]
          },
          {
            "name": "other_amount_threshold_numerator",
            "mul": [
              "$param.estimated_out",
              "$slippage_keep_bps"
            ]
          },
          {
            "name": "other_amount_threshold",
            "floor_div": [
              "$other_amount_threshold_numerator",
              "10000"
            ]
          }
        ],
        "args": {
          "amount": "$param.amount_in",
          "other_amount_threshold": "$other_amount_threshold",
          "sqrt_price_limit": "0",
          "amount_specified_is_input": true,
          "a_to_b": "$a_to_b",
          "remaining_accounts_info": null
        },
        "accounts": {
          "token_program_a": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
          "token_program_b": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",
          "memo_program": "MemoSq4gqABAXKb96qnH8TysNcWxMyWCqXgDLGmfcHr",
          "token_authority": "$wallet",
          "whirlpool": "$input.whirlpool",
          "token_mint_a": "$whirlpool_data.token_mint_a",
          "token_mint_b": "$whirlpool_data.token_mint_b",
          "token_owner_account_a": "$token_owner_account_a",
          "token_vault_a": "$whirlpool_data.token_vault_a",
          "token_owner_account_b": "$token_owner_account_b",
          "token_vault_b": "$whirlpool_data.token_vault_b",
          "tick_array_0": "$tick_arrays.0",
          "tick_array_1": "$tick_arrays.1",
          "tick_array_2": "$tick_arrays.2",
          "oracle": "$oracle"
        },
        "post": [
          {
            "kind": "spl_token_close_account",
            "account": "$token_owner_account_a",
            "destination": "$wallet",
            "owner": "$wallet",
            "when": {
              "all": [
                {
                  "equals": [
                    "$input.unwrap_sol_output",
                    true
                  ]
                },
                {
                  "equals": [
                    "$a_to_b",
                    false
                  ]
                },
                {
                  "equals": [
                    "$input.token_out_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          },
          {
            "kind": "spl_token_close_account",
            "account": "$token_owner_account_b",
            "destination": "$wallet",
            "owner": "$wallet",
            "when": {
              "all": [
                {
                  "equals": [
                    "$input.unwrap_sol_output",
                    true
                  ]
                },
                {
                  "equals": [
                    "$a_to_b",
                    true
                  ]
                },
                {
                  "equals": [
                    "$input.token_out_mint",
                    "So11111111111111111111111111111111111111112"
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "orca.list_pools.v1": {
      "params": {
        "token_in_mint": {
          "type": "token_mint"
        },
        "token_out_mint": {
          "type": "token_mint"
        }
      },
      "expand": {
        "discover": [
          {
            "name": "pool_candidates",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Whirlpool",
            "commitment": "confirmed",
            "or_filters": [
              [
                {
                  "memcmp": {
                    "offset": 101,
                    "bytesFrom": "$param.token_in_mint"
                  }
                },
                {
                  "memcmp": {
                    "offset": 181,
                    "bytesFrom": "$param.token_out_mint"
                  }
                }
              ],
              [
                {
                  "memcmp": {
                    "offset": 101,
                    "bytesFrom": "$param.token_out_mint"
                  }
                },
                {
                  "memcmp": {
                    "offset": 181,
                    "bytesFrom": "$param.token_in_mint"
                  }
                }
              ]
            ],
            "where": [],
            "sort": [
              {
                "path": "decoded.liquidity",
                "dir": "desc"
              }
            ],
            "limit": 20,
            "select": {
              "whirlpool": "$account.pubkey",
              "tokenMintA": "$decoded.token_mint_a",
              "tokenMintB": "$decoded.token_mint_b",
              "tickSpacing": "$decoded.tick_spacing",
              "liquidity": "$decoded.liquidity"
            }
          }
        ],
        "derive": [],
        "compute": [],
        "args": {},
        "accounts": {}
      }
    }
  },
  "operations": {
    "swap_exact_in": {
      "inputs": {
        "token_in_mint": {
          "type": "token_mint",
          "required": true
        },
        "token_out_mint": {
          "type": "token_mint",
          "required": true
        },
        "amount_in": {
          "type": "u64",
          "required": true
        },
        "slippage_bps": {
          "type": "u16",
          "required": true
        },
        "estimated_out": {
          "type": "u64",
          "required": false,
          "default": "0"
        },
        "whirlpool": {
          "type": "pubkey",
          "required": true
        },
        "unwrap_sol_output": {
          "type": "bool",
          "required": false,
          "default": true
        }
      },
      "useTemplate": [
        {
          "template": "orca.swap_exact_in.v2",
          "with": {
            "token_in_mint": "$input.token_in_mint",
            "amount_in": "$input.amount_in",
            "slippage_bps": "$input.slippage_bps",
            "estimated_out": "$input.estimated_out"
          }
        }
      ]
    },
    "list_pools": {
      "inputs": {
        "token_in_mint": {
          "type": "token_mint",
          "required": true,
          "ui_example": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
        },
        "token_out_mint": {
          "type": "token_mint",
          "required": true,
          "ui_example": "So11111111111111111111111111111111111111112"
        }
      },
      "use": [
        {
          "template": "orca.list_pools.v1",
          "with": {
            "token_in_mint": "$input.token_in_mint",
            "token_out_mint": "$input.token_out_mint"
          }
        }
      ],
      "view": {
        "bootstrap": {
          "kind": "query",
          "steps": [
            "pool_candidates"
          ]
        },
        "stream": {
          "kind": "event",
          "source": "substreams.transactions_by_programid_without_votes",
          "filter": "program:$protocol.programId",
          "cursor_path": "$event.slot",
          "account_keys_paths": [
            "$event.transaction.message.accountKeys",
            "$event.meta.loadedWritableAddresses",
            "$event.meta.loadedReadonlyAddresses"
          ]
        },
        "mapping": {
          "source": "$derived.pool_candidates",
          "select": {
            "whirlpool": "$item.whirlpool",
            "tokenMintA": "$item.tokenMintA",
            "tokenMintB": "$item.tokenMintB",
            "tickSpacing": "$item.tickSpacing",
            "liquidity": "$item.liquidity"
          },
          "transforms": [
            "sort(liquidity desc)"
          ]
        },
        "entity_keys": [
          "whirlpool"
        ]
      },
      "read_output": {
        "type": "array",
        "source": "$derived.pool_candidates",
        "title": "Pools found",
        "empty_text": "No Whirlpool pool found for this pair.",
        "max_items": 20,
        "item_label_fields": ["whirlpool", "tickSpacing", "liquidity"]
      }
    }
  },
  "apps": {
    "swap_from_discovery": {
      "title": "Discover -> Swap",
      "description": "List pools for a pair, then execute swap on the selected pool.",
      "entry_step": "discover",
      "steps": [
        {
          "id": "discover",
          "operation": "list_pools",
          "title": "Discover Pools",
          "description": "Fetch Whirlpool candidates sorted by liquidity.",
          "actions": [
            {
              "id": "discover_run",
              "kind": "run",
              "label": "Find Pools",
              "mode": "view",
              "variant": "primary"
            }
          ],
          "blocking": {
            "depends_on": [],
            "requires_paths": []
          },
          "success": {
            "kind": "selection_made",
            "path": "$steps.discover.derived.selected_pool"
          },
          "transitions": [
            {
              "on": "success",
              "to": "swap"
            }
          ],
          "ui": {
            "kind": "select_from_derived",
            "source": "pool_candidates",
            "bind_to": "selected_pool",
            "value_path": "whirlpool",
            "label_fields": [
              "whirlpool",
              "tickSpacing",
              "liquidity"
            ],
            "require_selection": true,
            "auto_advance": true,
            "title": "Select a pool",
            "description": "Pick one discovered pool to continue to swap."
          }
        },
        {
          "id": "swap",
          "operation": "swap_exact_in",
          "title": "Swap By Pool",
          "description": "Run simulation or send on selected Whirlpool.",
          "actions": [
            {
              "id": "swap_back",
              "kind": "back",
              "label": "Back to Pools",
              "variant": "ghost"
            },
            {
              "id": "swap_simulate",
              "kind": "run",
              "label": "Simulate Swap",
              "mode": "simulate",
              "variant": "primary"
            },
            {
              "id": "swap_send",
              "kind": "run",
              "label": "Send Transaction",
              "mode": "send",
              "variant": "secondary"
            }
          ],
          "blocking": {
            "depends_on": ["discover"],
            "requires_paths": ["$steps.discover.derived.selected_pool.whirlpool"]
          },
          "success": {
            "kind": "operation_ok"
          },
          "transitions": [],
          "input_from": {
            "token_in_mint": "$steps.discover.input.token_in_mint",
            "token_out_mint": "$steps.discover.input.token_out_mint",
            "whirlpool": "$steps.discover.derived.selected_pool.whirlpool"
          }
        }
      ]
    }
  }
}
