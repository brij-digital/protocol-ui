{
  "name": "ec-ai-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "aidl:compile": "node scripts/compile-aidl.mjs",
    "aidl:check": "node scripts/compile-aidl.mjs --check",
    "pack:init": "node scripts/pack-init.mjs",
    "pack:doctor": "node scripts/pack-doctor.mjs",
    "pack:check": "node scripts/check-protocol-packs.mjs",
    "pack:rpc-check": "node scripts/check-protocol-rpc.mjs",
    "ci:protocol-packs": "npm run aidl:check && npm run pack:check",
    "ci:protocol-packs:rpc": "npm run ci:protocol-packs && npm run pack:rpc-check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@agentform/apppack-runtime": "git+https://github.com/brij-digital/apppack-runtime.git#v0.1.1",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "decimal.js": "^10.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "buffer": "^6.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "process": "^0.11.10",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0"
  }
}
