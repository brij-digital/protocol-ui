{
  "name": "ec-ai-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "npmrc:check": "node scripts/check-local-npmrc.mjs",
    "schemas:sync": "node scripts/sync-runtime-schemas.mjs",
    "schemas:check": "node scripts/sync-runtime-schemas.mjs --check",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "codama:check": "node scripts/check-codama-source.mjs",
    "aidl:compile": "npm run schemas:sync && node scripts/compile-aidl.mjs",
    "aidl:check": "npm run schemas:check && node scripts/compile-aidl.mjs --check",
    "pack:init": "node scripts/pack-init.mjs",
    "pack:doctor": "node scripts/pack-doctor.mjs",
    "pack:check": "node scripts/check-protocol-packs.mjs",
    "pack:topology:check": "node scripts/check-pack-topology.mjs",
    "pack:lint": "node scripts/lint-protocol-packs.mjs",
    "pack:complexity": "node scripts/report-pack-complexity.mjs",
    "pack:complexity:enforce": "node scripts/report-pack-complexity.mjs --enforce",
    "pack:rpc-check": "node scripts/check-protocol-rpc.mjs",
    "smoke:pack-metadata": "node scripts/smoke-pack-metadata.mjs",
    "ci:protocol-packs": "npm run npmrc:check && npm run schemas:check && npm run codama:check && npm run pack:check && npm run pack:topology:check && npm run pack:lint && npm run pack:complexity:enforce",
    "ci:protocol-packs:rpc": "npm run ci:protocol-packs && npm run pack:rpc-check",
    "preview": "vite preview",
    "smoke:runtime-import": "node -e \"const pkg=require('./node_modules/@brij-digital/apppack-runtime/package.json'); if (pkg.name !== '@brij-digital/apppack-runtime') throw new Error('runtime package mismatch'); console.log('runtime package ok', pkg.version)\""
  },
  "dependencies": {
    "@brij-digital/apppack-runtime": "^0.1.77",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.28",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "decimal.js": "^10.6.0",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.4.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "buffer": "^6.0.3",
    "codama": "^1.5.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.0",
    "process": "^0.11.10",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.1.0"
  }
}
